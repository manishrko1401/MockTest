qSNo}}</li><li ng-if="!hasSkipOptionSupport" class="label" ng-repeat="question in item.questions track by $index" ng-class="{ \'bookmarked\' : isBookmarked(question.SSNo, question.qSNo), \'attempted\' : isAttempted(question.SSNo, question.qSNo), \'skipped\' : isSkipped(question.SSNo, question.qSNo), \'current-question\': isCurrentQuestion(question.SSNo, question.qSNo), \'subsection-question-disabled\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\' }" ng-click="!(isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\') && sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li></ul></div><div class="questionList-states-railway show-on-railway"><ul><li class="new-legend" ng-repeat="question in section.questions track by $index" ng-class="{ \'reviewed\' : isBookmarked($parent.$index +1, $index+1), \'answered\' : isAttempted($parent.$index +1, $index+1), \'not-answered\': isSkipped($parent.$index + 1, $index + 1), \'current\': isCurrentQuestion($parent.$index + 1, $index + 1) }" ng-click="sideBarItemClicked($parent.$index +1, $index+1)">{{$index + 1}}</li></ul></div></div><button type="button" class="btn btn-theme mar-b8 for-all-exams" style="margin-left: 15px;" ng-if="test.isSectionalSubmit && ((sectionalSummary.length - 1) !== activeSectionIndex) && !shouldShowSubmitSubsectionButton()" ng-click="sectionalSubmitBtnClicked()">Submit Section</button> <button type="button" class="btn btn-theme mar-b8 for-all-exams" style="margin-left: 15px;" ng-if="shouldShowSubmitSubsectionButton()" ng-disabled="isSubsectionProgressionSyncInFlight()" ng-click="subsectionalSubmitBtnClicked()">Submit Sub-section</button></div></div><div class="marks-action"><ul id="mainBtnBox" class="main-btn-box" role="tablist"><li><button type="button" class="btn btn-info-test btn-block" ng-click="setTab(\'qpaper\')">{{\'Question Paper\' }}</button></li><li><button type="button" class="btn btn-info-test btn-block" ng-click="getDynamicInstructions()">{{\'Instructions\' }}</button></li></ul><button type="button" class="btn btn-theme btn-block for-all-exams" ng-click="submitBtnPressed()">{{\'Submit Test\' }}</button> <button type="button" class="btn btn-yellow-green btn-block for-ssc" ng-click="submitBtnPressed()">{{\'Submit Test\' }}</button></div></div></div><div class="calc-pause" ng-if="!isSscNewInterface"><drag-calculator ng-if="isShowCalculator" config="{btnClasses: \'btn-link\'}" is-basic-calc="isBasicCalculator" is-acca-type="false"></drag-calculator><button type="button" id="testFullScreenToggle" class="btn btn-default hidden-xs">{{\'Switch Full Screen\' | translate }}</button> <button type="button" class="btn" ng-click="pauseBtnPressed()" ng-show="!isLiveTest()">{{\'Pause\' | translate }}</button></div><div class="test-page-timer" ng-if="!isSscNewInterface"><h4 class="mar-0 text-nowrap" ng-class="{\'show-timer-alert\': showTimerAlert}"><span class="hidden-xs hidden-sm mar-r8 align-middle">{{getTimerPrompt() | translate}}</span><livetest-timer ng-if="test.sectionTimeSharedFlag" test-duration="{{test.remT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" test-time-over-ptr="testTimeOver" resume-ptr="resumeTimerCB" hide-zero="n" skip-duration="{{test.skipDuration}}" show-alert="$parent.showTimerAlert"></livetest-timer><livetest-timer ng-if="!test.sectionTimeSharedFlag" test-duration="{{activeSectionRemT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" test-time-over-ptr="testTimeOver" active-section-index="{{activeSectionIndex}}" active-sub-section-sss-no="{{activeSubSectionSSSNo}}" hide-zero="n" skip-duration="{{test.skipDuration}}" show-alert="$parent.showTimerAlert"></livetest-timer></h4></div><div class="modal" id="summaryModal" ng-class="{\'asm-summary\': isASMInterface}" tabindex="-1" role="dialog" aria-labelledby="summaryLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-lg"><div class="modal-content" ng-class="{\'asm-scroll-view\': isASMInterface}"><div class="header" ng-if="isASMInterface"><button class="btn btn-gray-1" ng-if="!isTimerPaused && !isTestSubmitted" ng-click="sectionalSummaryModalAction(true)">Skip</button> <button class="btn btn-gray-1" ng-if="!isTimerPaused && isTestSubmitted" ng-click="submitTestCB(true)">Skip</button></div><div class="modal-body" ng-if="!isASMInterface"><h4 class="text-center" ng-show="!isTestPaused"><small>Submit your test</small></h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th translate>Section</th><th translate>No. of questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Not Visited</th><th ng-if="hasSkipOptionSupport" translate>No Options Selected</th></tr></thead><tbody><tr ng-repeat="section in test.sections track by $index" ng-if="!(isSscNewInterface && test.containOptionalSections && test.chooseOptionalSecInTest) && (test.containOptionalSections && !test.chooseOptionalSecInTest || !test.containOptionalSections)"><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsCount($index + 1)}}</td><td data-prompt="Answered">{{getAnsweredCount($index + 1)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCount($index + 1)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCount($index + 1)}}</td><td data-prompt="Not Visited">{{getQuestionsCount($index + 1) - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1) - getNoOptionMarksCount($index + 1)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCount($index + 1)}}</td></tr><tr ng-repeat="section in test.allSections track by $index" ng-if="!isSscNewInterface && test.containOptionalSections && test.chooseOptionalSecInTest"><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptional($index + 1)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptional($index + 1)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptional($index + 1)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptional($index + 1)}}</td><td data-prompt="Not Visited">{{getQuestionsCountForOptional($index + 1) - getAnsweredCountForOptional($index + 1) - getNotAnsweredCountForOptional($index + 1) - getNoOptionMarksCountForOptional($index + 1)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptional($index + 1)}}</td></tr><tr ng-repeat="section in test.allSections track by $index" ng-if="isSscNewInterface && test.containOptionalSections && test.chooseOptionalSecInTest && shouldShowSectionInSummary(section, $index)"><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td><td data-prompt="Not Visited">{{getQuestionsCountForOptionalByIds(section.SSNo, section.SSSNo) - getAnsweredCountForOptionalByIds(section.SSNo, section.SSSNo) - getNotAnsweredCountForOptionalByIds(section.SSNo, section.SSSNo) - getNoOptionMarksCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptionalByIds(section.SSNo, section.SSSNo)}}</td></tr></tbody></table></div></div><div class="modal-body" ng-if="isASMInterface"><h3 class="text-center">Exam Summary</h3><h4 class="text-center" ng-if="!isTestSubmitted"><span ng-if="!isTimerPaused">Break Time:</span><span ng-if="isTimerPaused">Time Left:</span><livetest-timer ng-if="!test.sectionTimeSharedFlag" test-duration="{{activeSectionRemT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" active-section-index="{{activeSectionIndex}}" active-sub-section-sss-no="{{activeSubSectionSSSNo}}" hide-zero="n"></livetest-timer><livetest-timer ng-if="test.sectionTimeSharedFlag" test-duration="{{test.remT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" active-section-index="{{activeSectionIndex}}" hide-zero="n"></livetest-timer><span class="i-circle"><span class="i-tooltip">The next section will automatically begin when this time runs out.</span></span></h4><div class="table-responsive" ng-repeat="section in test.sections.slice().reverse() track by $index" ng-if="!section.isBreak"><h3 ng-if="isSectionVisibleInSummary($index + 1)" class="modal-heading">{{section.title || "Overall"}}</h3><table class="table table-bordered" ng-if="isSectionVisibleInSummary($index + 1)"><thead><tr><th translate>Section</th><th translate>No. of questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Answered & Marked for Review</th></tr></thead><tbody><tr><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsCount(getReverseIndex($index + 1))}}</td><td data-prompt="Answered">{{getAnsweredCount(getReverseIndex($index + 1))}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForASM(getReverseIndex($index + 1))}}</td><td data-prompt="Marked for Review">{{getBookmarkedCount(getReverseIndex($index + 1))}}</td><td data-prompt="Answered & Marked for Review">{{getBookmarkedAndAttempted(getReverseIndex($index + 1))}}</td></tr></tbody></table></div><div class="info-footer"><h3 ng-repeat="section in test.sections" ng-if="maxVisitedSectionIndex < $index + 1 && !section.isBreak">{{section.title}}:<span>(Yet to attempt)</span></h3></div></div><div class="modal-footer" ng-if="isTimerPaused || !isASMInterface"><a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromAttempted" href="/attempted-tests/" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromLivePage" href="/free-live-tests-and-quizzes/" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromLiveAttempted" href="/free-live-tests-and-quizzes/attempted/" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromSearch" href="/search/{{searchTerm}}" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromTestSeries" href="/{{testSeriesUrl}}/test-series" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromScholarshipTest" href="/{{scholarshipTestSlug}}/scholarship-test" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && fromPyp" href="/{{PypTestSlug}}/previous-year-papers" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <a ng-show="isTestPaused && !isTestSubmitted && !isInClass && !fromTestSeries && !fromAttempted && !fromPyp && !fromScholarshipTest && !fromLivePage && !fromLiveAttempted && !fromOrganisation" href="/{{examURL}}/" class="btn btn-theme mar-t0 pull-left" translate>Tests</a> <span ng-show="fromOrganisation && isTestPaused && !isTestSubmitted" class="btn btn-theme mar-t0 pull-left" translate ng-click="backBtnPressed()">Tests</span> <a ng-show="isTestPaused && !isTestSubmitted && isInClass" ng-href="{{backUrl}}" class="btn btn-theme mar-t0 pull-left">{{backTitle}}</a> <button ng-show="!isTestPaused" type="button" class="btn btn-theme mar-t0" data-dismiss="modal">Close</button> <button ng-show="isTestPaused && !isTestSubmitted" type="button" class="btn btn-theme mar-t0" ng-click="resumeBtnPressed()" data-dismiss="modal">Resume Test</button> <button ng-show="!isTestPaused" ng-click="submitTest(false)" type="button" class="btn btn-theme mar-t0" data-dismiss="modal">Submit</button></div></div></div></div><div class="modal modal--instructions" id="instructionsModal"><div class="modal-dialog" style="width: 80%"><div class="modal-content"><div class="modal-header"><div class="modal-title">{{instructionsPopupHeader}}</div><a href="#" class="modal-close" data-dismiss="modal" style="position: absolute;top: 1rem;right: 1rem;"><svg width="20" height="20" viewBox="0 0 20 20"><path d="M17 4.413L15.587 3 10 8.587 4.413 3 3 4.413 8.587 10 3 15.587 4.413 17 10 11.413 15.587 17 17 15.587 11.413 10z" fill-rule="evenodd"></path></svg></a></div><div class="modal-body" ng-if="!isUsefulData"><div ng-bind-html="parseHtml(sectionToInstructionsMap[test.sections[currentQuestion.sSNo-1].sectionNumber].text)"></div></div><div class="modal-body" ng-if="isUsefulData"><div ng-repeat="instruction in asmInstructionsArr"><div ng-bind-html="parseHtml(instruction.text)"></div></div></div></div></div></div><div ng-if="isOptionalSectionSubmit" class="modal show attemptmore" id="attemptmore"><div class="modal-dialog"><div class="modal-content"><div class="modal-header pad-0"><div ng-click="optionalModalClose()" class="tb-close" data-dismiss="modal"></div></div><div class="modal-body"><h4>You cannot attempt more than {{OptionalSectionQuestionMaximumAttemptedCount(currentQuestion.sSNo)}} questions in this section.</h4><h5>Please clear the response for some other question of this section to attempt this question.</h5></div><div class="modal-footer"><button type="button" ng-click="optionalModalClose()" class="btn btn-block btn-gray-1">Resume</button> <button type="button" class="btn btn-block btn-theme" ng-if="isLastSection" ng-click="submitBtnPressed()">Submit Test</button><button type="button" class="btn btn-block btn-theme" ng-if="!isLastSection && test.isSectionalSubmit && !activeSubSectionSSSNo" ng-click="sectionalSubmitBtnClicked()">Submit Section</button> <button type="button" class="btn btn-block btn-theme" ng-if="shouldShowSubmitSubsectionButton()" ng-disabled="isSubsectionProgressionSyncInFlight()" ng-click="subsectionalSubmitBtnClicked()">Submit Sub-section</button></div></div></div></div><div class="modal modal--skip" id="skipModal"><div class="modal-dialog"><div class="modal-content"><div class="modal-body"><h4 class="text-center">In the actual exam you may not be allowed to submit sections/summary before the timer for the section ends.</h4><div class="modal-footer d-flex"><button class="btn btn-theme" ng-click="proceedBtnClicked()">Proceed</button> <button class="btn btn-gray-1" data-dismiss="modal">Cancel</button></div></div></div></div></div><div class="modal sectional-summary-modal" id="sectionalSummaryModal" tabindex="-1" role="dialog" aria-labelledby="summaryLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog"><div class="modal-content"><div class="modal-body"><h4 class="text-center">Summary of {{sectionalSummaryDS.sectionTitle || "Overall"}}</h4><div class="table-responsive"><table class="table mar-b0 mar-t24"><tr><td data-prompt="{{_pendingSubsectionSyncIntent ? \'Sub-section\' : \'Section\'}} Time Left" text-align="left" class="summary-header"><svg width="15" height="15" viewBox="0 0 18 18"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="web---submit-test" transform="translate(-571 -341)" fill="#89959B"><g id="access-alarms" transform="translate(571 341)"><path d="M18 3.475L13.86 0l-1.17 1.337 4.14 3.475L18 3.475zM5.31 1.425L4.14.09 0 3.475l1.17 1.337 4.14-3.386zm4.14 4.1H8.1v5.346l4.23 2.584.72-1.069-3.6-2.138V5.525zM9 1.96C4.5 1.96.9 5.525.9 9.98.9 14.436 4.5 18 9 18s8.1-3.564 8.1-8.02c0-4.455-3.6-8.02-8.1-8.02zm0 14.258c-3.51 0-6.3-2.763-6.3-6.238 0-3.475 2.79-6.237 6.3-6.237s6.3 2.762 6.3 6.237-2.79 6.238-6.3 6.238z" id="Shape"></path></g></g></g></svg><span>{{_pendingSubsectionSyncIntent ? \'Sub-section\' : \'Section\'}} Time Left:</span></td><td data-prompt="Timer" class="summary-text"><livetest-timer ng-if="!test.sectionTimeSharedFlag" test-duration="{{activeSectionRemT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" active-section-index="{{activeSectionIndex}}" active-sub-section-sss-no="{{activeSubSectionSSSNo}}" skip-duration="{{test.skipDuration}}" hide-zero="n"></livetest-timer></td></tr><tr><td data-prompt="Attempted" class="summary-header"><svg width="15" height="15" viewBox="0 0 18 18"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="web---submit-test" transform="translate(-571 -399)" fill="#89959B"><g id="check-circle-outline" transform="translate(571 399)"><path d="M5.31 7.29L4.05 8.55 8.1 12.6l9-9-1.26-1.26-7.74 7.74-2.79-2.79zM9 16.2c-3.96 0-7.2-3.24-7.2-7.2S5.04 1.8 9 1.8c.72 0 1.35.09 1.98.27L12.42.63C11.34.27 10.17 0 9 0 4.05 0 0 4.05 0 9s4.05 9 9 9 9-4.05 9-9h-1.8c0 3.96-3.24 7.2-7.2 7.2z" id="Shape"></path></g></g></g></svg>Attempted</td><td data-prompt="Attempted Count" class="summary-text"><span class="summary-text">{{sectionalSummaryDS.attempted}}</span></td></tr><tr><td data-prompt="Unattempted" class="summary-header"><svg width="15" height="15" viewBox="0 0 18 18"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="web---submit-test" transform="translate(-571 -458)" fill="#89959B"><g id="unknown-4" transform="translate(571 458)"><path d="M9 0C4.05 0 0 4.05 0 9s4.05 9 9 9 9-4.05 9-9-4.05-9-9-9zm0 16.2c-3.96 0-7.2-3.24-7.2-7.2S5.04 1.8 9 1.8s7.2 3.24 7.2 7.2-3.24 7.2-7.2 7.2zM5.4 9.9h7.2V8.1H5.4v1.8z" id="Shape"></path></g></g></g></svg>Unattempted</td><td data-prompt="Unattempted Count" class="summary-text">{{sectionalSummaryDS.unattempted}}</td></tr><tr><td data-prompt="Marked for Review" class="summary-header"><svg width="15" height="15" viewBox="0 0 14 18"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="web---submit-test" transform="translate(-573 -517)" fill="#89959B"><g id="bookmark-outline" transform="translate(573 517)"><path d="M12 0H2C.9 0 0 .9 0 2v16l7-3 7 3V2c0-1.1-.9-2-2-2zm0 15l-5-2.2L2 15V2h10v13z" id="Shape"></path></g></g></g></svg>Marked</td><td data-prompt="Marked for Review Count" class="summary-text">{{sectionalSummaryDS.bookmarked}}</td></tr><tr ng-if="hasSkipOptionSupport"><td data-prompt="Unattempted" class="summary-header"><svg width="15" height="15" viewBox="0 0 18 18"><g id="Page-1" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="web---submit-test" transform="translate(-571 -458)" fill="#89959B"><g id="unknown-4" transform="translate(571 458)"><path d="M9 0C4.05 0 0 4.05 0 9s4.05 9 9 9 9-4.05 9-9-4.05-9-9-9zm0 16.2c-3.96 0-7.2-3.24-7.2-7.2S5.04 1.8 9 1.8s7.2 3.24 7.2 7.2-3.24 7.2-7.2 7.2zM5.4 9.9h7.2V8.1H5.4v1.8z" id="Shape"></path></g></g></g></svg>No options selected</td><td data-prompt="Unattempted Count" class="summary-text">{{sectionalSummaryDS.noOptionSelected}}</td></tr></table></div></div><div class="modal-footer pad-b24"><h4 class="text-left">Are you sure you want to submit this {{isSubmitInitiatedFromSubmitBtn ? \'test\' : (_pendingSubsectionSyncIntent ? \'sub-section\' : \'section\')}}?</h4><p ng-if="!isSubmitInitiatedFromSubmitBtn && isASMInterface" class="text-left">Note: In actual exam you cannot submit the section before its given time.</p><button type="button" class="btn btn-primary" ng-click="sectionalSummaryModalAction(true)">Yes</button> <button type="button" class="btn btn-primary btn-gray-1" ng-click="sectionalSummaryModalAction(false)">No</button></div></div></div></div><div class="modal show modal--confirmation" id="confirmationAlertBox" ng-if="showAlertBox" tabindex="-1" role="dialog" aria-labelledby="summaryLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog"><div class="modal-content"><div class="modal-body">Are you sure you want to submit this test ?</div><div class="modal-footer"><button type="button" class="btn tb-btn-secondary outline-none" ng-click="sectionalSummaryModalAction(false)">No</button> <button type="button" class="btn btn-primary outline-none" ng-click="sectionalSummaryModalAction(true)">Yes</button></div></div></div><div class="modal-backdrop fade in"></div></div><div class="modal modal--unattempt show" ng-if="hasSkipSupportModalOpen"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><h3>Hey! You need to mark at least one option in this question!</h3></div><div class="modal-body"><div class="mar-b2 pad-t2 text-gray-14">According to the latest OMR rules to combat cheating, a last option named \'Leave Question unattempted\' is added which is compulsory to select if you wish to skip this Question.</div><div class="mar-b2 pad-t2 text-gray-14">If you want to leave this Question unattempted, please mark the last option.</div></div><div class="modal-footer"><button data-bb-handler="cancel" ng-click="skipSupportModalStatus(\'cta\')" type="button" class="btn btn-theme mar-r12">Okay, Understood</button></div></div></div><div class="modal-backdrop fade in"></div></div></div><div ng-if="isJeeTestInterfaceUsed" ng-include="\'/views/partials/jee-test.html\'"></div>',controller:"TestController"}).when("/nt-test",{template:'<div ng-if="isCurTab(\'question\')"><div class="sat-interface"><div class="sat-interface__header"><div class="sat-header-title"><h4 ng-show="currentQuestion.satActualIndex == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index">{{test.IsFullTest ? \'Section \'+section.SSNo+\',\'+section.title+\':\'+section.customText : section.title}}</h4><button ng-click="directionModal()" class="sat-btn sat-btn-flex">Directions <img src="/assets/img/sat/arrow-down-dark.svg" alt="arrow"></button> <img ng-if="showDirectionalModal" src="/assets/img/sat/sat-triangle-icon.svg" alt="triangle"></div><div class="sat-header-timer"><livetest-timer ng-if="!test.sectionTimeSharedFlag" ng-show="showTimer" test-duration="{{activeSectionRemT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" active-section-index="{{activeSectionIndex}}" hide-zero="n" skip-duration="{{test.skipDuration}}" show-alert="$parent.showTimerAlert"></livetest-timer><h4 ng-show="!showTimer"><img src="/assets/img/sat/timer-icon.svg" alt="time"></h4><button ng-click="TimerBtnText()" class="sat-btn sat-btn-timer">{{TimerText}}</button></div><div class="sat-header-action" ng-if="!showReviewPage"><button class="sat-btn sat-btn-flex" ng-class="{\'active\': showSatCalModalUI }" ng-click="openSatCalcFun()" ng-if="isShowSatCalcCTA && containsMath(test)"><img src="/assets/img/sat/calculator.svg" alt="calculator" width="16"> Calculator</button> <button class="sat-btn sat-btn-flex" ng-class="{\'active\': showReferenceSupport}" ng-click="referenceSupport()" ng-if="containsMath(test)"><img src="/assets/img/sat/text-super-script.svg" alt="text-super-script"> Reference</button> <button class="sat-btn sat-btn-flex" ng-class="{\'active\': showMoreDropdownModal }" ng-click="moreDropdownModal()"><img src="/assets/img/sat/three-dots.svg" alt="three-dots"> More</button></div></div><div ng-show="!showReviewPage" class="sat-interface__main" ng-include="\'/views/partials/sat-test/sat-question.html\'"></div><div ng-show="showReviewPage" class="sat-interface__main" ng-include="\'/views/partials/sat-test/sat-review.html\'" style="grid-template-columns: 1fr;"></div><div class="sat-interface__footer" ng-class="{\'sat-footer-safari\': detectBrowser() == \'Apple Safari\',\'sat-footer-samsung\': detectBrowser() == \'Samsung Browser\'}"><div class="sat-footer-title" ng-if="!isMobile">{{name}}</div><div><div class="sat-footer-number" ng-if="!showReviewPage" ng-click="toggleNavigation()">Question {{currentQuestion.qSNo}} of {{totalQuestionCount()}} <img src="/assets/img/sat/arrow-up-white.svg" alt="arrow"></div></div><div class="sat-footer-action"><button ng-class="{\'sat-hide\': currentQuestion.qSNo == 1}" class="sat-btn sat-btn-primary" ng-click="saveAndPreviousSatBtnPressed()">Back</button> <button class="sat-btn sat-btn-primary" ng-click="saveAndNextSatBtnPressed()">Next</button></div></div></div></div><div class="modal-sat modal-sat-direction" id="directionModal" ng-if="showDirectionalModal"><div class="modal-content"><div class="modal-header"><h4>Directions</h4><button ng-click="directionModal()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-body" ng-if="!containsMath(test)"><h2>Reading & Writing Instructions</h2><p>The questions in this section address a number of important reading and writing skills. Each question includes one or more passages, which may include a table or graph. Read each passage and question carefully, and then choose the best answer to the question based on the passage(s).</p><hr><h2>Instructions for Answering Questions</h2><p>All questions in this section are multiple-choice with four answer choices. Each question has a single best answer.</p><h4>Follow these guidelines while answering:</h4><ul><li>Read each passage carefully to understand its main ideas and details.</li><li>Pay close attention to any accompanying tables or graphs.</li><li>Eliminate incorrect answers to improve your chances of selecting the best one.</li><li>Use the context of the passage to infer meanings and relationships.</li><li>Manage your time effectively to ensure you answer all questions.</li></ul></div><div class="modal-body" ng-if="containsMath(test)"><h2>Maths Instructions</h2><p>The questions in this section address a number of important math skills. Use of a calculator is permitted for all questions. A reference sheet, calculator, and these directions can be accessed throughout the test.</p><p>Unless otherwise indicated:</p><ul><li>All variables and expressions represent real numbers.</li><li>Figures provided are drawn to scale.</li><li>All figures lie in a plane.</li><li>The domain of a given function <i>f</i> is the set of all real numbers <i>x</i> for which <i>f(x)</i> is a real number.</li></ul><hr><h2>Instructions for Answering Questions</h2><h4>For Multiple-Choice Questions:</h4><ul><li>Solve each problem and choose the correct answer from the choices provided.</li><li>Each multiple-choice question has a single correct answer.</li></ul><h4>For Student-Produced Response Questions,Solve each problem and enter your answer as described below:</h4><ul><li>If you find more than one correct answer, enter only one answer.</li><li>You can enter up to 5 characters for a positive answer and up to 6 characters (including the negative sign) for a negative answer.</li><li>If your answer is a fraction that doesn\'t fit in the provided space, enter the decimal equivalent.</li><li>If your answer is a decimal that doesn\'t fit in the provided space, enter it by truncating or rounding at the fourth digit.</li><li>If your answer is a mixed number (such as 3<sup>1</sup>/<sub>2</sub>), enter it as an improper fraction (7/2) or its decimal equivalent (3.5).</li><li>Don\'t enter symbols such as a percent sign, comma, or dollar sign.</li></ul><img src="/assets/img/sat/math-direction.png" alt="move" style="display: block; margin: auto;width: 50%;" ng-class="{\'directionImage\': isMobile}"></div><div class="modal-footer"><button ng-click="directionModal()" class="sat-btn sat-btn-primary">Close</button></div></div></div><div class="modal-sat modal-sat--reference" ng-if="showReferenceSupport"><div class="modal-content"><div class="modal-header"><h4>Reference Sheet</h4><button ng-if="!isMobile"></button> <button ng-if="!isMobile" ng-click="satPageFullScreen()"><img ng-if="isFullscreen()" src="/assets/img/sat/full-screen-img.svg" alt="full-screen" width="16" height="16"> <img ng-if="!isFullscreen()" src="/assets/img/sat/short-screen-img.svg" alt="short-screen" width="16" height="16"></button> <button ng-click="referenceSupport()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-body"><img src="/assets/img/sat/reference-modal-img.svg" alt="img"><p>The number of degrees of arc in a circle is 360.</p><p>The number of radians of arc in a circle is 2π.</p><p>The sum of the measures in degrees of the angles of a triangle is 180.</p></div></div></div><div class="modal-sat modal-sat--navigation" ng-show="currentNavActive"><div class="modal-content"><div class="modal-header"><h4 ng-show="currentQuestion.satActualIndex == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index">{{test.IsFullTest ? \'Section \'+section.SSNo+\',\'+section.title+\':\'+section.customText : section.title}}</h4><button ng-click="toggleNavigation()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-helper"><div class="list-item-flex"><img src="/assets/img/sat/location-img.svg" alt="img" width="18">Current</div><div class="list-item-flex"><img src="/assets/img/sat/selection-border-img.svg" alt="img" width="18">Unanswered</div><div class="list-item-flex"><img src="/assets/img/sat/marked-review.svg" alt="img" width="18">For Review</div></div><div class="modal-body" ng-include="\'/views/partials/sat-test/sat-navigation.html\'"></div><div class="modal-footer"><button class="sat-btn sat-btn-primary" ng-click="goToReviewPage()">Go to Review Page</button></div></div><div class="modal-arrow"><img src="/assets/img/sat/sat-triangle-icon.svg" alt="arrow" width="20" height="20"></div></div><div class="modal-sat modal-sat-help" ng-if="showHelpModal"><div class="modal-content"><div class="modal-header"><h4>Help</h4><button ng-click="helpSupport()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-controller"><button ng-click="expandAll()" class="sat-btn">Expand All</button> <img src="/assets/img/sat/pipe-img.svg" alt="pipe"> <button ng-click="collapseAll()" class="sat-btn">Collapse All</button></div><div class="modal-body"><div class="accordion accordion-sat-help" id="satHelpAccordion"><div class="accordion-list" ng-repeat="item in helpAccordion track by $index"><div class="accordion-header" id="itemHeader{{$index}}" ng-click="toggleItem($index)"><div>{{item.title}}</div><button class="sat-btn" type="button" data-toggle="collapse" data-target="#collapse{{$index}}" aria-expanded="{{item.isOpen}}" aria-controls="collapse{{$index}}"><img ng-if="item.isOpen" src="/assets/img/sat/minus-icon.svg" alt="minus"> <img ng-if="!item.isOpen" src="/assets/img/sat/plus-icon.svg" alt="plus"></button></div><div id="collapse{{$index}}" ng-class="{\'collapse\': !item.isOpen}" aria-labelledby="itemHeader{{$index}}" data-parent="#satHelpAccordion"><div class="accordion-content"><div>{{item.content}}</div></div></div></div></div></div><div class="modal-footer"><button class="sat-btn sat-btn-primary" ng-click="helpSupport()">Close</button></div></div></div><div class="modal-sat modal-sat-exit" ng-if="exitModal"><div class="modal-content"><div class="modal-header"><h4>Do You Want to Exit this Practice Test?</h4><button ng-click="toggleExitModal()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-body"><p>If you exit now, your test will be submitted, and you won\'t be able to make further changes. Ensure you\'ve reviewed all answers before proceeding.</p></div><div class="modal-footer"><button class="sat-btn sat-btn-flex" ng-click="toggleExitModal()">Continue Practice Test</button> <button class="sat-btn sat-btn-primary" ng-click="submitTest(false)">Submit and Exit</button></div></div></div><div class="modal-sat sat-modal--more" ng-if="showMoreDropdownModal"><div class="modal-content" ng-class="{\'sat-more-safari\': detectBrowser() == \'Apple Safari\',\'sat-more-samsung\': detectBrowser() == \'Samsung Browser\'}"><div class="modal-header"><button ng-click="moreDropdownModal()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-body"><div class="modal-list" ng-click="helpSupport()"><img src="/assets/img/sat/sat-help-icon.svg" alt="help">Help</div><div class="modal-list" ng-click="toggleReportModal()"><img src="/assets/img/sat/sat-report-icon.svg" alt="help">Report Question</div><div class="modal-list" ng-click="toggleExitModal()"><img src="/assets/img/sat/sat-exit-icon.svg" alt="help">Save and Exit</div></div></div><div class="modal-backdrop" ng-click="moreDropdownModal()"></div></div><div class="modal-sat modal-sat--hero" ng-if="isCurTab(\'sectionBreak\')"><div class="modal-content"><div class="modal-body" ng-include="\'/views/partials/sat-test/sat-test-break.html\'"></div></div></div><div class="modal-sat modal-sat--hero" ng-if="isCurTab(\'moduleOver\')"><div class="modal-content"><div class="modal-body" ng-include="\'/views/partials/sat-test/sat-module-over.html\'"></div></div></div><div class="modal-sat modal-sat--calc" ng-show="showSatCalModalUI"><div class="modal-content" ng-class="{\'sat-calc-safari\': detectBrowser() == \'Apple Safari\',\'sat-calc-samsung\': detectBrowser() == \'Samsung Browser\'}"><div class="modal-header"><h4>Calculator</h4><button ng-if="!isMobile"></button> <button ng-if="!isMobile" ng-click="satPageFullScreen()"><img ng-if="isFullscreen()" src="/assets/img/sat/full-screen-img.svg" alt="full-screen" width="16" height="16"> <img ng-if="!isFullscreen()" src="/assets/img/sat/short-screen-img.svg" alt="short-screen" width="16" height="16"></button> <button ng-click="closeSatCalcFun()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close" width="20" height="20"></button></div><div class="modal-body" id="satCalcModal"></div></div></div><div class="modal modal-sat modal-sat-report" ng-if="showReportModal" ng-class="{\'sat-report--success\': showReportSuccessModal}"><div class="modal-content" ng-if="!showReportSuccessModal"><div class="modal-header"><h4>You have chosen to Report<br>this Question</h4><p>What seems to be the issue?</p><button ng-click="toggleReportModal()"><img src="/assets/img/sat/sat-modal-close.svg" alt="close"></button></div><div class="modal-body"><div class="sat-report-group"><label class="sat-report-list" for="list{{$index}}" ng-repeat="reportType in [\'Wrong Question\',\'Formatting Issue\',\'Wrong Translation\',\'Others\'] track by $index"><input type="checkbox" id="list{{$index}}" ng-model="selectedReportTypes[reportType]" width="16" height="16"> {{reportType | translate}}</label></div><textarea ng-model="textAreaReportValue" ng-keydown="getReportAreaValue($event)" id="reportText" placeholder="Please tell us more about the issue (at least 7-8 words) for the quick resolution."></textarea></div><div class="modal-footer"><button class="sat-btn sat-btn-primary sat-report" id="reportSubmitBtn" ng-click="submitReportQuestion()" ng-disabled="isSubmitDisabled">Submit Report <span ng-if="isSubmitDisabled" class="tooltip tooltip-top">Describe the issue with the question.(20 characters)</span></button></div></div><div class="modal-content" ng-if="showReportSuccessModal"><div class="modal-header"><img class="report-image" src="/assets/img/sat/report-success.svg" alt="move"></div><div class="modal-body sat-succes-body"><h4>Thanks for your valuable feedback!<br>It means a lot!</h4></div><div class="modal-footer"><button class="sat-btn sat-btn-primary" id="reportSuccesCta" ng-click="toggleReportModal()">Continue Learning</button></div></div></div>',controller:"TestController"}).when("/pt-test",{template:'<div class="plutus-interface plutus-interface--test"><div class="plutus-interface__header"><div class="plutus-container"><div class="header-section"><a href="/" class="header-logo"><img ng-src="{{currentLogo}}" alt="logo" width="153"></a></div><div class="header-section" ng-show="currentQuestion.sSNo - 1 == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index"><div class="text-section">Section: {{section.title}}</div><div class="text-section">Question {{currentQuestion.qSNo}}</div></div><div class="header-divider"></div><div class="header-section" ng-class="{\'show-timer-alert\': showTimerAlert}"><div class="text-section">{{getTimerPrompt()}}</div><livetest-timer ng-if="test.sectionTimeSharedFlag" test-duration="{{test.remT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" test-time-over-ptr="testTimeOver" resume-ptr="resumeTimerCB" hide-zero="n" skip-duration="{{test.skipDuration}}" show-alert="$parent.showTimerAlert"></livetest-timer></div><div class="header-divider"></div><div class="header-section"><div class="exam-progress"><span class="exam-progress__bar" ng-style="{ \'width\' : testCompleteQuestionPercent() + \'%\' }"></span><div class="exam-progress__track">Exam {{testCompleteQuestionPercent()}}% Complete</div></div><div class="section-dropdown"><div class="section-dropdown__toggle" ng-click="toggleNavigation()"><img src="/assets/img/plutus/graph.png" alt="graph" width="24">Test Progress Details <img src="/assets/img/plutus/arrow-down.png" alt="arrow down" width="24"></div><div class="section-dropdown__menu" ng-show="currentNavActive" ng-include="\'/views/partials/plutus-test/plutus-section-view.html\'"></div><div class="section-dropdown__backdrop" ng-show="currentNavActive" ng-click="toggleNavigation()"></div></div></div><div class="header-divider"></div><div class="header-section"><div class="text-highlight" style="max-width: 200px">{{test.title}}</div></div><div class="header-divider"></div><div class="header-section" ng-click="toggleExitModal()"><div class="btn-text-group"><button><img src="/assets/img/plutus/exit.png" alt="exit" width="34"></button>Submit</div></div></div></div><div class="plutus-interface__body"><div class="plutus-container" ng-class="{\'container-comprehension\': hasComprehension()}"><div ng-include="\'/views/partials/plutus-test/plutus-question.html\'"></div></div></div><div class="plutus-interface__footer"><div class="plutus-container"><div class="btn-group"><div class="btn-text-group" ng-click="toggleReferenceSupport()"><img src="/assets/img/plutus/referance.png" alt="prev" width="34">References</div><div class="btn-text-group" ng-click="toggleHelpSupport()"><img src="/assets/img/plutus/help.png" alt="prev" width="34">Help</div><div class="btn-text-group"><drag-calculator ng-if="isShowCalculator" config="{btnClasses: \'btn-link\'}" is-basic-calc="isBasicCalculator" is-acca-type="true" id="calc"></drag-calculator></div></div><div ng-if="false" class="btn-text-complete">Question 0% Complete</div><div class="btn-group"><div class="btn-text-group" ng-if="!studentResponses[currentQuestionId()] || !studentResponses[currentQuestionId()].isBookmarked" ng-click="markQuestionPlutusClicked(currentQuestion.sSNo, currentQuestion.qSNo,true)" style="width: 78px"><img src="/assets/img/plutus/flag.png" alt="flag" width="34">Flag</div><div class="btn-text-group" ng-if="studentResponses[currentQuestionId()] && studentResponses[currentQuestionId()].isBookmarked" ng-click="markQuestionPlutusClicked(currentQuestion.sSNo, currentQuestion.qSNo,false)" style="width: 78px"><img src="/assets/img/plutus/flag-on.png" alt="flag-on" width="34">Remove Flag</div><div class="btn-text-group" style="width: 36px"><div class="btn-text-group" ng-hide="currentQuestion.sSNo == 1 && currentQuestion.qSNo == 1" ng-click="saveAndPreviousBtnPlutusPressed()"><img src="/assets/img/plutus/prev.png" alt="prev" width="34">Prev</div></div><div class="btn-text-group" style="width: 36px"><div class="btn-text-group" ng-hide="currentQuestion.sSNo == test.sections.length && currentQuestion.qSNo == test.sections[currentQuestion.sSNo -1].questions.length" ng-click="saveAndNextPlutusBtnPressed(false, \'\', true)"><img src="/assets/img/plutus/next.png" alt="prev" width="34">Next</div></div></div></div></div></div><div class="modal modal--test-plutus" ng-if="false"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><div class="modal-title">Navigation Warning</div></div><div class="modal-body"><p>You have partially attempted this question. You can choose to stay on the question and review your answer(s) or continue.</p><p>When reviewing your answer(s) ensure you read any message displayed in red. If you do not update your answer in accordance with the message displayed then your answer will not be marked</p><p>Until the question has been fully answered, the Exam Progress Details panel will display the question as incomplete.</p></div><div class="modal-footer"><button class="btn">Stay on Question</button> <button class="btn">Continue</button></div></div></div></div><div class="modal modal--test-plutus" ng-class="{\'show\' : exitModal}"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><div class="modal-title">Submit Confirmation</div></div><div class="modal-body"><p>Your exam contains:</p><p>Incomplete questions {{totalNotAnswerCount()}}</p><br><h4 style="margin-bottom: 1rem">Are you sure you wish to submit?</h4><p>If you select Yes to confirm you do wish to Submit you will not be able to return to the exam.</p></div><div class="modal-footer"><button class="btn" ng-click="submitTest(false)">Yes</button> <button class="btn" ng-click="toggleExitModal()">No</button></div></div></div></div><div class="modal modal--test-plutus" ng-class="{\'show\': TimeLimitSupport}"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><div class="modal-title">Time Limit Expired</div></div><div class="modal-body"><p>Your two hours limit has expired</p></div><div class="modal-footer"><button class="btn">OK</button></div></div></div></div><div class="modal modal--test-plutus modal--test-plutus--reference" ng-class="{\'show\': referenceSupport}"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><div class="modal-title">Reference Material</div><button class="btn" ng-click="toggleReferenceSupport()">X</button></div><div class="modal-body"><div class="reference-text"><p>Formulae Sheet</p><p>Annuity Table</p><p>Present Value Table</p><p>Standard Normal Distribution Table</p></div><hr><img src="/assets/img/plutus/formula.png" alt="formula"><hr><img src="/assets/img/plutus/annuity.png" alt="formula"><hr><img src="/assets/img/plutus/present.png" alt="formula"><hr><img src="/assets/img/plutus/standard.png" alt="formula"></div></div></div></div><div class="modal modal--test-plutus modal--test-plutus--help" ng-class="{\'show\': helpSupport}"><div class="modal-dialog"><div class="modal-content"><div class="modal-header"><div class="modal-title">Help</div><button class="btn" ng-click="toggleHelpSupport()">X</button></div><div class="modal-body"><div ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-one.html\'"></div><hr><div ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-two.html\'"></div><hr><div ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-three.html\'"></div></div><div class="modal-footer"><button class="btn" ng-click="toggleHelpSupport()">Close</button></div></div></div></div>',controller:"TestController"}).when("/lt-solutions",{template:'<link rel="stylesheet" href="//testbook.com/assets/style/tb/css/standalone-feedback.19ac6194cc7c9fa94189679b55c901cd19efec97e91.css"><span class="new-UI"><div class="notify-panel-box js-notify-panel-box js-banner-height-offset"></div></span><div id="MathJaxAlert" ng-show="isMathJaxAlertVisible()" ng-bind-html="mathJaxErrorMsgHTML" class="label bg-skipped" style="z-index:100;display: inline;position: absolute;left: 40%;top: 45px;padding: 5px;"></div><div class="test-top-bar" ng-show="isInitialized()"><div class="left-box back-to-mytests top-header" ng-if="!isInClass"><div class="d-inline-block align-middle"><a ng-if="!fromTestSeries && !fromAttempted && !fromScholarshipTest && !fromPyp && !fromLiveAttempted && !fromLivePage && !fromOrganisation" href="/{{examURL}}/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromOrganisation" class="test-btn-style" ng-click="backBtnPressed()"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromTestSeries" href="/{{testSeriesUrl}}/test-series" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromScholarshipTest" href="/{{scholarshipTestSlug}}/scholarship-test" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromPyp" href="/{{PypTestSlug}}/previous-year-papers" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromAttempted" href="/attempted-tests/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromLivePage" href="/free-live-tests-and-quizzes/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromLiveAttempted" href="/free-live-tests-and-quizzes/attempted/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a></div><div class="d-inline-block"><h4 class="mar-t0 mar-b8">Tests</h4><h6 class="mar-v0 text-ellipsis">{{test.title | translate}}</h6></div><ul class="d-inline-block attempts" ng-if="attemptList && attemptList.length > 1"><li class="dropdown dropdown-attempt"><button class="btn dropdown-toggle" type="button" data-toggle="dropdown"><span class="d-lg-inline">Attempt {{selectedAttemptNo}}</span> <img class="arrow-down" src="/assets/img/arrows/chevron-down.svg"></button><div class="dropdown-menu slim-scrollbar"><div class="dropdown-item" ng-repeat="item in attemptList" ng-click="toggleattemptNo(item)"><span class="align-middle"></span> Attempt {{item}}</div></div></li></ul></div><div class="left-box back-to-mytests" ng-if="isInClass"><div class="d-inline-block align-middle mar-t12"><a ng-href="{{backUrl}}" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a></div><div class="d-inline-block align-middle mar-t12"><h4 class="mar-t0 mar-b8">{{backTitle | translate}}</h4><h6 class="mar-v0 text-ellipsis">{{test.title | translate}}</h6></div></div><div class="right-box" ng-if="!isInClass && (!hideAnalysis && isAnalysisAvailable || !checkSdkModeActive)"><a href="{{backToAnalysisUrl}}" class="btn rb-btn test-btn-style" translate>ANALYTICS</a></div><div class="right-box" ng-if="hasTestDiscussion"><a href="javascript:void(0)" ng-click="openTestDiscussion()" class="btn rb-btn test-btn-style"><span translate>TEST DISCUSSION</span> <span class="badge badge-thick badge-notification ml--4">New</span></a></div><div class="pull-right new-UI hidden-xs mar-r16 mar-t16"><div id="feedback-staronly" ng-if="!hideFeedbackComponent" class="inline-feedback feedback-blurb" inline-feedback default-text="Rate the Test" selectable="true" submitted="feedbackSubmitted" on-select="inlineFeedbackCallback"></div></div><div class="pull-right hidden-xs" style="color: #fff;background-color: #0091bc;margin: 15px 30px;" ng-show="reattemptEnabled"><drag-calculator ng-if="isShowCalculator" config="{btnClasses: \'btn-link\'}" is-basic-calc="isBasicCalculator"></drag-calculator></div></div><div id="page" ng-cloak ng-show="isInitialized()" class="u-mob-sidebar solutions-page"><div class="tp-left-box"><div class="test-sections-list d-flex"><h5 class="sl-title" translate>Sections</h5><div class="sl-inner test-sections-scroll sl-solution"><ul id="sectionNavTabs" class="nav nav-pills sections-list"><li class="dropdown" ng-repeat="section in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo -1 == $index}" ng-click="jumpToQuestionView($index)" ng-hide="test.sections.length ==1 && section.title ==\'\'" ng-if="!(section.hasDescriptiveQuestions || section.hasExcelQuestions) || descriptiveSolutionAvailable"><a data-target="#section{{$index}}"><span class="hidden-xs">{{(section.title || "Overall") | translate}}</span> <span class="visible-xs">{{section.title.slice(0,3)}}</span></a><ul id="section{{$index}}Summary" class="dropdown-menu sections-list-details" role="menu" style="width:250px;"><li><div class="col-xs-12"><h6>{{section.title || "Overall"}}</h6></div></li><li><div class="col-xs-12"><h4><span class="label correct-answer pull-right">{{getCorrectFromSummary($index + 1)}}</span><small translate>Correct</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label wrong-answer pull-right">{{getIncorrectFromSummary($index + 1)}}</span><small translate>Incorrect</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label unattempted-que pull-right">{{getUnattemptedFromSummary($index + 1)}}</span><small translate>Unattempted</small></h4></div></li></ul></li></ul></div><div class="d-flex language-selector--div tp-language-selector"><button class="ebook-view--btn mar-r4" ng-show="isCurTab(\'qpaper\')" ng-click="toggleEbookView()">{{ebookBtnTxt}}</button><div class="form-inline" ng-show="isTranslationPresent() && languages &&languages.length > 1"><div class="form-group"><label for="language" class="control-label hidden-xs" translate>View in</label><select id="language" ng-model="$root.lang" ng-options="lang.prompt for lang in languages" ng-change="setLanguage(lang)"></select></div></div></div><div class="report-bookmark-mweb d-none visible-xs"><bookmarks ng-if="!isDisabledBookMarked" btn-classes="btn-sm" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" course-id="{{test.courseid}}" chapter-id test-id="{{test._id}}" lang="{{$root.lang.name}}" page-type="{{VAULT_API_TYPE}}" is-bookmarked="savedQIDMap[getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)]" sid="{{sid}}"></bookmarks><report-cta qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" class="report-this-question" module-Type="{{moduleType}}" btn-type="report-more-vert"></report-cta></div></div><div class="mob-question-holder"><div id="mainBox" class="test-qpip-holder"><div class="qpip-inner active" id="questions" ng-show="isCurTab(\'question\')"><div class="header" ng-if="!showFilterError"><div class="header-inner"><div class="row"><div class="col-xs-9 pad-t12 mar-t2 tp-info"><div class="tp-ques-number d-inline-block border-r1 border-color-gray-10 pad-lg-r8 pad-r4"><span class="hidden-xs">Question No.</span>{{currentQuestion.qSNo}}</div><div class="d-inline-block"><span class="badge pad-h8 pad-v4" ng-class="{ \'bg-attempted\': isCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-skipped\': isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-unattempt\': isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport, \'bg-partial-correct\': isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo) }">{{ (isCorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Correct\' : isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Incorrect\' : isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Partially Correct\' : isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport ? \'No option Selected\' : \'Skipped\') | translate }}</span></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.veryHappy === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-super-happy font-size-large text-success pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were superfast</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.happy === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-happy font-size-large text-success pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were on time</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.sad === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-sad font-size-large text-danger pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were slow</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.neutral === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-poker-face font-size-large text-secondary pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were on time but not correct</div></div></div><div class="d-inline-block pad-md-r8" ng-if="!isASM"><span class="font-size-small">{{\'You\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getStudentTimeInQuestion()}}</span></div><div class="d-inline-block pad-md-r8" ng-if="(isAverageTimeInQuestionValid() || isCorrectAnsAvgTimeInQuestionValid()) && !isASM"><span class="font-size-small">{{\'Avg\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getAverageTimeForView()}}</span></div><div class="d-inline-block pad-md-r8" ng-if="isBestTimeInQuestionValid() && !isASM"><span class="font-size-small">{{\'Top\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getBestTimeInQuestion()}}</span></div><div class="d-inline-block pad-lg-l8 pad-l4 border-l1 border-color-gray-10"><span class="font-size-small">{{\'Marks\' | translate }}</span> <span class="badge" ng-class="{ \'bg-attempted\' : isCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-skipped\' : isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-partial-correct\': isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-unattempt gernal-tooltip\' : isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport }">{{getMarks(currentQuestion.sSNo, currentQuestion.qSNo)}} <img ng-if="isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport" src="/assets/img/other/info-white.svg" width="12" height="12" class="mar-b1" alt="info-icon"><div ng-if="isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport" class="tooltiptext solution"><ol><li>Marks will be deducted if no option is selected in this question.</li><li>If you want to leave this Question unattempted, please mark the last option.</li></ol></div></span></div><div class="d-inline-block pad-lg-l8 pad-l4" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><span class="d-block font-size-small pad-v2 pad-h8 ans-percent">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span></div></div><div class="col-xs-3 tp-pos-neg-marks pad-l0"><div class="d-inline-block align-middle hidden-xs" style="position: relative; left:20px;" ng-if="!isDisabledBookMarked"><bookmarks btn-classes="btn-sm" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" course-id="{{test.courseid}}" chapter-id test-id="{{test._id}}" lang="{{$root.lang.name}}" page-type="{{VAULT_API_TYPE}}" is-bookmarked="savedQIDMap[getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)]" sid="{{sid}}" ng-if="currentQuestion"></bookmarks></div><div class="hidden-xs visible-lg-inline-block d-inline-block align-middle"><report-cta qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" module-type="{{moduleType}}" class="report-this-question"></report-cta></div></div></div></div><div class="hidden-xs text-size-resize">{{\'Text Size\' | translate }} <button type="button" class="btn js-font-size fs-decrease"><small>A<sup>-</sup></small></button> <button type="button" class="btn js-font-size fs-increase">A<sup>+</sup></button></div></div><div class="body detailed-question js-detailed-question" ng-if="!showFilterError"><div class="aei-comprehension" ng-if="hasComprehension()"><div class="mar-b16"><u class="font-weight-semibold"><i>{{\'Comprehension\' | translate }}:</i></u><span class="d-inline-block mar-l16">(Que No. {{(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno + 1) + " - " + (test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1)}})</span></div><div ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div ng-if="injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div></div><div class="que-ans-box" ng-class="{ \'solution-viewed\' : isSolutionVisible || !reattemptEnabled || isCorrect(currentQuestion.sSNo, currentQuestion.qSNo) }"><b ng-show="hasComprehension()"><u><i>{{\'Question\' | translate }}:</i></u></b><div class="mar-b16 qns-view-box" ng-class="{\'que-solution-box\' : fromOrganisation}" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div class="mar-b16 qns-view-box" ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage(lang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><ul class="list-unstyled clearfix mar-b24" ng-class="{\'reattempt-mode-on\': validForReattempt()}" ng-hide="isNumerical()"><li ng-repeat="option in getOptions() track by $index" class="option" ng-class="{ \'correct-option correct-icon\': isCorrectOption(option) && !validForReattempt() && !isOptionReattempted(option), \'incorrect-option\': isIncorrectOption(option) && (!reattemptEnabled || viewSolutionClicked) && !validForReattempt() && !reattemptedIncorrectOption(option), \'correct-option correct-icon reattempt-correct-option\': reattemptedCorrectOption(option) && isOptionReattempted(option) && isCorrectOption(option), \'incorrect-option reattempt-icon\': reattemptedIncorrectOption(option) && isOptionReattempted(option) && !viewSolutionClicked, \'missed-option missed-icon\': isMAMCQ() && isOptionMissed(option), \'actual-incorrect-option\': firstAttemptedOption(option), \'incorrect-icon\':(firstAttemptedOption(option) && !reattemptedIncorrectOption(option) && a(option) && !reattemptedCorrectOption(option)) || (isIncorrectOption(option) && !validForReattempt() && !reattemptedIncorrectOption(option)), \'stat-available\': (isCorrectAttemptPercentValid() && isCorrectOption(option)) || firstAttemptedOption(option), \'unattempted-option\' : isSkipOption(option) && !validForReattempt() && hasSkipOptionSupport, \'unattempted-icon\' : isSkipOption(option) && !validForReattempt() && !reattemptedIncorrectOption(option) && hasSkipOptionSupport }"><label><input ng-if="validForReattempt() && !isMAMCQ()" type="radio" name="option" ng-click="reattempt(option,$event)"> <input class="mca-checkbox" ng-show="isMAMCQ()" ng-if="validForReattempt()" ng-click="setOption(option)" type="checkbox" name="option"><div ng-bind-html="parseDesc(option.value)" class="qns-view-box"></div><div class="mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label><div class="option-stat"><span class="d-block font-size-small pad-v2 pad-h8 correctness" ng-if="isCorrectAttemptPercentValid() && isCorrectOption(option) && !isMAMCQ() && (reattemptedQuestion() || !reattemptEnabled)">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span> <span class="d-block font-size-small pad-v2 pad-h8" ng-class="{ \'correctness\': isCorrectOption(option), \'incorrectness\': isIncorrectOption(option), \'skipness\' : isSkipOption(option) }" ng-if="firstAttemptedOption(option)">{{\'Your first attempt\' | translate }}</span> <span class="d-block font-size-small pad-v2 pad-h8 missed-option-stat" ng-if="isMAMCQ() && isOptionMissed(option)">You Missed This Answer</span></div></li></ul><div ng-show="isNumerical()"><ul class="list-unstyled"><div ng-show="firstAttemptedOptionNumerical() && reattemptEnabled && !validForReattempt()"><li class="option incorrect-icon mar-b24 actual-incorrect-option stat-available"><label><div>{{getStudentFirstResponseForNum()}}</div></label><div class="option-stat"><span class="d-block font-size-small pad-v2 pad-h8 incorrectness">{{\'Your first attempt\' | translate }}</span></div></li></div><li class="option incorrect-option reattempt-icon mar-b24 stat-available" ng-show="isReattemptedOptionWrongForNum() && reattemptEnabled && !validForReattempt() && isQuestionReattempted()"><label><div>{{getStudentsReattemptedResponse()}}</div></label><div class="option-stat" ng-show="getStudentFirstResponseForNum() == getStudentsReattemptedResponse()"><span class="d-block font-size-small pad-v2 pad-h8 incorrectness" translate>Your first attempt</span></div></li><li class="option" ng-show="((!validForReattempt() && !correctOptionNumerical() && !isQuestionReattempted()) || (viewSolutionClicked) ) && (getStudentResponseForNum() != \'Not Attempted\')" ng-class="{ \'incorrect-option incorrect-icon\': wrongOptionNumerical(), \'first-attempt\':firstAttemptedOptionNumerical(), \'mar-b32\': isCorrectAttemptPercentValid() && (getStudentResponseForNum() != \'Not Attempted\' && (getStudentResponseForNum() >= getNumericalAnswer().lowerLimit && getStudentResponseForNum() <= getNumericalAnswer().upperLimit))}"><label><div>{{\'My Answer\' | translate }}: {{getStudentResponseForNum()}}</div></label></li><li class="option correct-option correct-icon mar-b24 stat-available" ng-show="!validForReattempt()"><label><div ng-if="isNumerical() && (correctOptionNumerical() || isReattemptedOptionCorrectForNum())">{{correctOptionNumerical() ? getStudentResponseForNum() : getStudentsReattemptedResponse()}}</div><div ng-if="isNumerical() && (!correctOptionNumerical() && !isReattemptedOptionCorrectForNum())">{{getNumericalAnswer().lowerLimit == getNumericalAnswer().upperLimit? getNumericalAnswer().upperLimit : getNumericalAnswer().lowerLimit + \'-\' + (getNumericalAnswer().upperLimit) }}</div><div class="option-stat" ng-if="isCorrectAttemptPercentValid()"><span class="d-block font-size-small pad-v2 pad-h8 correctness">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span></div></label></li></ul><div ng-show="validForReattempt()" class="max-width-250 pad-h16 mar-b32" ng-controller="KeypadController"><div class="alert bg-gray-1"><span ng-show="getNumInput() === \'None\'" translate>Re-attempt answer</span> <span class="font-weight-semibold" ng-show="getNumInput() !== \'None\'">{{getNumInput()}}</span></div><div class="row"><div class="col-xs-4 pad-h8" ng-repeat="i in range" ng-click="onKeyPress(i)"><button type="button" class="btn btn-theme" style="min-width:60px; margin:3px;">{{i}}</button></div></div><div class="text-center mar-t16"><button class="btn btn-success btn-block" ng-disabled="getNumInput() === \'None\'" type="button" ng-click="reattempt(selectedOption)" translate>Submit</button></div></div></div><div class="d-block text-center mar-b24" ng-if="validForReattempt()" ng-show="isMAMCQ()"><button type="button" class="btn btn-info-test mar-t0 min-width-100" ng-click="reattempt(option)">Submit</button></div><div ng-show="validForReattempt()"><div class="alert alert-warning max-width-300" ng-if="reattemptEnabled && !(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><div class="font-weight-semibold text-gray-9" translate>Re-attempt mode: ON</div><div class="text-gray-4 font-size-base-1 font-italic" translate>Now You can re-attempt the question</div></div><div><button type="button" class="btn btn-sm btn-outline-theme mar-r4" ng-click="toggleViewSolution()"><i class="tb-icon tb-view-eye mar-r2"></i> <span class="font-size-small" translate>{{isSolutionVisible ? \'Hide\' : \'View\'}} Solution</span></button> <span class="font-size-small text-gray-4" translate>Click here to see the answer now</span></div></div><div class="max-width-500" ng-show="!reattemptEnabled" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><div class="mar-b8 text-gray-4 font-size-base-1 font-italic"><span ng-if="!reattemptEnabled" translate>Reattempt mode is Off. Turn it on from bottom bar</span></div></div><div class="jee-highlighter" ng-show="reattemptEnabled && isSolutionVisible && isMAMCQ(currentQuestion.sSNo, currentQuestion.qSNo) && firstOptions && firstOptions.length > 0"><h4><b>Your First Attempt Answers</b></h4><span class="jee-highlighter__wrong-selection" ng-class="answer.class" ng-repeat="answer in firstOptions">{{answer.prompt}}</span></div><div ng-show="isSolutionVisible || !reattemptEnabled"><div class="btn-group btn-underline-group btn-group--tab"><div class="btn btn-underline-primary nav-spacing py-0" ng-click="setSolTab(1)" ng-class="{\'active\': isSet(1)}">Solution</div></div><div ng-show="isSet(1)"><li class="option" ng-show="isNumerical() && (correctOptionNumerical() || (reattemptEnabled && isReattemptedOptionCorrectForNum()))">Accepted answer is between: <b>{{getNumericalAnswer().lowerLimit}}</b> and <b>{{getNumericalAnswer().upperLimit}}</b></li><div class="qns-view-box" ng-bind-html="getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div ng-if="injectTranslation(getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))"><hr><div class="qns-view-box" ng-bind-html="getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div></div></div></div><div class="solution-like-box" ng-show="isSolutionVisible || !reattemptEnabled" ng-class="{\'in-comprehension\':hasComprehension()}"><span>Was the solution helpful?</span> <button class="btn" ng-class="{\'active\' : getTQues(currentQuestion.sSNo, currentQuestion.qSNo).vote > 0}" ng-click="likeDislikeSolution(getTQDID(currentQuestion.sSNo, currentQuestion.qSNo), 1)"><svg width="20" height="17" viewBox="0 0 20 17" style="margin-right: 10px"><path d="M.8 7.192v8.64c0 .596.531 1.08 1.187 1.08h3.56v-10.8h-3.56C1.33 6.112.8 6.595.8 7.192zm16.794-.959h-3.505a.584.584 0 0 1-.512-.293.584.584 0 0 1-.008-.589l1.236-2.225c.271-.487.3-1.06.077-1.572A1.766 1.766 0 0 0 13.681.536l-.872-.218a.589.589 0 0 0-.584.178L7.494 5.752a2.966 2.966 0 0 0-.761 1.985v6.208a2.97 2.97 0 0 0 2.966 2.967l5.902-.001c1.333 0 2.51-.897 2.861-2.182l1.267-5.812a2.194 2.194 0 0 0-2.135-2.684z" fill="#86A1AF" fill-rule="evenodd"></path></svg>Yes</button> <button class="btn" ng-class="{\'active\' : getTQues(currentQuestion.sSNo, currentQuestion.qSNo).vote < 0}" ng-click="likeDislikeSolution(getTQDID(currentQuestion.sSNo, currentQuestion.qSNo), -1)"><svg width="21" height="18" viewBox="0 0 21 18" style="margin-right: 10px"><path d="M.6 9.82V1.18C.6.584 1.145.1 1.818.1h3.656v10.8H1.818C1.145 10.9.6 10.416.6 9.82zm17.245 1.246h-3.6a.6.6 0 0 0-.525.3.602.602 0 0 0-.007.605l1.269 2.285c.278.5.307 1.09.079 1.614a1.812 1.812 0 0 1-1.234 1.046l-.895.224a.608.608 0 0 1-.6-.183l-4.859-5.398a3.045 3.045 0 0 1-.78-2.037V3.146A3.047 3.047 0 0 1 9.737.1H15.8c1.369 0 2.577.922 2.938 2.241l1.3 5.969a2.253 2.253 0 0 1-2.192 2.756z" fill="#86A1AF"></path></svg>No</button></div></div></div><div class="body" ng-if="showFilterError"><div class="alert alert-warning text-center max-width-400 mar-h-auto mar-t32"><p class="mar-b8">{{filterErrMsg}}</p><button type="button" class="btn btn-danger btn-sm" ng-click="resetFilter()">{{\'Reset Filter\' | translate }}</button></div></div><div class="footer mob-button-footer"><div class="footer-inner"><button type="button" class="btn btn-info-test mar-t0" ng-click="navBtnPressed(false)" ng-disabled="currentQuestion.sSNo ==1 && currentQuestion.qSNo ==1">Previous</button> <button type="button" class="btn btn-info-test pull-right mar-t0" ng-click="navBtnPressed(true)">{{\'Next\' | translate }}</button></div><div class="footer-inner-ssc"><button type="button" class="btn btn-gray-dark" ng-click="navBtnPressed(false)" ng-disabled="currentQuestion.sSNo ==1 && currentQuestion.qSNo ==1"><i class="tb-icon tb-arrow-left-thin"></i> Prev<span class="temp-text">ious</span> <span class="temp-text">Question</span></button> <button type="button" class="btn btn-gray-dark pull-right" ng-click="navBtnPressed(true)">{{\'Next \' | translate }}<span class="temp-text">Question</span> <i class="tb-icon tb-arrow-right-thin"></i></button></div><div class="toggle-reattempt-state" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><span class="text-gray-4">Re-attempt Ques<span class="hidden-xs">tions</span></span> <label class="tb-checkbox-switch"><input type="checkbox" ng-checked="reattemptEnabled" ng-click="reattemptSliderClick()"> <span class="tb-checkbox-switch-slider"></span> <span ng-show="isTooltipVisible" class="tb-popover top min-width-300"><button type="button" class="cancel-po" ng-click="isTooltipVisible = false"><i class="tb-icon tb-clear font-sm"></i></button> <span class="po-content text-left" translate>Re-attempt mode is on. You can re-attempt the question or click on View Solution to see the answer and detailed solution</span></span></label></div></div></div><div class="qpip-inner" id="questionPaper" ng-show="isCurTab(\'qpaper\')"><div class="header" ng-if="!isInEbookView"><div class="header-inner"><h4 class="text-center pad-t12">{{\'My Total Marks\' | translate }}: {{getMarksFromSummary(0)}}</h4></div></div><div class="body"><div class="body-inner"><h3 style="font-weight: bold;" class="text-center pad-12 mar-t0" ng-show="isInEbookView">{{test.title | translate }}</h3><div ng-repeat="section in test.sections track by $index"><h4>Section: {{section.title || "Overall"}}</h4><ul class="list-group"><li class="list-group-item" style="margin-bottom:10px;" ng-repeat="question in section.questions | filter : {isShow : true}">Q. {{question.index + 1}}) <span ng-show="!isInEbookView" class="badge pull-right" ng-class="{\'bg-attempted\' : isCorrect($parent.$index +1, question.index + 1), \'bg-partial-correct\': isPartiallyCorrect($parent.$index + 1, question.index + 1), \'bg-skipped\' : isIncorrect($parent.$index +1, question.index + 1), \'bg-unattempt\': isNoOptionSelected($parent.$index +1, question.index + 1) && hasSkipOptionSupport}">Marks: {{getMarks($parent.$index +1, question.index + 1)}}</span><span class="qns-view-box" ng-bind-html="getQuestionDesc($parent.$index + 1, question.index + 1, $root.lang.name)"></span><ol class="list-unstyled clearfix mar-b24" ng-show="isInEbookView"><li ng-repeat="option in getOptions(question) track by $index" class="option"><label>({{alphabet[$index]}}) <span class="mar-l8 qns-view-box" ng-bind-html="parseDesc(option.value)"></span> <span class="mar-l8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><span class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></span></span></label></li></ol><hr ng-show="!isInEbookView"></li></ul></div></div></div><div class="footer"><div class="footer-inner text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div></div></div></div><div class="sidebar-open-bg"></div><button type="button" class="btn btn-theme navbar-toggle js-trigger-toggle-sidebar"><span class="tb-icon tb-menu"></span> <span class="tb-icon tb-clear"></span></button></div><div id="sidebar" class="tp-right-box"><button type="button" class="toggle-sidebar-btn js-toggle-sidebar-btn"><i class="tb-icon tb-arrow-left-thin"></i> <i class="tb-icon tb-arrow-right-thin"></i></button><div class="sidebar-content on-solution-page"><div class="student-details"><div class="dropdown pull-right test-question-filters"><button type="button" class="btn dropdown-toggle pad-h0 text-gray-9" data-toggle="dropdown"><span class="pull-right label label-danger filter-label" ng-if="( testSolutionsFilter.isCorrect || testSolutionsFilter.isIncorrect || testSolutionsFilter.isUnattempted || testSolutionsFilter.isSaved || testSolutionsFilter.skipOptionSelected) && isFilterActive">{{ appliedFiltersCount }}</span> <i class="tb-icon tb-filter"></i> Filter</button><ul class="dropdown-menu dropdown-menu-right pad-b0" style="min-width: 200px;"><li class="d-arrow"></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].correct == 0}">{{ testSummaryArr[0].correct }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].correct == 0}"><input type="checkbox" name="filterQueCorrect" ng-model="testSolutionsFilter.isCorrect"> <span class="text-capitalize">Correct</span></label></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].incorrect == 0}">{{ testSummaryArr[0].incorrect }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].incorrect == 0}"><input type="checkbox" name="filterQueIncorrect" ng-model="testSolutionsFilter.isIncorrect"> <span class="text-capitalize">Incorrect</span></label></li><li class="filter-item js-stop-propagation"><ng-container ng-if="hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].skipOptionSelected == 0}">{{ testSummaryArr[0].skipOptionSelected }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].skipOptionSelected == 0}"><input type="checkbox" name="filterQueSkipOption" ng-model="testSolutionsFilter.skipOptionSelected"> <span class="text-capitalize">Unattempted</span></label></ng-container><ng-container ng-if="!hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}">{{ testSummaryArr[0].unattempted }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}"><input type="checkbox" name="filterQueUnattempted" ng-model="testSolutionsFilter.isUnattempted"> <span class="text-capitalize">Unattempted</span></label></ng-container></li><li class="filter-item js-stop-propagation"><ng-container ng-if="hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}">{{ testSummaryArr[0].unattempted }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}"><input type="checkbox" name="filterQueUnattempted" ng-model="testSolutionsFilter.isUnattempted"> <span class="text-capitalize">No option selected</span></label></ng-container></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].bookmarked == 0}">{{ testSummaryArr[0].bookmarked }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].bookmarked == 0}"><input type="checkbox" name="filterQueSaved" ng-model="testSolutionsFilter.isSaved"> <span class="text-capitalize">Saved</span></label></li><li class="pad-h16 pad-v8"><div class="row"><div class="col-xs-6 pad-l12 pad-r4"><button type="button" class="btn btn-sm btn-block btn-primary" ng-class="{\'disabled\': !(testSolutionsFilter.isCorrect || testSolutionsFilter.isIncorrect || testSolutionsFilter.isUnattempted || testSolutionsFilter.isSaved || testSolutionsFilter.skipOptionSelected)}" ng-click="applyFilter()">Apply</button></div><div class="col-xs-6 pad-r12 pad-l4"><button type="button" class="btn btn-sm btn-block btn-danger" ng-class="{\'disabled\': !isFilterActive}" ng-click="resetFilter()">Reset</button></div></div></li></ul></div><span class="img" ng-style="{\'background-image\': \'url(\' + dpSrc + \')\'}"></span> <span>{{name}}</span></div><div class="q-possible-states"><div class="col-xs-4 pad-r0"><span class="label correct-answer u-legend-indicator">{{getCorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Correct</span></div><div class="col-xs-4 pad-l0 pad-r0"><span class="label u-legend-indicator">{{getUnattemptedFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Unattempted</span></div><div class="col-xs-4 pad-l0"><span class="label wrong-answer u-legend-indicator">{{getIncorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Incorrect</span></div><div class="col-xs-4 pad-r0"><span class="label partial-correct u-legend-indicator">{{getPartiallyCorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Partially Correct</span></div><div ng-if="hasSkipOptionSupport" class="col-xs-4 pad-h32"><span class="u-legend-indicator unattempted ng-binding">{{getNoOptionSelectedFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">No option selected</span></div></div><div class="time-indicators"><div class="mar-b8"><span class="font-size-small font-weight-semibold text-uppercase">Speed Indicators</span></div><div class="row mar-h0"><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-super-happy font-size-medium text-success mar-b4"></i><div class="font-size-smaller">Superfast</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-happy font-size-medium text-success mar-b4"></i><div class="font-size-smaller">On Time</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-sad font-size-medium text-danger mar-b4"></i><div class="font-size-smaller">Slow</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-poker-face font-size-medium text-secondary mar-b4"></i><div class="font-size-smaller">On Time but not Correct</div></div></div></div><div class="questions-number-holder new-rly-interface"><div class="qnh-inner slim-scrollbar" ng-show="currentQuestion.sSNo -1 == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index"><div class="mob-sidebar-section" ng-if="section.title != \'\'"><span>Section :</span> {{section.title}}</div><ul class="questionList slim-scrollbar hide-on-desktop"><li class="label" ng-repeat="question in section.questions | filter : {isShow : true}" ng-class="{ \'saved-question\' : savedQIDMap[question._id], \'correct-answer\' : isCorrect($parent.$index +1, question.index + 1), \'wrong-answer\' : isIncorrect($parent.$index +1, question.index + 1), \'partial-correct\': isPartiallyCorrect($parent.$index + 1, question.index + 1), \'current-question\': isCurrentQuestion($parent.$index + 1, question.index + 1), \'unattempted\': isNoOptionSelected($parent.$index + 1, question.index + 1) && hasSkipOptionSupport, }" ng-click="sideBarItemClicked($parent.$index +1, question.index + 1)">{{question.index + 1}} <i class="tb-icon tb-bookmark"></i></li></ul></div></div><div class="marks-action"><ul id="mainBtnBox" class="main-btn-box" role="tablist"><li><button class="btn btn-info-test btn-block" type="button" ng-click="setTab(\'qpaper\');">Question Paper</button></li><li><button class="btn btn-info-test btn-block" type="button" data-target="#summaryModal" data-toggle="modal">Summary</button></li></ul></div></div></div><div class="modal fade" id="summaryModal" tabindex="-1" role="dialog" aria-labelledby="summaryLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-lg"><div class="modal-content"><div class="modal-header"><button type="button" class="close" data-dismiss="modal"><span aria-hidden="true"><i class="tb-icon tb-clear"></i></span></button><h3 class="modal-title" id="summaryLabel">Summary</h3></div><div class="modal-body"><h4 class="text-center mar-t0">Total Marks: {{getMarksFromSummary(0)}}</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Section</th><th>No. of questions</th><th>Correct</th><th>Incorrect</th><th>Skipped</th><th ng-if="hasSkipOptionSupport">No option Selected</th><th>Marks</th></tr></thead><tbody><tr ng-repeat="section in test.sections track by $index"><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsFromSummary($index + 1)}}</td><td data-prompt="Correct">{{getCorrectFromSummary($index + 1)}}</td><td data-prompt="Incorrect">{{getIncorrectFromSummary($index + 1)}}</td><td data-prompt="Skipped">{{getUnattemptedFromSummary($index + 1)}}</td><td ng-if="hasSkipOptionSupport" data-prompt="NooptionSelected">{{getNoOptionSelectedFromSummary($index + 1)}}</td><td data-prompt="Marks">{{getMarksFromSummary($index + 1)}}</td></tr></tbody></table></div></div><div class="modal-footer" ng-if="!hideAnalysis && isAnalysisAvailable || !checkSdkModeActive"><a href="{{backToAnalysisUrl}}" class="btn btn-theme test-analysis-btn">Continue to Test Analysis</a></div></div></div></div><div class="modal modal_app d-large-none" id="appStore" ng-if="!isPlutus"><div class="modal-dialog h-100" role="document"><div class="modal-content modal_app-content"><div class="modal_app-body" style="font-family: \'Inter\', sans-serif; text-align: center; background: #fff; padding: 20px; border-radius: 16px; box-shadow: 0 0 12px rgba(0, 0, 0, 0.1); max-width: 400px; margin: auto; border: 1px solid #e0e0e0;"><div style="font-size: 20px; font-weight: 600; margin-bottom: 4px; color: #000;">Download the Testbook App</div><div style="font-size: 14px; color: #333; margin-bottom: 16px;">to see your performance</div><div style="margin-bottom: 16px;"><img src="https://cdn.testbook.com/1747205478756-image.png/1747205479.png" alt="Download Testbook App Result Blocker" style="width: 100%; border-radius: 12px; max-width: 312px; height: auto;"></div><a href="https://link.testbook.com/iKruZlF82Db" style="display: inline-block; text-decoration: none; background: #4788F4; color: white; font-weight: 500; font-size: 14px; padding: 12px 20px; border-radius: 8px; width: 312px; max-width: 100%; text-align: center;"><img src="/assets/img/other/masterclass-playstore.svg" class="mr--16" style="height: 20px; vertical-align: middle; margin-right: 8px;"> Continue In Testbook App</a></div></div></div></div><div class="modal modal--blocker" id="blocker" ng-if="isMobile"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><a class="modal-close" href="/{{testSeriesUrl}}/test-series"></a><div class="modal-body"><div class="testbook-logo"><img loading="lazy" width="110" height="24" src="https://cdn.testbook.com/mailer/pyp-pdf/Testbook_Logo.svg" alt="logo"></div><div class="alert-message">This test is available only on Computer/Laptop on www.testbook.com</div><div class="copy-text" ng-click="copyLink()"><img ng-if="linkCopied" src="/assets/img/other/copied.svg" width="18" height="18" style="margin-right: 2px;" alt="copy-logo"> <img ng-if="!linkCopied" src="/assets/img/other/copy.svg" width="16" height="16" style="margin-right: 2px;" alt="copy-logo"> {{linkCopied ? \'Copied\' : \'Copy\'}} link</div></div></div></div></div></div><set-language current-language="$root.lang.name"></set-language><div class="reattempt-alert-section" ng-if="toast.show" ng-class="{\'active\': toast.show}"><div class="alert alert-dismissible mar-b0" ng-class="{ \'alert-success\': toast.success, \'alert-danger\': !toast.success}"><button type="button" class="close"><i class="tb-icon tb-clear font-sm"></i></button> {{toast.viewMessage}}</div></div>',controller:"SolutionsController"}).when("/lt-solutions/:lid",{template:'<link rel="stylesheet" href="//testbook.com/assets/style/tb/css/standalone-feedback.19ac6194cc7c9fa94189679b55c901cd19efec97e91.css"><span class="new-UI"><div class="notify-panel-box js-notify-panel-box js-banner-height-offset"></div></span><div id="MathJaxAlert" ng-show="isMathJaxAlertVisible()" ng-bind-html="mathJaxErrorMsgHTML" class="label bg-skipped" style="z-index:100;display: inline;position: absolute;left: 40%;top: 45px;padding: 5px;"></div><div class="test-top-bar" ng-show="isInitialized()"><div class="left-box back-to-mytests top-header" ng-if="!isInClass"><div class="d-inline-block align-middle"><a ng-if="!fromTestSeries && !fromAttempted && !fromScholarshipTest && !fromPyp && !fromLiveAttempted && !fromLivePage && !fromOrganisation" href="/{{examURL}}/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromOrganisation" class="test-btn-style" ng-click="backBtnPressed()"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromTestSeries" href="/{{testSeriesUrl}}/test-series" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromScholarshipTest" href="/{{scholarshipTestSlug}}/scholarship-test" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromPyp" href="/{{PypTestSlug}}/previous-year-papers" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromAttempted" href="/attempted-tests/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromLivePage" href="/free-live-tests-and-quizzes/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a> <a ng-if="fromLiveAttempted" href="/free-live-tests-and-quizzes/attempted/" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a></div><div class="d-inline-block"><h4 class="mar-t0 mar-b8">Tests</h4><h6 class="mar-v0 text-ellipsis">{{test.title | translate}}</h6></div><ul class="d-inline-block attempts" ng-if="attemptList && attemptList.length > 1"><li class="dropdown dropdown-attempt"><button class="btn dropdown-toggle" type="button" data-toggle="dropdown"><span class="d-lg-inline">Attempt {{selectedAttemptNo}}</span> <img class="arrow-down" src="/assets/img/arrows/chevron-down.svg"></button><div class="dropdown-menu slim-scrollbar"><div class="dropdown-item" ng-repeat="item in attemptList" ng-click="toggleattemptNo(item)"><span class="align-middle"></span> Attempt {{item}}</div></div></li></ul></div><div class="left-box back-to-mytests" ng-if="isInClass"><div class="d-inline-block align-middle mar-t12"><a ng-href="{{backUrl}}" class="test-btn-style"><i class="tb-icon tb-arrow-left"></i></a></div><div class="d-inline-block align-middle mar-t12"><h4 class="mar-t0 mar-b8">{{backTitle | translate}}</h4><h6 class="mar-v0 text-ellipsis">{{test.title | translate}}</h6></div></div><div class="right-box" ng-if="!isInClass && (!hideAnalysis && isAnalysisAvailable || !checkSdkModeActive)"><a href="{{backToAnalysisUrl}}" class="btn rb-btn test-btn-style" translate>ANALYTICS</a></div><div class="right-box" ng-if="hasTestDiscussion"><a href="javascript:void(0)" ng-click="openTestDiscussion()" class="btn rb-btn test-btn-style"><span translate>TEST DISCUSSION</span> <span class="badge badge-thick badge-notification ml--4">New</span></a></div><div class="pull-right new-UI hidden-xs mar-r16 mar-t16"><div id="feedback-staronly" ng-if="!hideFeedbackComponent" class="inline-feedback feedback-blurb" inline-feedback default-text="Rate the Test" selectable="true" submitted="feedbackSubmitted" on-select="inlineFeedbackCallback"></div></div><div class="pull-right hidden-xs" style="color: #fff;background-color: #0091bc;margin: 15px 30px;" ng-show="reattemptEnabled"><drag-calculator ng-if="isShowCalculator" config="{btnClasses: \'btn-link\'}" is-basic-calc="isBasicCalculator"></drag-calculator></div></div><div id="page" ng-cloak ng-show="isInitialized()" class="u-mob-sidebar solutions-page"><div class="tp-left-box"><div class="test-sections-list d-flex"><h5 class="sl-title" translate>Sections</h5><div class="sl-inner test-sections-scroll sl-solution"><ul id="sectionNavTabs" class="nav nav-pills sections-list"><li class="dropdown" ng-repeat="section in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo -1 == $index}" ng-click="jumpToQuestionView($index)" ng-hide="test.sections.length ==1 && section.title ==\'\'" ng-if="!(section.hasDescriptiveQuestions || section.hasExcelQuestions) || descriptiveSolutionAvailable"><a data-target="#section{{$index}}"><span class="hidden-xs">{{(section.title || "Overall") | translate}}</span> <span class="visible-xs">{{section.title.slice(0,3)}}</span></a><ul id="section{{$index}}Summary" class="dropdown-menu sections-list-details" role="menu" style="width:250px;"><li><div class="col-xs-12"><h6>{{section.title || "Overall"}}</h6></div></li><li><div class="col-xs-12"><h4><span class="label correct-answer pull-right">{{getCorrectFromSummary($index + 1)}}</span><small translate>Correct</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label wrong-answer pull-right">{{getIncorrectFromSummary($index + 1)}}</span><small translate>Incorrect</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label unattempted-que pull-right">{{getUnattemptedFromSummary($index + 1)}}</span><small translate>Unattempted</small></h4></div></li></ul></li></ul></div><div class="d-flex language-selector--div tp-language-selector"><button class="ebook-view--btn mar-r4" ng-show="isCurTab(\'qpaper\')" ng-click="toggleEbookView()">{{ebookBtnTxt}}</button><div class="form-inline" ng-show="isTranslationPresent() && languages &&languages.length > 1"><div class="form-group"><label for="language" class="control-label hidden-xs" translate>View in</label><select id="language" ng-model="$root.lang" ng-options="lang.prompt for lang in languages" ng-change="setLanguage(lang)"></select></div></div></div><div class="report-bookmark-mweb d-none visible-xs"><bookmarks ng-if="!isDisabledBookMarked" btn-classes="btn-sm" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" course-id="{{test.courseid}}" chapter-id test-id="{{test._id}}" lang="{{$root.lang.name}}" page-type="{{VAULT_API_TYPE}}" is-bookmarked="savedQIDMap[getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)]" sid="{{sid}}"></bookmarks><report-cta qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" class="report-this-question" module-Type="{{moduleType}}" btn-type="report-more-vert"></report-cta></div></div><div class="mob-question-holder"><div id="mainBox" class="test-qpip-holder"><div class="qpip-inner active" id="questions" ng-show="isCurTab(\'question\')"><div class="header" ng-if="!showFilterError"><div class="header-inner"><div class="row"><div class="col-xs-9 pad-t12 mar-t2 tp-info"><div class="tp-ques-number d-inline-block border-r1 border-color-gray-10 pad-lg-r8 pad-r4"><span class="hidden-xs">Question No.</span>{{currentQuestion.qSNo}}</div><div class="d-inline-block"><span class="badge pad-h8 pad-v4" ng-class="{ \'bg-attempted\': isCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-skipped\': isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-unattempt\': isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport, \'bg-partial-correct\': isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo) }">{{ (isCorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Correct\' : isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Incorrect\' : isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo) ? \'Partially Correct\' : isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport ? \'No option Selected\' : \'Skipped\') | translate }}</span></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.veryHappy === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-super-happy font-size-large text-success pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were superfast</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.happy === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-happy font-size-large text-success pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were on time</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.sad === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-sad font-size-large text-danger pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were slow</div></div></div><div class="hidden-xs d-inline-block" ng-if="emoticonState.neutral === presentEmoticonState && !isASM" data-toggle="tb-tooltip"><i class="tb-icon tb-poker-face font-size-large text-secondary pad-h8"></i><div class="tb-tooltip right"><div class="po-content" translate>You were on time but not correct</div></div></div><div class="d-inline-block pad-md-r8" ng-if="!isASM"><span class="font-size-small">{{\'You\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getStudentTimeInQuestion()}}</span></div><div class="d-inline-block pad-md-r8" ng-if="(isAverageTimeInQuestionValid() || isCorrectAnsAvgTimeInQuestionValid()) && !isASM"><span class="font-size-small">{{\'Avg\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getAverageTimeForView()}}</span></div><div class="d-inline-block pad-md-r8" ng-if="isBestTimeInQuestionValid() && !isASM"><span class="font-size-small">{{\'Top\' | translate }}:</span> <span class="font-size-small text-gray-4 pad-0">{{getBestTimeInQuestion()}}</span></div><div class="d-inline-block pad-lg-l8 pad-l4 border-l1 border-color-gray-10"><span class="font-size-small">{{\'Marks\' | translate }}</span> <span class="badge" ng-class="{ \'bg-attempted\' : isCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-skipped\' : isIncorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-partial-correct\': isPartiallyCorrect(currentQuestion.sSNo, currentQuestion.qSNo), \'bg-unattempt gernal-tooltip\' : isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport }">{{getMarks(currentQuestion.sSNo, currentQuestion.qSNo)}} <img ng-if="isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport" src="/assets/img/other/info-white.svg" width="12" height="12" class="mar-b1" alt="info-icon"><div ng-if="isNoOptionSelected(currentQuestion.sSNo, currentQuestion.qSNo) && hasSkipOptionSupport" class="tooltiptext solution"><ol><li>Marks will be deducted if no option is selected in this question.</li><li>If you want to leave this Question unattempted, please mark the last option.</li></ol></div></span></div><div class="d-inline-block pad-lg-l8 pad-l4" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><span class="d-block font-size-small pad-v2 pad-h8 ans-percent">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span></div></div><div class="col-xs-3 tp-pos-neg-marks pad-l0"><div class="d-inline-block align-middle hidden-xs" style="position: relative; left:20px;" ng-if="!isDisabledBookMarked"><bookmarks btn-classes="btn-sm" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" course-id="{{test.courseid}}" chapter-id test-id="{{test._id}}" lang="{{$root.lang.name}}" page-type="{{VAULT_API_TYPE}}" is-bookmarked="savedQIDMap[getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)]" sid="{{sid}}" ng-if="currentQuestion"></bookmarks></div><div class="hidden-xs visible-lg-inline-block d-inline-block align-middle"><report-cta qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" module-type="{{moduleType}}" class="report-this-question"></report-cta></div></div></div></div><div class="hidden-xs text-size-resize">{{\'Text Size\' | translate }} <button type="button" class="btn js-font-size fs-decrease"><small>A<sup>-</sup></small></button> <button type="button" class="btn js-font-size fs-increase">A<sup>+</sup></button></div></div><div class="body detailed-question js-detailed-question" ng-if="!showFilterError"><div class="aei-comprehension" ng-if="hasComprehension()"><div class="mar-b16"><u class="font-weight-semibold"><i>{{\'Comprehension\' | translate }}:</i></u><span class="d-inline-block mar-l16">(Que No. {{(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno + 1) + " - " + (test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1)}})</span></div><div ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div ng-if="injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div></div><div class="que-ans-box" ng-class="{ \'solution-viewed\' : isSolutionVisible || !reattemptEnabled || isCorrect(currentQuestion.sSNo, currentQuestion.qSNo) }"><b ng-show="hasComprehension()"><u><i>{{\'Question\' | translate }}:</i></u></b><div class="mar-b16 qns-view-box" ng-class="{\'que-solution-box\' : fromOrganisation}" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div class="mar-b16 qns-view-box" ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage(lang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><ul class="list-unstyled clearfix mar-b24" ng-class="{\'reattempt-mode-on\': validForReattempt()}" ng-hide="isNumerical()"><li ng-repeat="option in getOptions() track by $index" class="option" ng-class="{ \'correct-option correct-icon\': isCorrectOption(option) && !validForReattempt() && !isOptionReattempted(option), \'incorrect-option\': isIncorrectOption(option) && (!reattemptEnabled || viewSolutionClicked) && !validForReattempt() && !reattemptedIncorrectOption(option), \'correct-option correct-icon reattempt-correct-option\': reattemptedCorrectOption(option) && isOptionReattempted(option) && isCorrectOption(option), \'incorrect-option reattempt-icon\': reattemptedIncorrectOption(option) && isOptionReattempted(option) && !viewSolutionClicked, \'missed-option missed-icon\': isMAMCQ() && isOptionMissed(option), \'actual-incorrect-option\': firstAttemptedOption(option), \'incorrect-icon\':(firstAttemptedOption(option) && !reattemptedIncorrectOption(option) && a(option) && !reattemptedCorrectOption(option)) || (isIncorrectOption(option) && !validForReattempt() && !reattemptedIncorrectOption(option)), \'stat-available\': (isCorrectAttemptPercentValid() && isCorrectOption(option)) || firstAttemptedOption(option), \'unattempted-option\' : isSkipOption(option) && !validForReattempt() && hasSkipOptionSupport, \'unattempted-icon\' : isSkipOption(option) && !validForReattempt() && !reattemptedIncorrectOption(option) && hasSkipOptionSupport }"><label><input ng-if="validForReattempt() && !isMAMCQ()" type="radio" name="option" ng-click="reattempt(option,$event)"> <input class="mca-checkbox" ng-show="isMAMCQ()" ng-if="validForReattempt()" ng-click="setOption(option)" type="checkbox" name="option"><div ng-bind-html="parseDesc(option.value)" class="qns-view-box"></div><div class="mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label><div class="option-stat"><span class="d-block font-size-small pad-v2 pad-h8 correctness" ng-if="isCorrectAttemptPercentValid() && isCorrectOption(option) && !isMAMCQ() && (reattemptedQuestion() || !reattemptEnabled)">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span> <span class="d-block font-size-small pad-v2 pad-h8" ng-class="{ \'correctness\': isCorrectOption(option), \'incorrectness\': isIncorrectOption(option), \'skipness\' : isSkipOption(option) }" ng-if="firstAttemptedOption(option)">{{\'Your first attempt\' | translate }}</span> <span class="d-block font-size-small pad-v2 pad-h8 missed-option-stat" ng-if="isMAMCQ() && isOptionMissed(option)">You Missed This Answer</span></div></li></ul><div ng-show="isNumerical()"><ul class="list-unstyled"><div ng-show="firstAttemptedOptionNumerical() && reattemptEnabled && !validForReattempt()"><li class="option incorrect-icon mar-b24 actual-incorrect-option stat-available"><label><div>{{getStudentFirstResponseForNum()}}</div></label><div class="option-stat"><span class="d-block font-size-small pad-v2 pad-h8 incorrectness">{{\'Your first attempt\' | translate }}</span></div></li></div><li class="option incorrect-option reattempt-icon mar-b24 stat-available" ng-show="isReattemptedOptionWrongForNum() && reattemptEnabled && !validForReattempt() && isQuestionReattempted()"><label><div>{{getStudentsReattemptedResponse()}}</div></label><div class="option-stat" ng-show="getStudentFirstResponseForNum() == getStudentsReattemptedResponse()"><span class="d-block font-size-small pad-v2 pad-h8 incorrectness" translate>Your first attempt</span></div></li><li class="option" ng-show="((!validForReattempt() && !correctOptionNumerical() && !isQuestionReattempted()) || (viewSolutionClicked) ) && (getStudentResponseForNum() != \'Not Attempted\')" ng-class="{ \'incorrect-option incorrect-icon\': wrongOptionNumerical(), \'first-attempt\':firstAttemptedOptionNumerical(), \'mar-b32\': isCorrectAttemptPercentValid() && (getStudentResponseForNum() != \'Not Attempted\' && (getStudentResponseForNum() >= getNumericalAnswer().lowerLimit && getStudentResponseForNum() <= getNumericalAnswer().upperLimit))}"><label><div>{{\'My Answer\' | translate }}: {{getStudentResponseForNum()}}</div></label></li><li class="option correct-option correct-icon mar-b24 stat-available" ng-show="!validForReattempt()"><label><div ng-if="isNumerical() && (correctOptionNumerical() || isReattemptedOptionCorrectForNum())">{{correctOptionNumerical() ? getStudentResponseForNum() : getStudentsReattemptedResponse()}}</div><div ng-if="isNumerical() && (!correctOptionNumerical() && !isReattemptedOptionCorrectForNum())">{{getNumericalAnswer().lowerLimit == getNumericalAnswer().upperLimit? getNumericalAnswer().upperLimit : getNumericalAnswer().lowerLimit + \'-\' + (getNumericalAnswer().upperLimit) }}</div><div class="option-stat" ng-if="isCorrectAttemptPercentValid()"><span class="d-block font-size-small pad-v2 pad-h8 correctness">{{getCorrectAttemptPercent()}}% {{\'answered correctly\' | translate }}</span></div></label></li></ul><div ng-show="validForReattempt()" class="max-width-250 pad-h16 mar-b32" ng-controller="KeypadController"><div class="alert bg-gray-1"><span ng-show="getNumInput() === \'None\'" translate>Re-attempt answer</span> <span class="font-weight-semibold" ng-show="getNumInput() !== \'None\'">{{getNumInput()}}</span></div><div class="row"><div class="col-xs-4 pad-h8" ng-repeat="i in range" ng-click="onKeyPress(i)"><button type="button" class="btn btn-theme" style="min-width:60px; margin:3px;">{{i}}</button></div></div><div class="text-center mar-t16"><button class="btn btn-success btn-block" ng-disabled="getNumInput() === \'None\'" type="button" ng-click="reattempt(selectedOption)" translate>Submit</button></div></div></div><div class="d-block text-center mar-b24" ng-if="validForReattempt()" ng-show="isMAMCQ()"><button type="button" class="btn btn-info-test mar-t0 min-width-100" ng-click="reattempt(option)">Submit</button></div><div ng-show="validForReattempt()"><div class="alert alert-warning max-width-300" ng-if="reattemptEnabled && !(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><div class="font-weight-semibold text-gray-9" translate>Re-attempt mode: ON</div><div class="text-gray-4 font-size-base-1 font-italic" translate>Now You can re-attempt the question</div></div><div><button type="button" class="btn btn-sm btn-outline-theme mar-r4" ng-click="toggleViewSolution()"><i class="tb-icon tb-view-eye mar-r2"></i> <span class="font-size-small" translate>{{isSolutionVisible ? \'Hide\' : \'View\'}} Solution</span></button> <span class="font-size-small text-gray-4" translate>Click here to see the answer now</span></div></div><div class="max-width-500" ng-show="!reattemptEnabled" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><div class="mar-b8 text-gray-4 font-size-base-1 font-italic"><span ng-if="!reattemptEnabled" translate>Reattempt mode is Off. Turn it on from bottom bar</span></div></div><div class="jee-highlighter" ng-show="reattemptEnabled && isSolutionVisible && isMAMCQ(currentQuestion.sSNo, currentQuestion.qSNo) && firstOptions && firstOptions.length > 0"><h4><b>Your First Attempt Answers</b></h4><span class="jee-highlighter__wrong-selection" ng-class="answer.class" ng-repeat="answer in firstOptions">{{answer.prompt}}</span></div><div ng-show="isSolutionVisible || !reattemptEnabled"><div class="btn-group btn-underline-group btn-group--tab"><div class="btn btn-underline-primary nav-spacing py-0" ng-click="setSolTab(1)" ng-class="{\'active\': isSet(1)}">Solution</div></div><div ng-show="isSet(1)"><li class="option" ng-show="isNumerical() && (correctOptionNumerical() || (reattemptEnabled && isReattemptedOptionCorrectForNum()))">Accepted answer is between: <b>{{getNumericalAnswer().lowerLimit}}</b> and <b>{{getNumericalAnswer().upperLimit}}</b></li><div class="qns-view-box" ng-bind-html="getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div ng-if="injectTranslation(getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))"><hr><div class="qns-view-box" ng-bind-html="getSolutionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div></div></div></div><div class="solution-like-box" ng-show="isSolutionVisible || !reattemptEnabled" ng-class="{\'in-comprehension\':hasComprehension()}"><span>Was the solution helpful?</span> <button class="btn" ng-class="{\'active\' : getTQues(currentQuestion.sSNo, currentQuestion.qSNo).vote > 0}" ng-click="likeDislikeSolution(getTQDID(currentQuestion.sSNo, currentQuestion.qSNo), 1)"><svg width="20" height="17" viewBox="0 0 20 17" style="margin-right: 10px"><path d="M.8 7.192v8.64c0 .596.531 1.08 1.187 1.08h3.56v-10.8h-3.56C1.33 6.112.8 6.595.8 7.192zm16.794-.959h-3.505a.584.584 0 0 1-.512-.293.584.584 0 0 1-.008-.589l1.236-2.225c.271-.487.3-1.06.077-1.572A1.766 1.766 0 0 0 13.681.536l-.872-.218a.589.589 0 0 0-.584.178L7.494 5.752a2.966 2.966 0 0 0-.761 1.985v6.208a2.97 2.97 0 0 0 2.966 2.967l5.902-.001c1.333 0 2.51-.897 2.861-2.182l1.267-5.812a2.194 2.194 0 0 0-2.135-2.684z" fill="#86A1AF" fill-rule="evenodd"></path></svg>Yes</button> <button class="btn" ng-class="{\'active\' : getTQues(currentQuestion.sSNo, currentQuestion.qSNo).vote < 0}" ng-click="likeDislikeSolution(getTQDID(currentQuestion.sSNo, currentQuestion.qSNo), -1)"><svg width="21" height="18" viewBox="0 0 21 18" style="margin-right: 10px"><path d="M.6 9.82V1.18C.6.584 1.145.1 1.818.1h3.656v10.8H1.818C1.145 10.9.6 10.416.6 9.82zm17.245 1.246h-3.6a.6.6 0 0 0-.525.3.602.602 0 0 0-.007.605l1.269 2.285c.278.5.307 1.09.079 1.614a1.812 1.812 0 0 1-1.234 1.046l-.895.224a.608.608 0 0 1-.6-.183l-4.859-5.398a3.045 3.045 0 0 1-.78-2.037V3.146A3.047 3.047 0 0 1 9.737.1H15.8c1.369 0 2.577.922 2.938 2.241l1.3 5.969a2.253 2.253 0 0 1-2.192 2.756z" fill="#86A1AF"></path></svg>No</button></div></div></div><div class="body" ng-if="showFilterError"><div class="alert alert-warning text-center max-width-400 mar-h-auto mar-t32"><p class="mar-b8">{{filterErrMsg}}</p><button type="button" class="btn btn-danger btn-sm" ng-click="resetFilter()">{{\'Reset Filter\' | translate }}</button></div></div><div class="footer mob-button-footer"><div class="footer-inner"><button type="button" class="btn btn-info-test mar-t0" ng-click="navBtnPressed(false)" ng-disabled="currentQuestion.sSNo ==1 && currentQuestion.qSNo ==1">Previous</button> <button type="button" class="btn btn-info-test pull-right mar-t0" ng-click="navBtnPressed(true)">{{\'Next\' | translate }}</button></div><div class="footer-inner-ssc"><button type="button" class="btn btn-gray-dark" ng-click="navBtnPressed(false)" ng-disabled="currentQuestion.sSNo ==1 && currentQuestion.qSNo ==1"><i class="tb-icon tb-arrow-left-thin"></i> Prev<span class="temp-text">ious</span> <span class="temp-text">Question</span></button> <button type="button" class="btn btn-gray-dark pull-right" ng-click="navBtnPressed(true)">{{\'Next \' | translate }}<span class="temp-text">Question</span> <i class="tb-icon tb-arrow-right-thin"></i></button></div><div class="toggle-reattempt-state" ng-if="!(test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions || test.sections[currentQuestion.sSNo-1].hasExcelQuestions)"><span class="text-gray-4">Re-attempt Ques<span class="hidden-xs">tions</span></span> <label class="tb-checkbox-switch"><input type="checkbox" ng-checked="reattemptEnabled" ng-click="reattemptSliderClick()"> <span class="tb-checkbox-switch-slider"></span> <span ng-show="isTooltipVisible" class="tb-popover top min-width-300"><button type="button" class="cancel-po" ng-click="isTooltipVisible = false"><i class="tb-icon tb-clear font-sm"></i></button> <span class="po-content text-left" translate>Re-attempt mode is on. You can re-attempt the question or click on View Solution to see the answer and detailed solution</span></span></label></div></div></div><div class="qpip-inner" id="questionPaper" ng-show="isCurTab(\'qpaper\')"><div class="header" ng-if="!isInEbookView"><div class="header-inner"><h4 class="text-center pad-t12">{{\'My Total Marks\' | translate }}: {{getMarksFromSummary(0)}}</h4></div></div><div class="body"><div class="body-inner"><h3 style="font-weight: bold;" class="text-center pad-12 mar-t0" ng-show="isInEbookView">{{test.title | translate }}</h3><div ng-repeat="section in test.sections track by $index"><h4>Section: {{section.title || "Overall"}}</h4><ul class="list-group"><li class="list-group-item" style="margin-bottom:10px;" ng-repeat="question in section.questions | filter : {isShow : true}">Q. {{question.index + 1}}) <span ng-show="!isInEbookView" class="badge pull-right" ng-class="{\'bg-attempted\' : isCorrect($parent.$index +1, question.index + 1), \'bg-partial-correct\': isPartiallyCorrect($parent.$index + 1, question.index + 1), \'bg-skipped\' : isIncorrect($parent.$index +1, question.index + 1), \'bg-unattempt\': isNoOptionSelected($parent.$index +1, question.index + 1) && hasSkipOptionSupport}">Marks: {{getMarks($parent.$index +1, question.index + 1)}}</span><span class="qns-view-box" ng-bind-html="getQuestionDesc($parent.$index + 1, question.index + 1, $root.lang.name)"></span><ol class="list-unstyled clearfix mar-b24" ng-show="isInEbookView"><li ng-repeat="option in getOptions(question) track by $index" class="option"><label>({{alphabet[$index]}}) <span class="mar-l8 qns-view-box" ng-bind-html="parseDesc(option.value)"></span> <span class="mar-l8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><span class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></span></span></label></li></ol><hr ng-show="!isInEbookView"></li></ul></div></div></div><div class="footer"><div class="footer-inner text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div></div></div></div><div class="sidebar-open-bg"></div><button type="button" class="btn btn-theme navbar-toggle js-trigger-toggle-sidebar"><span class="tb-icon tb-menu"></span> <span class="tb-icon tb-clear"></span></button></div><div id="sidebar" class="tp-right-box"><button type="button" class="toggle-sidebar-btn js-toggle-sidebar-btn"><i class="tb-icon tb-arrow-left-thin"></i> <i class="tb-icon tb-arrow-right-thin"></i></button><div class="sidebar-content on-solution-page"><div class="student-details"><div class="dropdown pull-right test-question-filters"><button type="button" class="btn dropdown-toggle pad-h0 text-gray-9" data-toggle="dropdown"><span class="pull-right label label-danger filter-label" ng-if="( testSolutionsFilter.isCorrect || testSolutionsFilter.isIncorrect || testSolutionsFilter.isUnattempted || testSolutionsFilter.isSaved || testSolutionsFilter.skipOptionSelected) && isFilterActive">{{ appliedFiltersCount }}</span> <i class="tb-icon tb-filter"></i> Filter</button><ul class="dropdown-menu dropdown-menu-right pad-b0" style="min-width: 200px;"><li class="d-arrow"></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].correct == 0}">{{ testSummaryArr[0].correct }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].correct == 0}"><input type="checkbox" name="filterQueCorrect" ng-model="testSolutionsFilter.isCorrect"> <span class="text-capitalize">Correct</span></label></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].incorrect == 0}">{{ testSummaryArr[0].incorrect }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].incorrect == 0}"><input type="checkbox" name="filterQueIncorrect" ng-model="testSolutionsFilter.isIncorrect"> <span class="text-capitalize">Incorrect</span></label></li><li class="filter-item js-stop-propagation"><ng-container ng-if="hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].skipOptionSelected == 0}">{{ testSummaryArr[0].skipOptionSelected }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].skipOptionSelected == 0}"><input type="checkbox" name="filterQueSkipOption" ng-model="testSolutionsFilter.skipOptionSelected"> <span class="text-capitalize">Unattempted</span></label></ng-container><ng-container ng-if="!hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}">{{ testSummaryArr[0].unattempted }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}"><input type="checkbox" name="filterQueUnattempted" ng-model="testSolutionsFilter.isUnattempted"> <span class="text-capitalize">Unattempted</span></label></ng-container></li><li class="filter-item js-stop-propagation"><ng-container ng-if="hasSkipOptionSupport"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}">{{ testSummaryArr[0].unattempted }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].unattempted == 0}"><input type="checkbox" name="filterQueUnattempted" ng-model="testSolutionsFilter.isUnattempted"> <span class="text-capitalize">No option selected</span></label></ng-container></li><li class="filter-item js-stop-propagation"><div class="filter-count" ng-class="{ \'disabled\' : testSummaryArr[0].bookmarked == 0}">{{ testSummaryArr[0].bookmarked }}</div><label class="tb-checkbox" ng-class="{ \'disabled\' : testSummaryArr[0].bookmarked == 0}"><input type="checkbox" name="filterQueSaved" ng-model="testSolutionsFilter.isSaved"> <span class="text-capitalize">Saved</span></label></li><li class="pad-h16 pad-v8"><div class="row"><div class="col-xs-6 pad-l12 pad-r4"><button type="button" class="btn btn-sm btn-block btn-primary" ng-class="{\'disabled\': !(testSolutionsFilter.isCorrect || testSolutionsFilter.isIncorrect || testSolutionsFilter.isUnattempted || testSolutionsFilter.isSaved || testSolutionsFilter.skipOptionSelected)}" ng-click="applyFilter()">Apply</button></div><div class="col-xs-6 pad-r12 pad-l4"><button type="button" class="btn btn-sm btn-block btn-danger" ng-class="{\'disabled\': !isFilterActive}" ng-click="resetFilter()">Reset</button></div></div></li></ul></div><span class="img" ng-style="{\'background-image\': \'url(\' + dpSrc + \')\'}"></span> <span>{{name}}</span></div><div class="q-possible-states"><div class="col-xs-4 pad-r0"><span class="label correct-answer u-legend-indicator">{{getCorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Correct</span></div><div class="col-xs-4 pad-l0 pad-r0"><span class="label u-legend-indicator">{{getUnattemptedFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Unattempted</span></div><div class="col-xs-4 pad-l0"><span class="label wrong-answer u-legend-indicator">{{getIncorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Incorrect</span></div><div class="col-xs-4 pad-r0"><span class="label partial-correct u-legend-indicator">{{getPartiallyCorrectFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">Partially Correct</span></div><div ng-if="hasSkipOptionSupport" class="col-xs-4 pad-h32"><span class="u-legend-indicator unattempted ng-binding">{{getNoOptionSelectedFromSummary(currentQuestion.sSNo)}}</span> <span class="qps-state">No option selected</span></div></div><div class="time-indicators"><div class="mar-b8"><span class="font-size-small font-weight-semibold text-uppercase">Speed Indicators</span></div><div class="row mar-h0"><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-super-happy font-size-medium text-success mar-b4"></i><div class="font-size-smaller">Superfast</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-happy font-size-medium text-success mar-b4"></i><div class="font-size-smaller">On Time</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-sad font-size-medium text-danger mar-b4"></i><div class="font-size-smaller">Slow</div></div><div class="col-xs-3 text-center pad-0"><i class="tb-icon tb-poker-face font-size-medium text-secondary mar-b4"></i><div class="font-size-smaller">On Time but not Correct</div></div></div></div><div class="questions-number-holder new-rly-interface"><div class="qnh-inner slim-scrollbar" ng-show="currentQuestion.sSNo -1 == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index"><div class="mob-sidebar-section" ng-if="section.title != \'\'"><span>Section :</span> {{section.title}}</div><ul class="questionList slim-scrollbar hide-on-desktop"><li class="label" ng-repeat="question in section.questions | filter : {isShow : true}" ng-class="{ \'saved-question\' : savedQIDMap[question._id], \'correct-answer\' : isCorrect($parent.$index +1, question.index + 1), \'wrong-answer\' : isIncorrect($parent.$index +1, question.index + 1), \'partial-correct\': isPartiallyCorrect($parent.$index + 1, question.index + 1), \'current-question\': isCurrentQuestion($parent.$index + 1, question.index + 1), \'unattempted\': isNoOptionSelected($parent.$index + 1, question.index + 1) && hasSkipOptionSupport, }" ng-click="sideBarItemClicked($parent.$index +1, question.index + 1)">{{question.index + 1}} <i class="tb-icon tb-bookmark"></i></li></ul></div></div><div class="marks-action"><ul id="mainBtnBox" class="main-btn-box" role="tablist"><li><button class="btn btn-info-test btn-block" type="button" ng-click="setTab(\'qpaper\');">Question Paper</button></li><li><button class="btn btn-info-test btn-block" type="button" data-target="#summaryModal" data-toggle="modal">Summary</button></li></ul></div></div></div><div class="modal fade" id="summaryModal" tabindex="-1" role="dialog" aria-labelledby="summaryLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-lg"><div class="modal-content"><div class="modal-header"><button type="button" class="close" data-dismiss="modal"><span aria-hidden="true"><i class="tb-icon tb-clear"></i></span></button><h3 class="modal-title" id="summaryLabel">Summary</h3></div><div class="modal-body"><h4 class="text-center mar-t0">Total Marks: {{getMarksFromSummary(0)}}</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th>Section</th><th>No. of questions</th><th>Correct</th><th>Incorrect</th><th>Skipped</th><th ng-if="hasSkipOptionSupport">No option Selected</th><th>Marks</th></tr></thead><tbody><tr ng-repeat="section in test.sections track by $index"><td data-prompt="Section">{{section.title || "Overall"}}</td><td data-prompt="No. of questions">{{getQuestionsFromSummary($index + 1)}}</td><td data-prompt="Correct">{{getCorrectFromSummary($index + 1)}}</td><td data-prompt="Incorrect">{{getIncorrectFromSummary($index + 1)}}</td><td data-prompt="Skipped">{{getUnattemptedFromSummary($index + 1)}}</td><td ng-if="hasSkipOptionSupport" data-prompt="NooptionSelected">{{getNoOptionSelectedFromSummary($index + 1)}}</td><td data-prompt="Marks">{{getMarksFromSummary($index + 1)}}</td></tr></tbody></table></div></div><div class="modal-footer" ng-if="!hideAnalysis && isAnalysisAvailable || !checkSdkModeActive"><a href="{{backToAnalysisUrl}}" class="btn btn-theme test-analysis-btn">Continue to Test Analysis</a></div></div></div></div><div class="modal modal_app d-large-none" id="appStore" ng-if="!isPlutus"><div class="modal-dialog h-100" role="document"><div class="modal-content modal_app-content"><div class="modal_app-body" style="font-family: \'Inter\', sans-serif; text-align: center; background: #fff; padding: 20px; border-radius: 16px; box-shadow: 0 0 12px rgba(0, 0, 0, 0.1); max-width: 400px; margin: auto; border: 1px solid #e0e0e0;"><div style="font-size: 20px; font-weight: 600; margin-bottom: 4px; color: #000;">Download the Testbook App</div><div style="font-size: 14px; color: #333; margin-bottom: 16px;">to see your performance</div><div style="margin-bottom: 16px;"><img src="https://cdn.testbook.com/1747205478756-image.png/1747205479.png" alt="Download Testbook App Result Blocker" style="width: 100%; border-radius: 12px; max-width: 312px; height: auto;"></div><a href="https://link.testbook.com/iKruZlF82Db" style="display: inline-block; text-decoration: none; background: #4788F4; color: white; font-weight: 500; font-size: 14px; padding: 12px 20px; border-radius: 8px; width: 312px; max-width: 100%; text-align: center;"><img src="/assets/img/other/masterclass-playstore.svg" class="mr--16" style="height: 20px; vertical-align: middle; margin-right: 8px;"> Continue In Testbook App</a></div></div></div></div><div class="modal modal--blocker" id="blocker" ng-if="isMobile"><div class="modal-dialog modal-dialog-centered"><div class="modal-content"><a class="modal-close" href="/{{testSeriesUrl}}/test-series"></a><div class="modal-body"><div class="testbook-logo"><img loading="lazy" width="110" height="24" src="https://cdn.testbook.com/mailer/pyp-pdf/Testbook_Logo.svg" alt="logo"></div><div class="alert-message">This test is available only on Computer/Laptop on www.testbook.com</div><div class="copy-text" ng-click="copyLink()"><img ng-if="linkCopied" src="/assets/img/other/copied.svg" width="18" height="18" style="margin-right: 2px;" alt="copy-logo"> <img ng-if="!linkCopied" src="/assets/img/other/copy.svg" width="16" height="16" style="margin-right: 2px;" alt="copy-logo"> {{linkCopied ? \'Copied\' : \'Copy\'}} link</div></div></div></div></div></div><set-language current-language="$root.lang.name"></set-language><div class="reattempt-alert-section" ng-if="toast.show" ng-class="{\'active\': toast.show}"><div class="alert alert-dismissible mar-b0" ng-class="{ \'alert-success\': toast.success, \'alert-danger\': !toast.success}"><button type="button" class="close"><i class="tb-icon tb-clear font-sm"></i></button> {{toast.viewMessage}}</div></div>',controller:"SolutionsController"}).when("/lt-instructions",{template:'<div class="tb-main-header" ng-show="!isJeeTestInterfaceUsed"><ng-container ng-if="!fromOrganisation"><a href="/" class="tb-logo" target="_self"><img class="logo-full" src="/assets/img/brand/logo-full.svg" onerror="this.onerror=null; this.src=\'/assets/img/brand/logo-full-medium.png\'" alt="Testbook Logo"></a><p class="test-title pull-left hidden-xs mar-t16 mar-l16 mar-b0">{{instructionsJSON.testHeading}}</p></ng-container><div class="tb-header-logo" ng-if="fromOrganisation"><span class="back-cta" ng-click="backBtnPressed()"><img class="back-btn" src="/assets/img/login-signup/arrow-left.svg" height="20px" width="16px"></span> <a class="tb-logo" target="_self" ng-if="partnerLogo && partnerLogo.logo"><img class="logo-full" ng-src="{{partnerLogo && partnerLogo.logo}}" alt="partner Logo" height="36px" width="36px" style="width: 100%;"></a><p class="test-title pull-left hidden-xs mar-t16 mar-l16 mar-b0">{{instructionsJSON.testHeading}}</p></div></div><div class="student-profile" ng-if="!isTestInProgress && !isJeeTestInterfaceUsed"><img ng-src="{{dpSrc}}" style="width: 100px;height: 100px;border-radius: 50%;"><h3>{{name}}</h3></div><div class="container-fluid u-mob-sidebar test-instructions slim-scrollbar" ng-if="!isJeeTestInterfaceUsed"><div class="row"><div class="col-xs-12 c-test-instructions" ng-show="showInstTab == 0" id="cuet-instructions"><div class="row"><div class="col-xs-12 cuet-instructions"><div class="row"><div class="col-xs-12 col-sm-12 heading"><h3 class="text-center">{{instructionsJSON.examHeading}}</h3><h2 class="text-center">{{instructionsJSON.testHeading}}</h2></div><div class="col-xs-12 d-flex col-sm-12 content__section"><div class="col-xs-12 col-sm-6"><h4><b>Select your subjects</b></h4><p>Select <b>Maximum of {{maxSelectSubjects}} subjects</b> to attempt. Your score & time will be determined by the subjects you select</p></div><div class="col-sm-3" ng-if="totalSectionSelected > 0 && !isMobile">Subjects <b>: {{totalSectionSelected}}</b></div><div style="width: 280px !important;" class="col-sm-3 text-right" ng-if="totalTestTime > 0 && !isMobile"><span><svg width="15px" height="15px" viewBox="0 0 15 15" class="time-grey"><g id="Course-&amp;-Exam-Pages" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Course-Page" transform="translate(-732 -4194)" fill="#86A1AE"><g id="Time" transform="translate(732 4194)"><path d="M7.493.75A6.747 6.747 0 0 0 .75 7.5a6.747 6.747 0 0 0 6.743 6.75A6.754 6.754 0 0 0 14.25 7.5 6.754 6.754 0 0 0 7.493.75zM7.5 12.9a5.399 5.399 0 0 1-5.4-5.4c0-2.984 2.416-5.4 5.4-5.4 2.983 0 5.4 2.416 5.4 5.4 0 2.983-2.417 5.4-5.4 5.4zm.338-8.775H6.825v4.05l3.544 2.126.506-.83-3.037-1.802V4.125z" id="Shape"></path></g></g></g></svg>Total Test Duration : <b>{{totalTestTime}} Mins</b></span></div></div><div class="content" ng-repeat="item in preInstructionBucket track by $index"><div class="col-xs-12 col-sm-12 content__section" ng-if="item.sections.length >1"><div class="col-xs-12 col-sm-3"><h5 class="mar-b8"><b>{{item.title}}</b></h5><span ng-if="!isMobile" class="text-gray-8">{{item.selectedSectionCount}} Subject added</span></div><div class="col-xs-12 col-sm-3"><button ng-click="setPreInstructionDropdown($index)" class="btn btn-block dropdown-btn text-gray-8" ng-class="{\'selected\':item.selectedSection.length>0}" ng-style="totalSectionSelected >= item.maxSubLimit && item.selectedSectionCount == 0 ? {\'background-color\': \'#F1F4F6\'} : {}"><span ng-if="!item.selectedSection || item.selectedSection.length==0">Select Subjects</span><span ng-if="item.selectedSection.length>0">{{item.selectedSection}}</span></button></div><div class="col-xs-6 col-sm-3 section_add"><span class="text-gray-8" ng-if="isMobile">{{item.selectedSectionCount}} Subject added</span></div><div class="col-xs-6 col-sm-3 text-right section_time"><span class="text-gray-8" ng-if="item.selectedSectionCount == 0"><img src="/assets/img/ui-kit/time.svg" data-inline-source> {{item.sectionDuration}} min per subject</span> <span class="text-class" ng-if="item.selectedSectionCount > 0"><svg width="15px" height="15px" viewBox="0 0 15 15" class="time-blue"><g id="Course-&amp;-Exam-Pages" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Course-Page" transform="translate(-732 -4194)" fill="#86A1AE"><g id="Time" transform="translate(732 4194)"><path d="M7.493.75A6.747 6.747 0 0 0 .75 7.5a6.747 6.747 0 0 0 6.743 6.75A6.754 6.754 0 0 0 14.25 7.5 6.754 6.754 0 0 0 7.493.75zM7.5 12.9a5.399 5.399 0 0 1-5.4-5.4c0-2.984 2.416-5.4 5.4-5.4 2.983 0 5.4 2.416 5.4 5.4 0 2.983-2.417 5.4-5.4 5.4zm.338-8.775H6.825v4.05l3.544 2.126.506-.83-3.037-1.802V4.125z" id="Shape"></path></g></g></g></svg>{{item.selectedSectionTime}} min per subject</span></div></div><div class="col-xs-12 col-sm-12 content__section" ng-if="item.sections.length == 1"><div class="col-xs-12 col-sm-3"><h5 class="mar-b8"><b>{{item.title}}</b></h5><span class="text-gray-8" ng-if="!isMobile">{{item.optionalSectionChecked ? \'Attempting section\' : \'Select to attempt\'}}</span></div><div class="col-xs-12 col-sm-6"><label class="tb-checkbox" style="text-transform:none;display: flex;align-items: center;" ng-class="{\'selected-checkbox\':isMobile && item.optionalSectionChecked}" ng-style="{\'padding\':!item.optionalSectionChecked && isMobile && currentCuetSlectedItems >= maxSelectSubjects ? \'0px 12px\':\'0px\',\'background-color\': isMobile && currentCuetSlectedItems >= maxSelectSubjects ? \'rgb(241, 244, 246)\':\'\'}" ng-click="currentCuetSlectedItems >= maxSelectSubjects && showDisableCheckAlert($event,$index,item.optionalSectionChecked)"><input class="cuet-checkbox" ng-if="currentCuetSlectedItems != maxSelectSubjects || item.optionalSectionChecked" type="checkbox" ng-checked="item.optionalSectionChecked" ng-disabled="currentCuetSlectedItems == maxSelectSubjects && !item.optionalSectionChecked" ng-click="OptionalfilterSubject($index,$event)"><p ng-if="currentCuetSlectedItems == maxSelectSubjects && !item.optionalSectionChecked" style="width: 14px;height: 14px;border:1px solid #86A1AE !important;border-radius: 4px; display: inline-block;margin: 0px;padding: 0px ;margin-right: -29px; background-color: rgb(241, 244, 246) ;border-color: rgb(241, 244, 246);" ng-style="{\'background-color\': \'#F1F4F6\'}"></p><span style="display: inline-block;" ng-class="{\'mycustomcheckbox\':currentCuetSlectedItems == maxSelectSubjects && !item.optionalSectionChecked}" class="text-gray-8">Attempt {{item.sections[0].title}}</span></label></div><div style="width: 100%;justify-content: space-between;align-items: center;" ng-style="\'{display: !isMobile ? \'inline\': \'flex\'}"><div class="section_add" ng-if="isMobile"></div><div class="text-right" style="justify-content: space-between;" ng-style="{\'display\': isMobile ? \'flex\' : \'block\', \'padding\': !isMobile ? \'0px\' : \'4px 24px\'}"><span class="text-gray-8 ng-scope" ng-if="isMobile">{{item.optionalSectionChecked ? \'Attempting section\' : \'Select to attempt\'}}</span> <span class="text-class" ng-if="item.selectedSectionCount > 0" style="color:#8e9aa9"><svg width="15px" height="15px" viewBox="0 0 15 15" class="time-blue"><g id="Course-&amp;-Exam-Pages" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Course-Page" transform="translate(-732 -4194)" fill="#86A1AE"><g id="Time" transform="translate(732 4194)"><path d="M7.493.75A6.747 6.747 0 0 0 .75 7.5a6.747 6.747 0 0 0 6.743 6.75A6.754 6.754 0 0 0 14.25 7.5 6.754 6.754 0 0 0 7.493.75zM7.5 12.9a5.399 5.399 0 0 1-5.4-5.4c0-2.984 2.416-5.4 5.4-5.4 2.983 0 5.4 2.416 5.4 5.4 0 2.983-2.417 5.4-5.4 5.4zm.338-8.775H6.825v4.05l3.544 2.126.506-.83-3.037-1.802V4.125z" id="Shape"></path></g></g></g></svg>{{item.selectedSectionTime}} min per subject</span> <span class="text-gray-8" ng-if="item.selectedSectionCount == 0"><img src="/assets/img/ui-kit/time.svg" data-inline-source> {{item.sectionDuration}} min per subject</span></div></div></div></div></div></div></div><div class="cuet-analysis selected-analysis" ng-if="isMobile && totalSectionSelected > 0 && totalTestTime > 0"><div class="col-xs-12"><div class="col-xs-4 pad-0">Subjects :<b class="text-class mar-l4">{{totalSectionSelected}}</b></div><div class="col-xs-8 pad-0" style="text-align: right;"><span style="display: flex; align-items: center;justify-content: right;">Total Test Duration :<svg width="15px" height="15px" viewBox="0 0 15 15" style="vertical-align:middle; margin: 0 4px;" class="time-blue"><g id="Course-&amp;-Exam-Pages" stroke="none" stroke-width="1" fill="none" fill-rule="evenodd"><g id="Course-Page" transform="translate(-732 -4194)" fill="#86A1AE"><g id="Time" transform="translate(732 4194)"><path d="M7.493.75A6.747 6.747 0 0 0 .75 7.5a6.747 6.747 0 0 0 6.743 6.75A6.754 6.754 0 0 0 14.25 7.5 6.754 6.754 0 0 0 7.493.75zM7.5 12.9a5.399 5.399 0 0 1-5.4-5.4c0-2.984 2.416-5.4 5.4-5.4 2.983 0 5.4 2.416 5.4 5.4 0 2.983-2.417 5.4-5.4 5.4zm.338-8.775H6.825v4.05l3.544 2.126.506-.83-3.037-1.802V4.125z" id="Shape"></path></g></g></g></svg><b class="text-class">{{totalTestTime}} Mins</b></span></div></div></div></div><div class="col-xs-12 c-test-instructions" ng-show="showInstTab == 1" id="gate-instructions" ng-if="instructionsJSON.isGateExam"><h4>General Instructions:</h4><ol start="1"><li><p>The clock will be set at the server. The countdown timer at the top right corner of screen will display the remaining time available for you to complete the examination. When the timer reaches zero, the examination will end by itself. You need not terminate the examination or submit your paper.</p></li><li><p>You are only allowed to use on screen calculator. No personal calculators are allowed.</p></li><li><p>The Question Palette displayed on the right side of screen will show the status of each question using one of the following symbols:</p><ul class="que-ans-states"><li><span class="label"></span> You have not visited the question yet.</li><li><span class="label skipped"></span> You have not answered the question.</li><li><span class="label attempted"></span> You have answered the question.</li><li><span class="label bookmarked"></span> You have NOT answered the question, but have marked the question for review.</li><li><span class="label attempted bookmarked"></span> You have answered the question, but marked it for review.</li><li ng-if="hasSkipOptionSupport"><span class="label unattempted"></span> You have answered NOT selected any option.</li></ul></li></ol><p>The <b>Mark For Review</b> status for a question simply indicates that you would like to look at that question again. If a question is answered, but marked for review, then the answer will be considered for evaluation unless the status is modified by the candidate.</p><b>Navigating to a Question :</b><ol start="4"><li><p>To answer a question, do the following:</p><ol><li>Click on the question number in the Question Palette to go to that question directly.</li><li>Select an answer for a multiple choice type question by clicking on the bubble placed before the 4 choices, namely A, B, C and D. Use the virtual numeric keypad to enter a number as answer for a numerical type question.</li><li>Click on <b>Save & Next</b> to save your answer for the current question and then go to the next question.</li><li>Click on <b>Mark for Review & Next</b> to save your answer for the current question and also mark it for review, and then go to the next question.</li></ol></li></ol><p>Note that your answer for the current question will not be saved, if you navigate to another question directly by clicking on a question number <span>without saving</span> the answer to the previous question.</p><p>You can view all the questions by clicking on the <b>Question Paper</b> button. <span style="color:#ff0000">This feature is provided, so that if you want you can just see the entire question paper at a glance.</span></p><h4>Answering a Question :</h4><ol start="5"><li><p>Procedure for answering a multiple choice (MCQ) type question:</p><ol><li>Choose one answer from the 4 options (A,B,C,D) given below the question, click on the bubble placed before the chosen option.</li><li>To deselect your chosen answer, click on the bubble of the chosen option again or click on the <b>Clear Response</b> button</li><li>To change your chosen answer, click on the bubble of another option.</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>Procedure for answering a numerical answer type question :</p><ol><li>To enter a number as your answer, use the virtual numerical keypad.</li><li>A fraction (e.g. -0.3 or -.3) can be entered as an answer with or without "0" before the decimal point. <span style="color: red">As many as four decimal points, e.g. 12.5435 or 0.003 or -932.6711 or 12.82 can be entered.</span></li><li>To clear your answer, click on the <b>Clear Response</b> button</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>Procedure for answering a multiple correct answers (MCAQ) type question</p><ol><li>Choose one or more answers from the 4 options (A,B,C,D) given below the question, click on the bubble placed before the chosen option.</li><li>To deselect your chosen answer, click on the bubble of the chosen option again or click on the <b>Clear Response</b> button</li><li>To change your chosen answer, click on the bubble of another option</li><li>To save your answer, you MUST click on the <b>Save & Next</b> button</li></ol></li><li><p>To mark a question for review, click on the <b>Mark for Review & Next</b> button. If an answer is selected (for MCQ) entered (for numerival answer type) for a question that is <b>Marked for Review</b> , that answer will be considered in the evaluation unless the status is modified by the candidate.</p></li><li><p>To change your answer to a question that has already been answered, first select that question for answering and then follow the procedure for answering that type of question.</p></li><li><p>Note that ONLY Questions for which answers are <b>saved</b> or <b>marked for review after answering</b> will be considered for evaluation.</p></li><li><p>Sections in this question paper are displayed on the top bar of the screen. Questions in a Section can be viewed by clicking on the name of that Section. The Section you are currently viewing will be highlighted.</p></li><li><p>After clicking the <b>Save & Next</b> button for the last question in a Section, you will automatically be taken to the first question of the next Section in sequence.</p></li><li><p>You can move the mouse cursor over the name of a Section to view the answering status for that Section.</p></li></ol></div><div class="col-xs-12 c-test-instructions" ng-class="{\'railway-test-interface\':isRailwayTestInterfaceUsed}" ng-show="showInstTab == 1" id="bank-instructions" ng-if="isNewSscInterfaceInstructionEnabled && isSscNewInterface"><img src="/assets/img/ui-kit/new-ssc-instruction.webp" alt="new-ssc-instruction"></div><div class="col-xs-12 c-test-instructions" ng-class="{\'railway-test-interface\':isRailwayTestInterfaceUsed}" ng-show="showInstTab == 1" id="bank-instructions" ng-if="!instructionsJSON.isGateExam && !isNewSscInterfaceInstructionEnabled"><h4>General Instructions:</h4><ol start="1"><li><p>The clock will be set at the server. The countdown timer at the top right corner of screen will display the remaining time available for you to complete the examination. When the timer reaches zero, the examination will end by itself. You need not terminate the examination or submit your paper.</p></li><li><p>The Question Palette displayed on the right side of screen will show the status of each question using one of the following symbols:</p><ul class="que-ans-states hide-on-railway"><li><span class="label"></span> You have not visited the question yet.</li><li><span class="label skipped"></span> You have not answered the question.</li><li><span class="label attempted"></span> You have answered the question.</li><li><span class="label bookmarked"></span> You have NOT answered the question, but have marked the question for review.</li><li><span class="label attempted bookmarked"></span> You have answered the question, but marked it for review.</li><li ng-if="hasSkipOptionSupport"><span class="label unattempted"></span> You have answered NOT selected any option.</li></ul><ul class="railway-instructions-legend show-on-railway"><li><span class="new-legend not-answered"></span> You have not answered the question.</li><li><span class="new-legend answered"></span> You have answered the question.</li><li><span class="new-legend reviewed"></span> You have NOT answered the question, but have marked the question for review.</li><li><span class="new-legend reviewed-answered"></span> You answered the question also marked the question for review.</li><li ng-if="hasSkipOptionSupport"><span class="label unattempted"></span> You have answered NOT selected any option.</li></ul></li></ol><p>The <b>Mark For Review</b> status for a question simply indicates that you would like to look at that question again. If a question is answered, but marked for review, then the answer will be considered for evaluation unless the status is modified by the candidate.</p><b>Navigating to a Question :</b><ol start="3"><li><p>To answer a question, do the following:</p><ol><li>Click on the question number in the Question Palette at the right of your screen to go to that numbered question directly. Note that using this option does NOT save your answer to the current question.</li><li>Click on <b>Save & Next</b> to save your answer for the current question and then go to the next question.</li><li>Click on <b>Mark for Review <span class="hide-on-railway">& Next</span></b> to save your answer for the current question and also mark it for review <span class="hide-on-railway">, and then go to the next question.</span></li></ol></li></ol><p>Note that your answer for the current question will not be saved, if you navigate to another question directly by clicking on a question number <span>without saving</span> the answer to the previous question.</p><p>You can view all the questions by clicking on the <b>Question Paper</b> button. <span style="color:#ff0000">This feature is provided, so that if you want you can just see the entire question paper at a glance.</span></p><h4>Answering a Question :</h4><ol start="4"><li><p>Procedure for answering a multiple choice (MCQ) type question:</p><ol><li>Choose one answer from the 4 options (A,B,C,D) given below the question<span class="hide-on-railway">, click on the bubble placed before the chosen option.</span></li><li class="hide-on-railway">To deselect your chosen answer, click on the bubble of the chosen option again or click on the <b><span class="hide-on-railway">Clear Response</span> <span class="show-on-railway">Erase Answer</span></b> button</li><li>To change your chosen answer, click on the bubble of another option.</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>Procedure for answering a numerical answer type question :</p><ol><li>To enter a number as your answer, use the virtual numerical keypad.</li><li>A fraction (e.g. -0.3 or -.3) can be entered as an answer with or without "0" before the decimal point. <span style="color: red">As many as four decimal points, e.g. 12.5435 or 0.003 or -932.6711 or 12.82 can be entered.</span></li><li>To clear your answer, click on the <b>Clear Response</b> button</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li ng-show="isJeeTestInterfaceUsed"><p>Procedure for answering a multiple correct answers (MCAQ) type question</p><ol><li>Choose one or more answers from the 4 options (A,B,C,D) given below the question, click on the bubble placed before the chosen option.</li><li>To deselect your chosen answer, click on the checkbox of the chosen option again</li><li>To clear your marked responses, click on the <b>Clear Response</b> button</li><li>To save your answer, you MUST click on the <b>Save & Next</b> button</li></ol></li><li><p>To mark a question for review, click on the <b>Mark for Review <span class="hide-on-railway">& Next</span></b> button. If an answer is selected (for MCQ/MCAQ) entered (for numerical answer type) for a question that is <b>Marked for Review</b> , that answer will be considered in the evaluation unless the status is modified by the candidate.</p></li><li><p>To change your answer to a question that has already been answered, first select that question for answering and then follow the procedure for answering that type of question.</p></li><li><p>Note that ONLY Questions for which answers are <b>saved</b> or <b>marked for review after answering</b> will be considered for evaluation.</p></li><li><p>Sections in this question paper are displayed on the top bar of the screen. Questions in a Section can be viewed by clicking on the name of that Section. The Section you are currently viewing will be highlighted.</p></li><li><p>After clicking the <b>Save & Next</b> button for the last question in a Section, you will automatically be taken to the first question of the next Section in sequence.</p></li><li><p>You can move the mouse cursor over the name of a Section to view the answering status for that Section.</p></li></ol></div><div class="col-xs-12 c-test-instructions" id="dynamic-instructions" ng-show="showInstTab == 2"><div class="row"><div class="col-xs-12 dynamic-instructions"><div class="row"><div class="col-xs-12 col-sm-12 di-heading"><h3 class="text-center">{{instructionsJSON.examHeading}}</h3><h2 class="text-center">{{instructionsJSON.testHeading}}</h2></div><div ng-if="!instructionsJSON.hasSkippableSections" class="col-xs-12 col-sm-6"><b translate="TESTINSTRUCTIONDURATION" translate-values="{instructionsJSON: instructionsJSON}"></b></div><div ng-if="!instructionsJSON.hasSkippableSections" class="col-xs-12 col-sm-6"><b class="pull-right">{{\'Maximum Marks\' | translate }}: {{instructionsJSON.maximumMarks}}</b></div><div class="col-xs-12 col-sm-12 di-content"><div ng-if="instructionsJSON.instructionsArr"><p><b translate>Read the following instructions carefully.</b></p><div ng-if="instructionsJSON.instructionsArr.length == 1 && instructionsJSON.isSourceCP" class="for-all-exams"><li class="list-choices" ng-repeat="ins in instructionsJSON.instructionsArr"><span ng-bind-html="parseHtml(ins.value)"></span></li></div><ol start="1" ng-if="instructionsJSON && instructionsJSON.instructionsArr.length > 1 && !instructionsJSON.isSourceCP" class="for-all-exams"><li ng-repeat="ins in instructionsJSON.instructionsArr"><p><span ng-bind-html="parseHtml(ins.value)"></span></p></li></ol><div class="for-ssc"><u><b>प्रश्‍नपत्र के बारे में</b></u>:<br><br>1) इस प्रश्‍नपत्र में बहु-विकल्पीय वस्तुनिष्ठ प्रश्‍न हैं जिसमें 4 विकल्प दिए गए हैं, जिसमें से केवल 1 विकल्प सही है ।<br><br>2) कंप्‍यूटर आधारित परीक्षा द्विभाषी अर्थात अंग्रेजी एवं हिन्‍दी भाषा में होगी । प्रश्‍न और उत्‍तर के विकल्‍प दोनो भाषाओं में दिखाई देंगे ।<br><br>3) स्क्रीन के शीर्ष दाएं कोने में टाइमर (घड़ी) उपलब्ध है; आपसे अनुरोध है कि परीक्षा पूरी करने के लिए शेष समय की जानकारी हेतु इसे देखते रहें ।<br><br>4) एक बार में कंप्यूटर स्क्रीन पर केवल एक प्रश्‍न प्रदर्शित किया जाएगा । अभ्यर्थियों को अगले प्रश्‍न पर जाने के लिए स्क्रीन के नीचे दिए गए बटन <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> पर क्लिक करना चाहिए अथवा पिछले प्रश्‍न पर जाने के लिए <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> पर क्लिक करना चाहिए ।<br><br>5) प्रश्‍नों को दी गई समय सीमा के भीतर किसी भी क्रम में हल किया जा सकता है । अभ्‍यर्थी को 4 विकल्पों में से सही विकल्प पर माउस से क्लिक करना होगा । यदि अभ्यर्थी प्रश्‍न का उत्तर नही देना चाहता है तो वह उस प्रश्‍न को खाली छोड़ सकता है ।<div><br>6) अभ्यर्थी यदि चाहता है तो वह नए विकल्प का चयन कर किसी प्रश्‍न के विकल्प को बदल सकता है । यदि अभ्यर्थी प्रश्‍न का उत्तर नहीं देना चाहता है तो वह प्रश्‍न के सामने दिए गए <button type="button" class="btn btn-danger">Erase</button> को क्लिक कर उत्‍तर को अचयनित कर सकता है ।</div><div><br>7) प्रश्‍नों में आगे और पीछे जाने के लिए, अभ्यर्थियों को <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> या <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> बटन का इस्तेमाल करना चाहिए अथवा कंप्यूटर स्क्रीन के दाएं हाथ की ओर दी गई प्रश्‍न संख्या पर क्लिक करना चाहिए जहां पर प्रश्‍न संख्याओं को `किए गए` या `न किए गए` की स्थिति के साथ प्रदर्शित किया जाएगा।<br><br>8) जब भी अभ्यर्थी <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> या <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> बटन पर क्लिक करके अगले प्रश्‍न पर जाता है तो उत्तरों को सहेज लिया जाएगा ।<br><br>9) अभ्यर्थियों के पास स्क्रीन के निचले हिस्से में उपलब्ध. <button type="button" class="btn btn-warning">Tag</button> बटन पर क्लिक करके किसी प्रश्‍न को बुकमार्क करने का विकल्प है, अगर वे बाद में उसकी समीक्षा करने की इच्छा रखते हैं । एक विशेष प्रश्‍न पर मौजूद बुकमार्क को <button type="button" class="btn btn-warning">De-Tag</button> पर क्लिक करके हटाया जा सकता है ।<br><br>10) स्क्रीन के दायीं ओर प्रश्‍न पैलेट में प्रत्येक संख्यांकित प्रश्‍न की निम्नलिखित स्थिति दिखाई देती है ।<br><br><ul class="que-ans-states"><li><span class="label skipped"></span> आपने प्रश्‍न का उत्तर नहीं दिया है।</li><li><span class="label attempted"></span> आपने प्रश्‍न का उत्तर दिया है।</li><li><span class="label bookmarked"></span> आपने प्रश्‍न का उत्तर नहीं दिया है और समीक्षा के लिए चिन्हित किया है।</li><li><span class="label attempted bookmarked"></span> आपने प्रश्‍न का उत्तर दिया है लेकिन समीक्षा के लिए चिन्हित किया है।</li></ul><br><b>कृपया ध्यान दें: जिन</b><b>प्रश्‍नों का उत्तर दिया गया है और समीक्षा के लिए चिन्हित किया गया है उन</b><b>प्रश्‍नों को केवल तभी तक उत्तर दिया गया</b><b>प्रश्‍न माना जाएगा जब तक अभ्यर्थी चयनित विकल्प को <button type="button" class="btn btn-warning">Erase</button> नहीं करता है।</b><br><br>11) परीक्षा की अवधि पूर्ण होने पर, यदि अभ्‍यर्थी उत्‍तर पर क्लिक नहीं करता है अथवा <button type="button" class="btn btn-yellow-green">Submit Test</button> बटन पर क्लिक नहीं करता है तो कंप्‍यूटर द्वारा स्‍वत: शून्‍य परिणाम सहेज लिया जाएगा ।<br><br>12) अभ्‍यर्थी निर्धारित 1 घण्‍टा ( 60 मिनट ) के पूर्ण होने पर ही परीक्षा को submit करने में समर्थ होंगे । यदि अभ्‍यर्थी ने 1 घण्‍टा (60 मिनट) के पूर्ण होने पर अपनी परीक्षा पूर्ण नहीं की तो सिस्‍टम स्‍वत: परीक्षा को submit कर देगा।<br><br><div align="center"><b>"शुभकामनाएँ"</b><br></div><br><br><br><u><b>About Question Paper:</b></u><br><br>1) The Question Paper consists of multiple choice objective type questions with 4 options out of which only 1 is correct.<br><br>2) The computer based exam will be in bilingual i.e. English & Hindi Languages. Questions and Answer options will appear in both the languages.<br><br>3) There is a TIMER (Clock) available on the TOP RIGHT HAND CORNER of the Screen; you are requested to keep an eye on it for knowing the time remaining for the completion of the exam.<br><br>4) Only one question will be displayed on the computer screen at a time. To attempt next question the candidates should click on <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> or to go back click on <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> button provided at the bottom of the screen<br><br>5) The questions can be answered in any order within the given time frame. The candidate should click with the mouse on the correct choice, from 4 options given. In case, the candidate does not wish to attempt any question, it can be left blank.<br><br>6) The candidate can change the option of a question later by selecting a new option in case he/she wishes to. In case candidate does not want to answer the question, he/she can deselect the answer by clicking <button type="button" class="btn btn-danger">Erase</button> provided against the question.<br><br>7) To move back and forth between questions, candidates should use the <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> or <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> button or click on the question number on the right hand side of the computer screen where question numbers would be displayed along with the `attempted` and `not attempted` status<br><br>8) The answers will be saved whenever the candidate goes for next question, by clicking on <button type="button" class="btn btn-gray-dark">Next Question <i class="tb-icon tb-arrow-right-thin"></i></button> or <button type="button" class="btn btn-gray-dark"><i class="tb-icon tb-arrow-left-thin"></i> Previous Question</button> button.<br><br>9) Candidates have the option to bookmark a question in case they want to review it at a later stage by clicking on the <button type="button" class="btn btn-warning">Tag</button> button available at the bottom of the screen. The Bookmark on a particular question can be removed by clicking on <button type="button" class="btn btn-warning">De-Tag</button><br><br>10) The question palette at the right of the screen shows the following status of each of the questions numbered<br><br><ul class="que-ans-states"><li><span class="label skipped"></span> You have not answered the question.</li><li><span class="label attempted"></span> You have answered the question.</li><li><span class="label bookmarked"></span> You have NOT answered the question, but have marked the question for review.</li><li><span class="label attempted bookmarked"></span> You have answered the question, but marked it for review.</li></ul><br><b>PS: Questions which are attempted and marked for review would be treated as attempted questions only as long as the candidate does not <button type="button" class="btn btn-danger">Erase</button> the option selected.</b><br><br>11) On the completion of the test duration, even if the candidate does not click on an answer or does not click on the <button type="button" class="btn btn-yellow-green">Submit Test</button> button, a NIL result will be saved automatically by the computer.<br><br>12) The candidate will only be able to submit the test on completion of the stipulated 1 hour (60 Minutes). In case a candidate not completed his/her test at the completion of stipulated 1 hour (60 Minutes), the system shall automatically submit the test.<br><br><div align="center"><b>"ALL THE BEST"</b><br></div><br><br></div></div></div><div ng-if="!isTestInProgress"><div class="js-dummy-height-creater"></div><div class="test-start-acceptance js-test-start-acceptance"><div ng-if="!isUISSCCGL()"><form ng-show="languages.length > 1 && checkSdkModeActive || !checkSdkModeActive"><label for="language" translate>Choose your default language:</label><select ng-disabled="languages.length == 1" id="language" ng-model="$root.lang" ng-options="lang.prompt for lang in languages" ng-change="setLanguage(lang)"></select></form><p class="text-danger" translate ng-if="languages.length > 1">Please note all questions will appear in your default language. This language can be changed for a particular question later on</p><div ng-if="containOptionalSections && !chooseOptionalSecInTest" ng-repeat="section in optionalSectionsArr track by $index"><label for="section" ng-if="section.customText" translate>{{section.customText}}:</label> <label for="section" ng-if="!section.customText" translate>Choose your {{section.sectNo}} Section:</label><select id="language" ng-model="section.selectedSubSection" ng-options="subSection.title for subSection in section.Subsections" ng-change="setLanguage(lang)"></select><p class="text-danger" translate ng-if="section.Subsections.length > 1">Please note all questions in {{section.sectNo}} section will appear based on your selection here. This <strong>CANNOT</strong> be changed later on once the test starts</p></div><hr class="mar-v8" ng-show="languages.length > 1"></div><p><b>{{\'Declaration\' | translate }}:</b></p><label class="test-instructions-declaration"><input type="checkbox" name="instructions" ng-model="$root.checkboxModel.isAccepted" ng-true-value="true" ng-false-value="false"> {{\'I have understood and agree to all the instructions.\' | translate }}</label></div></div></div></div></div></div></div><div class="ti-control text-center for-all-exams" ng-class="{\'newInterface-instructions\':isSscNewInterface }"><ng-container ng-if="!fromOrganisation"><a ng-if="!isInClass && fromPyp" href="/{{PypTestSlug}}/previous-year-papers" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && fromScholarshipTest" href="/{{scholarshipTestSlug}}/scholarship-test" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && fromAttempted" href="/attempted-tests/" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && !fromAttempted && fromLivePage" href="/free-live-tests-and-quizzes/" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && !fromAttempted && fromLiveAttempted" href="/free-live-tests-and-quizzes/attempted/" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && fromTestSeries" href="/{{testSeriesUrl}}/test-series" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && fromSearch" href="/search/{{searchTerm}}" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="!isInClass && !fromTestSeries && !fromAttempted && !fromSearch && !fromScholarshipTest && !fromPyp && !fromLivePage && !fromLiveAttempted" href="/{{examURL}}/" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <a ng-if="isInClass" ng-href="{{backUrl}}" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2"><i class="tb-icon tb-arrow-left"></i><span class="hidden-xs">Go back to</span> {{isFromLesson?\'Lesson\':\'Course\'}}</a></ng-container><a ng-if="fromOrganisation" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab != 2" ng-click="backBtnPressed()"><i class="tb-icon tb-arrow-left"></i> {{\'GOBACKTEST\' | translate}}</a> <button class="btn btn-info-test pull-left" type="button" ng-hide="showInstTab == 1 || showInstTab == 0" ng-click="showInstTab = 1">{{\'Previous\' | translate }}</button> <button class="btn btn-info-test inst-next" ng-disabled="nextShowBtn" type="button" ng-hide="showInstTab == 2 || showInstTab==1" ng-click="jumpToInstruction()">{{\'Next\' | translate }}</button> <button class="btn btn-info-test inst-next" type="button" ng-hide="showInstTab == 2 || showInstTab==0" ng-click="showInstTab = 2;setStartTestConfirmation()">{{\'Next\' | translate }}</button><div class="d-inline-block align-middle" data-toggle="tb-tooltip"><button class="btn btn-theme" type="button" ng-show="showInstTab == 2 && !isTestInProgress" ng-click="startTest()" ng-disabled="!$root.checkboxModel.isAccepted">{{\'I am ready to begin\' | translate }}</button><div class="tb-tooltip top" ng-if="!$root.checkboxModel.isAccepted"><div class="po-content" translate>Please accept terms and condition before proceeding</div></div></div></div><div class="ti-control text-center for-ssc"><a href="/{{examURL}}/test-series" ng-if="!isInClass" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab == 2"><i class="tb-icon tb-arrow-left"></i><span class="hidden-xs">Go back to</span> My Test</a> <a ng-href="{{backUrl}}" ng-if="isInClass" class="btn btn-link pull-left" ng-show="!isTestInProgress && showInstTab == 2"><i class="tb-icon tb-arrow-left"></i><span class="hidden-xs">Go back to</span> {{isFromLesson?\'Lesson\':\'Course\'}}</a> <button class="btn btn-gray-dark inst-next" type="button" ng-hide="showInstTab == 2" ng-click="showInstTab = 2;setStartTestConfirmation()">{{\'Next\' | translate}} <i class="tb-icon tb-arrow-right-thin"></i></button><div class="d-inline-block align-middle" data-toggle="tb-tooltip"><button class="btn btn-yellow-green" type="button" ng-show="showInstTab == 2 && !isTestInProgress" ng-click="startTest()" ng-disabled="!$root.checkboxModel.isAccepted" translate>I have read the instructions</button><div class="tb-tooltip top" ng-if="!$root.checkboxModel.isAccepted"><div class="po-content" translate>Please accept terms and condition before proceeding</div></div></div></div></div><div id="cuetSectionSubjectAlert" class="section-custom-alert-selection" style="opacity: 0; pointer-events: none;"><img width="24px" src="/assets/img/ui-kit/warn-circle.svg"><p style="margin:0px">You can select max {{maxSelectSubjects}} subjects overall according to CUET pattern</p></div></div><div class="jee-instruction" ng-if="isJeeTestInterfaceUsed"><div class="jee-instruction__jee-header">{{instructionsJSON.testHeading}}</div><div class="jee-instruction__main-left jee-instruction__page-1" ng-show="showInstTab == 1"><div class="jee-instruction__sub-title pad-l16">Instructions</div><div class="jee-instruction__container jee-instruction__page-1__container"><div class="pad-12"><div class="jee-instruction__body jee-instruction__page-1__body"><div class="jee-instruction__inner"><div class="text-title text-center pad-t16 pad-b16" style="font-size: 16px">READ THE INSTRUCTIONS CAREFULLY</div><div class="text-title mar-b16" style="font-size: 16px">GENERAL INSTRUCTIONS</div><ol class="text-left pad-r32" style="list-style-type: decimal; line-height: 18px"><li>Total duration of the paper is 3 hours (180 minutes).</li><li>The on-screen computer countdown timer on the top right corner of computer screen will display the remaining time (in minutes) available to you for completing the paper. When the on-screen countdown timer reaches zero, the paper will end by itself – No input from your side will be accepted after the timer reaches zero and whatever answers have been saved by you will automatically be submitted for evaluation.</li><li>The <strong>“Submit”</strong> button present at the bottom right corner of the screen will remain deactivated during the entire 180 minutes duration of the paper. Note that the <strong>“Submit”</strong> button will be activated only after the timer has reached zero and the saved responses will be automatically submitted. It is <strong>NOT</strong> required to click on <strong>“Submit”</strong> after the timer has reached zero.</li><li>The Question Palette displayed on the right side of screen will show the status of each question as per one of the following symbols (<em>the question numbers appear inside the symbols</em>):<br><table class="jee-instruction__table-area" border="1"><tbody><tr><td><span class="not_visited" title="Not Visited">1</span></td><td><strong>“Not Visited”</strong> - You have not visited the question yet.</td></tr><tr><td><span class="not_answered" title="Not Answered">2</span></td><td><strong>“Not Answered”</strong> - You have not answered the question yet.</td></tr><tr><td><span class="answered" title="Answered">3</span></td><td><strong>“Answered”</strong> - You have answered the question. All these questions will be evaluated.</td></tr><tr><td><span class="review" title="Marked for Review">4</span></td><td><strong>“Marked for Review”</strong> - You have NOT answered the question but have ONLY marked the question for review.</td></tr><tr><td><span class="review_marked_considered" title="Answered &amp; Marked for Review">5</span></td><td><strong>“Answered and Marked for Review”</strong> - You have answered the question and have also marked it for review. All these questions will be evaluated.</td></tr></tbody></table></li><br><li>The <strong>“Marked for Review”</strong> status for a question indicates you would like to look at that question again.</li><li>You can click on the "&gt;" arrow symbol, which appears to the left of question palette, to collapse the question palette thereby maximizing the question window. To view the question palette again, you can click on "&lt;" symbol which appears on the right side of question window.</li><li>Before you start the paper, select your default language (either ENGLISH or HINDI) for viewing the questions by selecting your preferred language from the drop down menu under <strong>“Choose your default language”</strong> located below the <strong>“Instructions to Candidates”</strong> section.</li><li>Anytime during the paper, you can change the question viewing language of the displayed question. To change the question viewing language (either ENGLISH or HINDI) of the displayed question, select the preferred language from the drop down menu under <strong>“View in”</strong> located in the upper right side of the question viewing window.</li><li>Anytime during the paper, you can change the default question viewing language of the question paper. You can click on <strong>“Profile”</strong> image on top right corner of computer screen to change the default language (either ENGLISH or HINDI) of the entire question paper during the exam. On clicking of Profile image, you will get an option to change the default question viewing language.</li><li>You can click on downward arrow symbol <img src="/assets/img/other/scroll-down.png" title="Scroll Down"> to navigate to the bottom and upward arrow <img src="/assets/img/other/scroll-up.png" title="Scroll Up"> to navigate to the top of the question area, without scrolling.</li><li>You can also use the computer mouse to scroll up/down the question viewing area to view complete contents of the question viewing area.</li><li>At the end of this <strong>“Instructions to Candidates”</strong> section, you must click on the checkbox beside the <strong>“I have read all the instructions and shall abide by them”</strong> and then only you will be able to proceed to view and answer the questions at the start of the paper. Your on-screen clock will start at the designated time of the start of the paper.</li><li>The full question paper can be viewed anytime during the paper by clicking the <strong>“Question Paper”</strong> button on the top right corner of the computer screen.</li><li>These instructions can be viewed anytime during the paper by clicking <strong>“Instructions”</strong> button located at the top right corner of the computer screen.</li></ol></div></div></div></div><div class="jee-instruction-footer jee-instruction-footer__page-1"><button class="btn btn-default jee-instruction-footer__btn-next-preview pull-right" ng-click="showInstTab = 2;setStartTestConfirmation()"><span class="text-right" style="width: 50px">Next</span> <span class="bg-angle bg-angle__next"></span></button></div></div><div class="jee-instruction__main-left jee-instruction__page-2" ng-show="showInstTab == 2"><div class="jee-instruction__sub-title pad-l16">Other Important Instructions</div><div class="jee-instruction__container jee-instruction__page-2__container"><div class="pad-12"><div class="jee-instruction__body jee-instruction__page-2__body"><div class="jee-instruction__inner"><div class="text-title">NAVIGATING THROUGH PARTS/SECTIONS OF QUESTION PAPER</div><ol class="text-left" style="list-style-type: lower-alpha"><li>Parts (PHYSICS, CHEMISTRY and MATHEMATICS) and sections of the parts thereof in the question paper are displayed on the top of the screen. Questions within a section can be viewed by clicking on the corresponding section name. The section which you will be viewing will be highlighted.</li><li>After clicking the<strong>“Save &amp; Next”</strong> button on the last question of a part/section, you will automatically be taken to the first question of the next part/section.</li><li>You can shuffle between parts/sections and questions within parts/sections anytime during the paper as per your convenience.</li><li>You can view the corresponding section summary which will be visible in every section above the question palette.</li></ol><div class="text-title mar-b12">NAVIGATING TO A QUESTION</div><div>To navigate between questions, you need to do the following:</div><ol start="1" class="text-left" style="list-style-type: lower-roman;" type="a"><li>Click on the question number in the Question Palette at the right of the screen to go to that numbered question directly. <strong>Note that using this option does NOT save the answer (if it is answered) to the current question. To save the answer, you must click on</strong><strong>“</strong><strong>Save &amp; Next”</strong>button<strong>.</strong></li><li>Click on <strong>“Save &amp; Next”</strong>button to save the answer for the current question and then go to the next question.</li><li>Click on <strong>“Mark for Review &amp; Next”</strong> button to mark it for review (with or without answering the question) and go to the next question.</li></ol><div class="text-title">ANSWERING A QUESTION</div><ul><li>Follow the procedure, given in <strong>“Instructions to Candidates”</strong> sheet (handed over to you before the start of the paper), for answering a particular type of question.</li><li>To change the answer of a question that has already been answered, if required, first click on the <strong>“Clear Response”</strong> button to clear the saved answer and then follow the procedure for answering that type of question.</li><li>To mark a question ONLY for review (i.e. without answering it), click on the <strong>“Mark for Review &amp; Next”</strong> button.</li><li>To mark a question for review (after answering it), click on <strong>“Mark for Review &amp; Next”</strong> button – the answered question which is also marked for review will be evaluated.</li><li>To save the answer, click on the <strong>“Save &amp; Next”</strong>button - the answered question will be evaluated.</li></ul><div class="text-title">END OF PAPER</div><ul><li>When the on-screen computer countdown timer on the top right corner of computer screen reaches zero, the paper will end by itself – No input from your side will be accepted after the timer reaches zero and whatever answers have been saved by you will be automatically submitted for evaluation. Note that the <strong>“</strong><strong>Submit</strong><strong>”</strong> button will be activated only after the timer has reached zero and the saved responses will be automatically submitted. It is NOT required to click on <strong>“Submit”</strong> after the timer has reached zero.</li></ul></div></div></div></div><div class="jee-instruction-footer jee-instruction-footer__page-2"><div ng-if="!isTestInProgress" class="jee-instruction-footer__scrollable"><form><label for="language" translate>Choose your default language:</label><select id="language" ng-model="$root.lang" ng-options="lang.prompt for lang in languages" ng-change="setLanguage(lang)"></select></form><p class="text-danger" translate>Please note all questions will appear in your default language. This language can be changed for a particular question later on</p><label class="label-acceptance"><input type="checkbox" name="instructions" ng-model="$root.checkboxModel.isAccepted" ng-true-value="true" ng-false-value="false"> I have read and understood the instructions. All computer hardware allotted to me are in proper working condition. I declare that I am not in possession of / not wearing / not carrying any prohibited gadget like mobile phone, bluetooth devices etc. /any prohibited material with me into the Examination Hall.I agree that in case of not adhering to the instructions, I shall be liable to be debarred from this Test and/or to disciplinary action, which may include ban from future Tests / Examinations</label></div><div class="text-center"><button class="btn btn-default jee-instruction-footer__btn-next-preview pull-left" ng-click="showInstTab = 1"><span class="bg-angle bg-angle__preview"></span> <span>Previous</span></button><div class="d-inline-block align-middle" data-toggle="tb-tooltip"><button class="btn jee-instruction-footer__jee-theme-btn" ng-click="startTest()" ng-disabled="!$root.checkboxModel.isAccepted">I am ready to begin</button><div class="tb-tooltip top" ng-if="!$root.checkboxModel.isAccepted"><div class="po-content" translate>Please accept terms and condition before proceeding</div></div></div></div></div></div><div class="jee-instruction__main-right"><div class="position-relative text-center" style="padding: 20px"><img src="/assets/img/other/new-candidateImage.jpg" height="100" width="100" alt="user-profile"></div><div class="jee-instruction__jee-user-profile">{{name}}</div><div class="jee-instruction__blue-gradient"></div></div></div><set-language current-language="lang.name"></set-language><div class="modal show cuet-dropdown" id="cuet-dropdown" ng-if="isPreInstructionDropDown"><div class="modal-dialog"><div class="modal-content pad-0"><div class="modal-header"><h4><b>Select Subjects in {{dropdownList.title}}</b></h4><div style="top:18px" class="tb-close text-gray-14" ng-click="closeInstructionModal()" data-dismiss="modal"></div></div><div class="modal-body" ng-style="{\'min-height\': isMobile ? \'300px\' : \'auto\'}"><div class="test-select-subject-search" ng-click="handleSubjectSearchInput()" ng-style="isSearchFocusEnabled ? {\'border\': \'1px solid #0AD0F4\'} : {}"><img class="search-icon" src="/assets/img/ui-kit/search.svg" alt="Search Icon"> <input class="search-input" ng-attr-autofocus="{{isSearchFocusEnabled ? \'true\' : undefined}}" type="text" ng-model="$searchTestSubject" ng-focus="isSearchFocusEnabled = true" ng-click="handleSubjectSearchInputFocus($event)" ng-blur="isSearchFocusEnabled = false" ng-keyup="handleSubjectSearchKeyup()" placeholder="Search subject"> <img ng-if="searchTestSubject.length > 0" ng-click="clearSearchSubjectSelection()" class="clear-icon" src="/assets/img/ui-kit/searchClear.svg" alt="Clear Icon"></div><div class="exam-list"><label class="tb-checkbox" style="text-transform:none;" ng-repeat="item in searchTestSubject ? currentSectionSearchData : dropdownList.sections track by $index"><input type="checkbox" ng-model="item.isChosen" ng-click="filterSubject($index)"> <span ng-class="{\'text-gray-8\': !item.isChosen}">{{item.title}}</span></label></div><div ng-if="currentSectionSearchData.length == 0 && searchTestSubject" class="noSearch-found-cuet-subject"><img class="search-icon" src="/assets/img/ui-kit/searchIcon.svg" width="24px" height="24px" alt="search Icon"><p class="not-found-tittle">No Subject found for “{{searchTestSubject}}”</p><p>Recheck or try searching in other sections</p></div><p class="current-subject-selected">{{dropdownList.selectedSectionCount || 0}} <span>Subjects Selected</span></p></div><div class="modal-footer d-flex"><button type="button" class="btn btn-link" ng-click="ClearResponse()">Clear All</button> <button type="button" class="btn btn-theme" style="margin-left:auto" ng-click="AddSectionSubject()">Confirm</button></div></div><div ng-if="cuetSelectionAlertEnabled" id="cuetSelectionModalAlert" class="toster-select-cuet-subject" style="background-color: #3B4A54;width: 100%;color:white;font-size: 16px;padding: 10px 20px; border-radius: 8px;display: flex; align-items: center; gap: 12px; margin-top: 14px;position: absolute; bottom: -73px;"><img width="24px" src="/assets/img/ui-kit/warn-circle.svg"><p style="margin:0px">You can select max {{maxSelectSubjects}} subjects overall according to CUET pattern</p></div></div></div><div class="modal version-warning show" tabindex="-1" role="dialog" ng-if="isVersionWarningModal && isMobile && checkSdkModeActive"><div><div class="modal-dialog" role="document"><button type="button" class="close" ng-click="closeWarningModal()"></button><div class="modal-content"><div class="modal-header"><h5 class="modal-title"><img src="/assets/img/other/warning-outline.svg" alt="warning"> <b>Warning</b></h5></div><div class="modal-body"><p>Your device seems to be using an outdated version of <b>Android System Webview.</b> This might cause some issues while attempting the test. Please update it now.</p></div><div class="modal-footer"><button type="button" class="btn btn-primary" ng-click="updateLink()">Update Now</button></div></div><div class="cuet-subject-modal"></div></div></div><div class="cuet-subject-modal"></div><div class="modal-backdrop" ng-click="closeWarningModal()"></div></div><div class="modal modal--blocker" id="blocker" ng-if="isMobile"><div class="modal-dialog modal-dialog-centered modal-dialog--blocker" style="align-items:flex-end"><div class="modal-content"><a class="modal-close" href="/{{testSeriesUrl}}/test-series"></a><div class="modal-body"><div class="testbook-logo"><img loading="lazy" width="110" height="24" src="https://cdn.testbook.com/mailer/pyp-pdf/Testbook_Logo.svg" alt="logo"></div><div class="alert-message">This test is available only on Computer/Laptop on www.testbook.com</div><div class="copy-text" ng-click="copyLink()"><img ng-if="linkCopied" src="/assets/img/other/copied.svg" width="18" height="18" style="margin-right: 2px;" alt="copy-logo"> <img ng-if="!linkCopied" src="/assets/img/other/copy.svg" width="16" height="16" style="margin-right: 2px;" alt="copy-logo"> {{linkCopied ? \'Copied\' : \'Copy\'}} link</div></div></div></div></div>',controller:"InstructionsController"}).when("/nt-instructions",{template:'<div class="sat-instruction"><div class="card card--sat-instruction"><img src="/assets/img/sat/tb-text-dark-logo.svg" alt="logo" width="120"><h1>Experience The Most <span>Realistic SAT Prep Platform.</span></h1><div class="card-flex"><img src="/assets/img/sat/clock-img.svg" alt="logo"><h4>Timing</h4><p><span>Practice tests are timed, but you can pause them. To continue on another device, you have to start over. We delete incomplete practice tests after 90 days.</span></p></div><div class="card-flex"><img src="/assets/img/sat/list-checks-img.svg" alt="logo"><h4>Scores</h4><p><span>When you finish the practice test, go to MY Practice to see your scores and get personalised study tips.</span></p></div><div ng-if="isMobile" class="card-flex"><img src="/assets/img/sat/assistance-technology.svg" alt="logo"><h4>Assistive Technology (AT)</h4><p><span>Be sure to practice with any AT you use for testing. If you to configure your AT settings here, you may need to repeat this step on test day.</span></p></div><div class="card-flex"><img src="/assets/img/sat/lock-open-img.svg" alt="logo"><h4>No Device Lock</h4><p><span>We don’t lock your device during practice. On test day, you’ll be blocked from using other programs or apps.</span></p></div><button ng-if="!isMobile" ng-click="startTest()" class="sat-btn sat-btn-primary">Start Now</button> <button ng-if="isMobile" ng-click="startTest()" class="sat-btn sat-btn-primary" ng-class="{\'sat-inst-safari\': detectBrowser() == \'Apple Safari\',\'sat-inst-samsung\': detectBrowser() == \'Samsung Browser\'}">Start Short Practice Test</button></div></div><div class="modal-sat modal-sat-exit" ng-if="isWarningPopup && isMobile"><div class="modal-content"><div class="sat-warning-header"><div class="icon-container"><img src="/assets/img/sat/sat-warning-frame.svg" alt="Check Icon" class="icon"></div></div><div class="modal-body"><h4 class="sat-warning-title">For the Best Experience,<br><span class="highlight">use Desktop</span></h4><div class="description">To simulate the real SAT testing environment, we recommend taking this test on a desktop computer. This will provide a more accurate experience, just like the official SAT exam setup.</div></div><div class="modal-footer"><button class="sat-btn sat-btn-primary" ng-click="backBtnPressed()">Exit Test</button> <button class="sat-btn sat-btn-flex" ng-click="toggleWarningPopup()">Continue (with limited experience)</button></div></div></div>',controller:"InstructionsController"}).when("/pt-instructions",{template:'<div class="plutus-interface plutus-interface--instruction"><div class="plutus-interface__header"><div class="plutus-container"><div class="header-section"><a href="/" class="header-logo"><img ng-src="{{currentLogo}}" alt="logo" width="153"></a></div><div class="header-section" style="flex: 1"><div class="text-title">{{instructionTitleArr[showPlutusCurrentTab-1]}}</div></div><div class="header-section"><div class="text-highlight">{{instructionsJSON.testHeading}}</div></div><div class="header-divider"></div><div class="header-section"><a class="btn-text-group" ng-href="{{backUrl}}"><img src="/assets/img/plutus/exit.png" alt="exit" width="34">Exit</a></div></div></div><div class="plutus-interface__body"><div class="plutus-container"><div ng-show="showPlutusCurrentTab == 1" ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-summary.html\'"></div><div ng-show="showPlutusCurrentTab == 2" ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-one.html\'"></div><div ng-show="showPlutusCurrentTab == 3" ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-two.html\'"></div><div ng-show="showPlutusCurrentTab == 4" ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-three.html\'"></div><div ng-show="showPlutusCurrentTab == 5" ng-include="\'/views/partials/plutus-test/instruction/plutus-instruction-start-exam.html\'"></div></div></div><div class="plutus-interface__footer"><div class="plutus-container"><div class="btn-group"></div><div class="btn-group"><div class="btn-text-group" ng-click="jumpToPreviousInstructionInPlutus()" ng-hide="showPlutusCurrentTab == 1"><img src="/assets/img/plutus/prev.png" alt="prev" width="34">Prev</div><div class="btn-text-group" ng-click="jumpToNextInstructionInPlutus()" ng-hide="showPlutusCurrentTab == 5"><img src="/assets/img/plutus/next.png" alt="next" width="34">Next</div></div></div></div></div>',controller:"InstructionsController"}).when("/test",{template:'<div class="test-top-bar" ng-show="isInitialized()"><div class="left-box"><div class="time-control-details"><div class="test-timer-play-pause"><button type="button" class="btn play-pause" ng-click="pauseBtnPressed()" ng-class="{\'js-paused\': isTimerPaused, \'js-submitted\': isTestSubmitted}"><i class="tb-icon tb-play"></i> <i class="tb-icon tb-pause"></i> <i class="tb-icon tb-check"></i></button></div><div class="time-name"><span class="time"><count-down-timer test-duration="{{test.remT}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{isTimerPaused}}" test-time-over-ptr="testTimeOver" resume-ptr="resumeTimerCB" hide-zero="n"></count-down-timer></span> <span class="name">{{test.title}}</span></div></div><div class="calci-btn"><button class="btn" ng-show="isGateExam" ng-click="showCalculator()"><span class="hidden-xs" translate>Calculator</span><svg width="15" height="15" viewBox="0 0 27 36"><g id="Styles" stroke="none" stroke-width="1" fill-rule="evenodd"><g id="Quiz-Calculator" transform="translate(-442 -53)"><g id="ic_calculator" transform="translate(442 53)"><path d="M2.43 0h22.14A2.43 2.43 0 0 1 27 2.43v31.14A2.43 2.43 0 0 1 24.57 36H2.43A2.43 2.43 0 0 1 0 33.57V2.43A2.43 2.43 0 0 1 2.43 0zm1.252 3.724V8.69h19.636V3.724H3.682zm0 8.69v4.965H8.59v-4.965H3.68zm0 7.448v4.966H8.59v-4.966H3.68zm0 7.448v4.966H8.59V27.31H3.68zm7.363-14.896v4.965h4.91v-4.965h-4.91zm0 7.448v4.966h4.91v-4.966h-4.91zm0 7.448v4.966h4.91V27.31h-4.91zm7.364-14.896v4.965h4.91v-4.965h-4.91zm0 7.448v12.414h4.91V19.862h-4.91z" id="Combined-Shape"></path></g></g></g></svg></button></div></div><div class="right-box"><button class="btn rb-btn test-btn-style" type="button" ng-click="submitBtnPressed()" translate>SUBMIT TEST</button></div></div><div class="test-content-container" ng-class="{\'sidebar-open\': isSideBarOpen}" ng-show="isInitialized()"><div class="test-section-bar"><div class="test-sections"><div class="scroll-gradient left"></div><div class="ts-inner"><div class="each" ng-repeat="section in test.sections track by $index" ng-hide="test.sections.length ==1 && section.title ==\'\'"><button type="button" class="btn" ng-class="{\'active\' : currentQuestion.sSNo -1 == $index, \'disabled\': !isActiveSection($index)}" ng-click="jumpToLastViewedQuestionInSection($index + 1)"><span class="name">{{section.title}}</span></button><ul class="dropdown-menu question-states-menu"><li class="d-arrow"></li><li class="skipped"><span class="icon"></span>{{\'Skipped\' | translate }}<span class="count">{{getNotAnsweredCount($index + 1)}}</span></li><li class="unseen"><span class="icon"></span>{{\'Unseen\' | translate }}<span class="count">{{getQuestionsCount($index + 1) - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1)}}</span></li><li class="answered"><span class="icon"></span>{{\'Attempted\' | translate }}<span class="count">{{getAnsweredCount($index + 1)}}</span></li><li class="marked"><span class="icon tb-icon tb-star"></span>{{\'Marked for Review\' | translate }}<span class="count">{{getBookmarkedCount($index + 1)}}</span></li></ul></div></div><div class="scroll-gradient right"></div></div><div class="dropdown select-language"><button class="lang-select-btn dropdown-toggle test-btn-style" type="button" id="language-selector" data-toggle="dropdown" aria-haspopup="true" aria-expanded="true"><span translate>View in:</span><span>{{lang.prompt}}</span> <i class="tb-icon tb-arrow-down-thin"></i></button><ul class="dropdown-menu dropdown-menu-right" aria-labelledby="language-selector"><li class="d-arrow"></li><li ng-repeat="l in languages" ng-class="{\'active\': l.name == lang.name, \'disabled\':!isTranslationPresent()}"><a data-href="#" class="btn-sm" ng-click="setLanguage(l)" ng-disabled="!isTranslationPresent()">{{l.prompt}}</a></li></ul></div></div><div class="inner-container" ng-class="{\'js-que-ans-view\':!isQuestionPaperVisible, \'js-que-list-view\':isQuestionPaperVisible}"><div class="content-view test-question-list"><div class="row"><div class="col-xs-12 content-height-fixer slim-scrollbar"><p class="test-ql-title" translate>Question Paper</p><div class="section-que-container" ng-repeat="section in test.sections track by $index" ng-show="isActiveSection($index)"><h4>Section: {{section.title}}</h4><ul class="list-choices"><li class="list-option" ng-repeat="question in section.questions track by $index" ng-click="questionPaperItemClicked($parent.$index +1, $index+1, false)"><div class="que-label ql-small" ng-class="{ \'js-que-bookmarked\': isBookmarked($parent.$index +1, $index+1), \'js-que-attempted\' : isAttempted($parent.$index +1, $index+1), \'js-que-skipped\' : isSkipped($parent.$index +1, $index+1), \'js-que-current\': isCurrentQuestion($parent.$index + 1, $index + 1) }"><div class="q-badge">{{$index + 1}}<span class="tb-icon tb-star"></span></div></div><div class="list-content" ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, lang.name)"></div></li></ul></div></div></div><div class="test-action-controls text-center"><button type="button" class="btn btn-gray-1 text-uppercase" ng-click="isQuestionPaperVisible = !isQuestionPaperVisible" translate>Back</button></div></div><div class="content-view test-question-view"><div class="row"><div class="content-height-fixer comprehension-box slim-scrollbar" ng-if="hasComprehension()"><div class="inner"><h4 class="title">Comprehension: <span class="d-inline-block mar-l16 font-weight-normal small">(Que No. {{(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno + 1) + " - " + (test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1)}})</span></h4><div ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, lang.name)"></div></div></div><div class="content-height-fixer question-answer-box on-test-page slim-scrollbar"><div ng-show="isNetworkAlertVisible" class="alert alert-danger network-unavailable font-sm">Network disconnected. Retrying...<br>You can continue to attempt the test, please <b>DO NOT REFRESH</b> the page and just make sure you are connected to network before submitting the test.</div><div ng-show="isMathJaxAlertVisible()" class="alert alert-danger network-unavailable font-sm" ng-bind-html="mathJaxErrorMsgHTML"></div><div class="question-box"><div class="row"><div class="col-xs-12 qb-header"><div class="left-box"><div class="que-label ql-small" ng-class="{ \'js-que-bookmarked\': isBookmarked(currentQuestion.sSNo, currentQuestion.qSNo), \'js-que-attempted\' : isAttempted(currentQuestion.sSNo, currentQuestion.qSNo), \'js-que-skipped\' : isSkipped(currentQuestion.sSNo, currentQuestion.qSNo), }"><div class="q-badge">{{currentQuestion.qSNo}}<span class="tb-icon tb-star"></span></div></div><div class="que-time"><count-up-timer secs="{{questionStartTimeOffsetIfRefresh}}" current-section="{{currentQuestion.sSNo}}" current-question="{{currentQuestion.qSNo}}" hide-zero="y" stop="{{isTestSubmitted || isTimerPaused}}"></count-up-timer></div><div class="que-marking-scheme"><span class="pos">+{{getPosMarks()}}</span> <span class="neg">-{{getNegMarks()}}</span></div></div><div class="clearfix right-box"><div class="pad-l4 mar-l4 pull-right"><button class="btn btn-sm mark-review-btn" type="button" ng-class="{\'marked-question\':isBookmarked(currentQuestion.sSNo, currentQuestion.qSNo)}" ng-click="bookmarkBtnPressed()"><i class="tb-icon tb-star-outline bookmark"></i> <i class="tb-icon tb-star bookmarked"></i> <span class="bookmark" translate>Mark For Review</span> <span class="bookmarked" translate>Marked For Review</span></button></div><div class="pull-right"><report-cta qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{lang.name}}" options="Wrong Question,Formatting Issue,Copyright Issue,Others" module-Type="{{moduleType}}" btn-type class="pull-right"></report-cta></div></div></div><div class="col-xs-12 qb-body"><div class="complete-que-content" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, lang.name)"></div></div></div></div><div class="answer-box"><ul class="list-choices" ng-show="!isNumerical()"><li class="list-option" ng-repeat="option in getOptions()" ng-class="{\'js-que-attempted\': selectedOption.value == option.prompt}" ng-click="setOption(option)"><div class="que-label ql-small"><div class="q-badge">{{option.prompt}}</div></div><div class="list-content" ng-bind-html="parseDesc(option.value)"></div></li></ul><div class="numeric-answer" ng-show="isNumerical()" ng-controller="KeypadController"><p>Your answer: <span>{{getNumInput()}}</span></p><div class="tb-icon tb-keypad"><button type="button" class="btn" ng-repeat="i in range" ng-click="onKeyPress(i)">{{i}}</button></div></div></div></div></div><div class="test-action-controls"><button type="button" class="btn tb-btn-secondary text-uppercase mark-next" ng-click="bookmarkAndNextBtnPressed()" translate>Mark <span class="hidden-xs">for Review</span> & Next</button> <button type="button" class="btn btn-link text-uppercase clear-selection" ng-click="clearResponse()"><span class="tb-icon tb-clear"></span> {{\'Clear Selection\' | translate }}</button> <button type="button" class="btn btn-primary text-uppercase pull-right save-next" ng-click="saveAndNextBtnPressed(false)" translate>Save & Next</button></div></div></div><div class="test-content-backdrop" ng-click="toggleSideBar(false)"></div><div class="open-test-sidebar" ng-click="toggleSideBar(true)"><span class="tb-icon tb-menu"></span></div><div class="test-sidebar"><button type="button" class="btn close-sidebar" ng-click="toggleSideBar(false)"><i class="tb-icon tb-clear"></i></button><ul class="list-unstyled nav-sections" ng-class="{\'list-view-active\': isListViewEnabled, \'list-view-deactive\': !isListViewEnabled}"><li ng-class="{\'active\': !isListViewEnabled}"><button type="button" class="btn" ng-click="toggleListView(false)"><i class="tb-icon tb-grid font-size-base-1"></i> {{\'Grid View\' | translate }}</button></li><li ng-class="{\'active\': isListViewEnabled}"><button type="button" class="btn" ng-click="toggleListView(true)"><i class="tb-icon tb-bullet-list font-size-base"></i> {{\'List View\' | translate }}</button></li></ul><div class="section-question-list" ng-class="{\'list-view\': isListViewEnabled}"><ul class="accordion"><li class="course-accordion each-section" ng-repeat="section in test.sections track by $index" ng-class="{\'disabled\': !isActiveSection($index)}"><div class="accordion-head header"><div class="section-details"><span class="tb-icon tb-arrow-right-b triangle-icon"></span><div class="name">{{section.title || test.title}}</div><span class="time-spent js-limited-time" ng-show="!test.sectionTimeSharedFlag"><count-down-timer test-duration="{{getSectionRemT($index)}}" is-test-submitted="{{isTestSubmitted}}" is-timer-paused="{{!isActiveSection($index) || isTimerPaused}}" hide-zero="y"></count-down-timer></span><div class="comp-status"><span ng-style="{\'width\':getAnsweredCount($index + 1)*100/getQuestionsCount($index + 1) + \'%\'}"></span></div></div><ul class="question-states-menu inline-menu mar-t8"><li class="skipped"><span class="icon"></span><span class="count">{{getNotAnsweredCount($index + 1)}}</span></li><li class="unseen"><span class="icon"></span><span class="count">{{section.questions.length - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1)}}</span></li><li class="answered"><span class="icon"></span><span class="count">{{getAnsweredCount($index + 1)}}</span></li><li class="marked"><span class="icon tb-icon tb-star"></span><span class="count">{{getBookmarkedCount($index + 1)}}</span></li></ul></div><div class="accordion-content body"><div class="row"><div class="col-xs-12"><ul class="question-list"><li class="que-label ql-large" ng-repeat="question in section.questions track by $index" ng-class="{ \'js-que-bookmarked\': isBookmarked($parent.$index +1, $index+1), \'js-que-attempted\' : isAttempted($parent.$index +1, $index+1), \'js-que-skipped\' : isSkipped($parent.$index +1, $index+1), \'js-que-current\': isCurrentQuestion($parent.$index + 1, $index + 1) }" ng-click="sideBarItemClicked($parent.$index +1, $index+1)"><div class="q-badge">{{$index + 1}}<span class="tb-icon tb-star"></span></div><div class="que-title" ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, lang.name, 170)"></div></li></ul></div></div></div></li></ul></div><div class="quesList-inst"><a data-href="#" class="dropup">Help<ul class="dropdown-menu question-states-menu"><li class="skipped"><span class="icon"></span>{{\'Skipped\' | translate }}</li><li class="unseen"><span class="icon"></span>{{\'Unseen\' | translate }}</li><li class="answered"><span class="icon"></span>{{\'Attempted\' | translate }}</li><li class="marked"><span class="icon tb-icon tb-star"></span>Marked for Review</li></ul></a> | <a data-href="#" ng-click="isQuestionPaperVisible = !isQuestionPaperVisible; toggleSideBar(false)" translate>Question Paper</a> | <a data-href="#" ng-click="getDynamicInstructions()" translate>Instructions</a></div></div></div><div id="summaryModal" class="modal" tabindex="-1" role="dialog" aria-labelledby="summaryModalLabel" aria-hidden="true"><div class="modal-dialog test-summary-modal"><div class="modal-content submit-test"><div class="modal-body clearfix"><div class="row"><div class="col-xs-12 intro-text"><h2 class="title" translate>My Test Summary</h2><span translate>Answers are saved Successfully</span></div><div class="col-xs-12 summary-container"><div class="summary-table"><div class="row"><div class="col-xs-12 summary-each-section head"><div class="content col-xs-2" translate>Section</div><div class="content col-xs-2" translate>Attempted</div><div class="content col-xs-2" translate>Skipped</div><div class="content col-xs-2" translate>Bookmarked</div><div class="content col-xs-2" translate>Unseen</div><div class="content col-xs-2" translate>Total</div></div><div class="col-xs-12 summary-each-section body" ng-repeat="section in test.sections track by $index" ng-show="test.sections.length>1"><div class="content col-xs-2">{{section.title}}</div><div class="content col-xs-2">{{getAnsweredCount($index + 1)}}</div><div class="content col-xs-2">{{getNotAnsweredCount($index + 1)}}</div><div class="content col-xs-2">{{getBookmarkedCount($index + 1)}}</div><div class="content col-xs-2">{{getQuestionsCount($index + 1) - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1)}}</div><div class="content col-xs-2">{{getQuestionsCount($index + 1) }}</div></div><div class="col-xs-12 summary-each-section footer"><div class="content col-xs-2">Total</div><div class="content col-xs-2">{{getAnsweredCount(0)}}</div><div class="content col-xs-2">{{getNotAnsweredCount(0)}}</div><div class="content col-xs-2">{{getBookmarkedCount(0)}}</div><div class="content col-xs-2">{{getQuestionsCount(0) - getAnsweredCount(0) - getNotAnsweredCount(0)}}</div><div class="content col-xs-2">{{getQuestionsCount(0)}}</div></div></div></div></div></div></div><div class="modal-footer pad-0"><button class="btn btn-block btn-lg btn-test-primary border-radius-t0" data-dismiss="modal" type="button" ng-show="isTestPaused && !isTestSubmitted" ng-click="resumeBtnPressed()">Resume Test</button> <a class="btn btn-block btn-lg btn-test-primary border-radius-t0 mar-t0" href="#/solutions" ng-show="isTestSubmitted">Continue</a></div></div><div class="modal-content-bottom mar-v32" ng-show="isTestPaused && !isTestSubmitted"><div class="modal-footer"><div class="text-center"><a href="/{{examURL}}/test-series" class="btn btn-sm btn-link-white" translate>Go back to Tests</a></div></div></div></div></div><div ng-include="\'/views/partials/test/modal.html\'"></div><div ng-include="\'/views/partials/test/instructions.html\'"></div><div id="drag-calculator" class="test-calculator" ng-show="isShowCalculator" style="position: absolute;z-index:1000;"><div class="test-calculator-header"><button type="button" id="drag-calculator-btn" class="btn btn-sm btn-test-primary" translate>Drag Here</button> <button type="button" class="btn btn-sm btn-test-primary pull-right" ng-click="closeCalculator()" translate>Close</button></div><div ng-if="isShowCalculator"><iframe id="calci" name="calci" src="../../views/partials/calculator.html" style="width:500px;height:312px;background-color:#f9f9f9;position: relative;left:-15px;top:-10px;"></iframe></div></div><set-language current-language="lang"></set-language>',controller:"TestController"}).when("/solutions",{redirectTo:"/lt-solutions"}).when("/interface",{template:'<div class="modal" id="selectInterface" tabindex="-1" role="dialog" aria-labelledby="selectInterfaceLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-md"><div class="modal-content select-interface-modal"><div class="modal-header text-center"><h4 class="modal-title">Select Test Interface</h4></div><div class="modal-body"><div class="row"><div class="col-xs-12"><div class="interface-options"><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="tb"> <span><span class="text">New Designed Interface</span> <span class="text">Improved experience by Testbook</span></span></label></div><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="official"> <span><span class="text">Actual Exam Interface</span> <span class="text">Same as in actual exam</span></span></label></div></div></div><div class="col-xs-12 set-default"><label class="tb-icon tb-checkbox"><input type="checkbox" ng-model="isDefault"> <span>Set as default</span></label></div></div></div><div class="modal-footer"><button type="button" class="btn btn-theme btn-lg btn-block" ng-click="processUISelection()">Continue</button></div></div><div class="modal-content-bottom mar-v16"><div class="modal-footer"><div class="text-center"><a href="/{{examURL}}/test-series" class="btn btn-sm btn-link-white">Go back to Test</a></div></div></div></div></div>',controller:"InterfaceController"}).when("/interface/:t",{template:'<div class="modal" id="selectInterface" tabindex="-1" role="dialog" aria-labelledby="selectInterfaceLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-md"><div class="modal-content select-interface-modal"><div class="modal-header text-center"><h4 class="modal-title">Select Test Interface</h4></div><div class="modal-body"><div class="row"><div class="col-xs-12"><div class="interface-options"><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="tb"> <span><span class="text">New Designed Interface</span> <span class="text">Improved experience by Testbook</span></span></label></div><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="official"> <span><span class="text">Actual Exam Interface</span> <span class="text">Same as in actual exam</span></span></label></div></div></div><div class="col-xs-12 set-default"><label class="tb-icon tb-checkbox"><input type="checkbox" ng-model="isDefault"> <span>Set as default</span></label></div></div></div><div class="modal-footer"><button type="button" class="btn btn-theme btn-lg btn-block" ng-click="processUISelection()">Continue</button></div></div><div class="modal-content-bottom mar-v16"><div class="modal-footer"><div class="text-center"><a href="/{{examURL}}/test-series" class="btn btn-sm btn-link-white">Go back to Test</a></div></div></div></div></div>',controller:"InterfaceController"}).when("/interface/:lid",{template:'<div class="modal" id="selectInterface" tabindex="-1" role="dialog" aria-labelledby="selectInterfaceLabel" aria-hidden="true" data-backdrop="static"><div class="modal-dialog modal-md"><div class="modal-content select-interface-modal"><div class="modal-header text-center"><h4 class="modal-title">Select Test Interface</h4></div><div class="modal-body"><div class="row"><div class="col-xs-12"><div class="interface-options"><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="tb"> <span><span class="text">New Designed Interface</span> <span class="text">Improved experience by Testbook</span></span></label></div><div class="each-option"><label class="tb-icon tb-radio"><input type="radio" name="selectInterface" ng-model="ui" value="official"> <span><span class="text">Actual Exam Interface</span> <span class="text">Same as in actual exam</span></span></label></div></div></div><div class="col-xs-12 set-default"><label class="tb-icon tb-checkbox"><input type="checkbox" ng-model="isDefault"> <span>Set as default</span></label></div></div></div><div class="modal-footer"><button type="button" class="btn btn-theme btn-lg btn-block" ng-click="processUISelection()">Continue</button></div></div><div class="modal-content-bottom mar-v16"><div class="modal-footer"><div class="text-center"><a href="/{{examURL}}/test-series" class="btn btn-sm btn-link-white">Go back to Test</a></div></div></div></div></div>',controller:"InterfaceController"}).when("/instructions",{template:'<div class="modal" id="readInstructions" tabindex="-1" role="dialog" aria-labelledby="readInstructionsLabel" aria-hidden="true"><div class="modal-dialog modal-md"><div class="modal-content read-instructions-modal"><div class="modal-header text-center"><h4 class="modal-title">Instructions for {{instructionsJSON.testHeading}} ({{instructionsJSON.examHeading}})</h4></div><div class="modal-body" style="max-height: calc(100vh - 224px);overflow-y: auto"><div class="row"><div class="col-xs-12"><div class="info-text"><span translate="TESTINSTRUCTIONDURATION" translate-values="{instructionsJSON: instructionsJSON}"></span> <span class="pull-right">Marks: {{instructionsJSON.maximumMarks}}</span></div></div><div class="col-xs-12"><div class="instructions"><h6>Read the following instructions carefully:</h6><ol start="1"><li ng-repeat="ins in instructionsJSON.instructionsArr"><span ng-bind-html="parseHtml(ins.value)"></span></li></ol></div><div class="row more-about-interface" ng-click="showInstTab = !showInstTab" ng-class="{\'open\': !showInstTab}">Know more about the interface<div class="pull-right"><span class="plus">+</span> <span class="minus">-</span></div></div><div class="other-instructions" ng-show="showInstTab == 0" id="gate-instructions" ng-if="instructionsJSON.isGateExam"><div class="row"><div class="col-xs-12"><h5>General Instructions:</h5><ol start="1"><li><p>The clock will be set at the server. The countdown timer at the top right corner of screen will display the remaining time available for you to complete the examination. When the timer reaches zero, the examination will end by itself. You need not terminate the examination or submit your paper.</p></li><li><p>You are only allowed to use on screen calculator. No personal calculators are allowed.</p></li><li><p>The Question Palette displayed on the right side of screen will show the status of each question using one of the following symbols:</p><ul class="que-legends"><li><div class="que-label ql-large js-que-skipped"><div class="q-badge"></div></div>You have not answered the question</li><li><div class="que-label ql-large js-que-unseen"><div class="q-badge"></div></div>You have not visited the question yet</li><li><div class="que-label ql-large js-que-attempted"><div class="q-badge"></div></div>You have answered the question</li><li><div class="que-label ql-large js-que-skipped js-que-bookmarked"><div class="q-badge"><span class="tb-icon tb-star"></span></div></div>You have NOT answered the question, but have marked the question for review</li><li><div class="que-label ql-large js-que-attempted js-que-bookmarked"><div class="q-badge"><span class="tb-icon tb-star"></span></div></div>You have answered the question, but marked it for review</li></ul></li></ol><p>The <b>Mark For Review</b> status for a question simply indicates that you would like to look at that question again. If a question is answered, but marked for review, then the answer will be considered for evaluation unless the status is modified by the candidate.</p><b>Navigating to a Question :</b><ol start="4"><li><p>To answer a question, do the following:</p><ol><li>Click on the question number in the Question Palette to go to that question directly.</li><li>Select an answer for a multiple choice type question by clicking on the bubble placed before the 4 choices, namely A, B, C and D. Use the virtual numeric keypad to enter a number as answer for a numerical type question.</li><li>Click on <b>Save & Next</b> to save your answer for the current question and then go to the next question.</li><li>Click on <b>Mark for Review & Next</b> to save your answer for the current question and also mark it for review, and then go to the next question.</li></ol></li></ol><p>Note that your answer for the current question will not be saved, if you navigate to another question directly by clicking on a question number <span>without saving</span> the answer to the previous question.</p><p>You can view all the questions by clicking on the <b>Question Paper</b> button. <span style="color:#ff0000">This feature is provided, so that if you want you can just see the entire question paper at a glance.</span></p><h5>Answering a Question :</h5><ol start="5"><li><p>Procedure for answering a multiple choice (MCQ) type question:</p><ol><li>Choose one answer from the 4 options (A,B,C,D) given below the question, click on the bubble placed before the chosen option.</li><li>To deselect your chosen answer, click on the bubble of the chosen option again or click on the <b>Clear Response</b> button</li><li>To change your chosen answer, click on the bubble of another option.</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>Procedure for answering a numerical answer type question :</p><ol><li>To enter a number as your answer, use the virtual numerical keypad.</li><li>A fraction (e.g. -0.3 or -.3) can be entered as an answer with or without "0" before the decimal point. <span style="color: red">As many as four decimal points, e.g. 12.5435 or 0.003 or -932.6711 or 12.82 can be entered.</span></li><li>To clear your answer, click on the <b>Clear Response</b> button</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>To mark a question for review, click on the <b>Mark for Review & Next</b> button. If an answer is selected (for MCQ) entered (for numerival answer type) for a question that is <b>Marked for Review</b> , that answer will be considered in the evaluation unless the status is modified by the candidate.</p></li><li><p>To change your answer to a question that has already been answered, first select that question for answering and then follow the procedure for answering that type of question.</p></li><li><p>Note that ONLY Questions for which answers are <b>saved</b> or <b>marked for review after answering</b> will be considered for evaluation.</p></li><li><p>Sections in this question paper are displayed on the top bar of the screen. Questions in a Section can be viewed by clicking on the name of that Section. The Section you are currently viewing will be highlighted.</p></li><li><p>After clicking the <b>Save & Next</b> button for the last question in a Section, you will automatically be taken to the first question of the next Section in sequence.</p></li><li><p>You can move the mouse cursor over the name of a Section to view the answering status for that Section.</p></li></ol></div></div></div><div class="other-instructions" ng-show="showInstTab == 0" id="bank-instructions" ng-if="!instructionsJSON.isGateExam"><div class="row"><div class="col-xs-12"><h5>General Instructions:</h5><ol start="1"><li><p>The clock will be set at the server. The countdown timer at the top right corner of screen will display the remaining time available for you to complete the examination. When the timer reaches zero, the examination will end by itself. You need not terminate the examination or submit your paper.</p></li><li><p>The Question Palette displayed on the right side of screen will show the status of each question using one of the following symbols:</p><ul class="que-legends"><li><div class="que-label ql-large js-que-skipped"><div class="q-badge"></div></div>You have not answered the question</li><li><div class="que-label ql-large js-que-unseen"><div class="q-badge"></div></div>You have not visited the question yet</li><li><div class="que-label ql-large js-que-attempted"><div class="q-badge"></div></div>You have answered the question</li><li><div class="que-label ql-large js-que-skipped js-que-bookmarked"><div class="q-badge"><span class="tb-icon tb-star"></span></div></div>You have NOT answered the question, but have marked the question for review</li><li><div class="que-label ql-large js-que-attempted js-que-bookmarked"><div class="q-badge"><span class="tb-icon tb-star"></span></div></div>You have answered the question, but marked it for review</li></ul></li></ol><p>The <b>Mark For Review</b> status for a question simply indicates that you would like to look at that question again. If a question is answered, but marked for review, then the answer will be considered for evaluation unless the status is modified by the candidate.</p><b>Navigating to a Question :</b><ol start="3"><li><p>To answer a question, do the following:</p><ol><li>Click on the question number in the Question Palette at the right of your screen to go to that numbered question directly. Note that using this option does NOT save your answer to the current question.</li><li>Click on <b>Save & Next</b> to save your answer for the current question and then go to the next question.</li><li>Click on <b>Mark for Review & Next</b> to save your answer for the current question and also mark it for review, and then go to the next question.</li></ol></li></ol><p>Note that your answer for the current question will not be saved, if you navigate to another question directly by clicking on a question number <span>without saving</span> the answer to the previous question.</p><p>You can view all the questions by clicking on the <b>Question Paper</b> button. <span style="color:#ff0000">This feature is provided, so that if you want you can just see the entire question paper at a glance.</span></p><h5>Answering a Question :</h5><ol start="4"><li><p>Procedure for answering a multiple choice (MCQ) type question:</p><ol><li>Choose one answer from the options given below the questions. You may click on the entire option box to select your answer</li><li>To deselect your chosen answer, click on the bubble of the chosen option again or click on the <b>Clear Response</b> button</li><li>To change your chosen answer, click on the bubble of another option.</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>Procedure for answering a numerical answer type question :</p><ol><li>To enter a number as your answer, use the virtual numerical keypad.</li><li>A fraction (e.g. -0.3 or -.3) can be entered as an answer with or without "0" before the decimal point. <span style="color: red">As many as four decimal points, e.g. 12.5435 or 0.003 or -932.6711 or 12.82 can be entered.</span></li><li>To clear your answer, click on the <b>Clear Response</b> button</li><li>To save your answer, you MUST click on the <b>Save & Next</b></li></ol></li><li><p>To mark a question for review, click on the <b>Mark for Review & Next</b> button. If an answer is selected (for MCQ) entered (for numerival answer type) for a question that is <b>Marked for Review</b> , that answer will be considered in the evaluation unless the status is modified by the candidate.</p></li><li><p>To change your answer to a question that has already been answered, first select that question for answering and then follow the procedure for answering that type of question.</p></li><li><p>Note that ONLY Questions for which answers are <b>saved</b> or <b>marked for review after answering</b> will be considered for evaluation.</p></li><li><p>Sections in this question paper are displayed on the top bar of the screen. Questions in a Section can be viewed by clicking on the name of that Section. The Section you are currently viewing will be highlighted.</p></li><li><p>After clicking the <b>Save & Next</b> button for the last question in a Section, you will automatically be taken to the first question of the next Section in sequence.</p></li><li><p>You can move the mouse cursor over the name of a Section to view the answering status for that Section.</p></li></ol></div></div></div></div></div></div><div class="modal-footer pad-v8" ng-if="isSmartLab && smartLabTestStartStep != 2"><p class="text-center text-gray-9">Are you {{name}} ({{email}})?</p><div class="text-center"><a href="/logout" class="btn btn-link text-gray-3"><span class="text-capitalize">Login again</span></a> <button type="button" class="btn btn-default" ng-click="setSmartLabTestStartStep(2)"><span class="text-theme">Yes, I\'m {{name}}</span></button></div></div><div class="modal-footer" ng-if="!isSmartLab || smartLabTestStartStep == 2"><button type="button" ng-click="startTest()" class="btn btn-success btn-lg btn-block border-radius-t0" ng-if="!isTestInProgress">Start Test</button> <button type="button" data-dismiss="modal" class="btn btn-primary btn-lg btn-block border-radius-t0" ng-if="isTestInProgress">Back to Test</button></div></div><div class="modal-content-bottom mar-v8" ng-if="!isTestInProgress"><div class="modal-footer"><p class="text-center text-danger mar-b4" ng-if="isSmartLab && smartLabTestStartStep != 2">You will lose your test data if you take test in wrong account!</p><div class="text-center"><a href="/{{examURL}}/test-series" class="btn btn-sm btn-link-white" translate>Go back to Tests</a></div></div></div></div></div><set-language current-language="lang.name"></set-language>',controller:"InstructionsController"}).otherwise({redirectTo:"/interface"})}]),n.controller("AuthController",["$scope","testService",function(e,t){e.orgDetails=JSON.parse(getLocalStorage("orgDetails")||"{}");var n=getQueryParamValue("fromTbIos")||!1;e.examURL=$("#examURL").val()||"",e.isInternational=e.examURL.startsWith("sat-"),JSON.parse(n)||e.isInternational||t.partnerDetails(e.orgDetails&&e.orgDetails["cp-org-id"]),e.page=getQueryParamValue("page"),e.hidePageName=getQueryParamValue("hidePageName")||"",e.hideAnalysis=getQueryParamValue("hideAnalysis")||!1,e.hideRank=getQueryParamValue("hideRank")||!1,setLocalStorage("isIOSDevice",n,COOKIE_EXPIRY_SHORT),setLocalStorage("hideRank",e.hideRank,COOKIE_EXPIRY_SHORT),setLocalStorage("hideAnalysis",e.hideAnalysis,COOKIE_EXPIRY_SHORT),setLocalStorage("hidePageName",JSON.stringify(e.hidePageName),COOKIE_EXPIRY_SHORT),""!=e.auth&&(t.getSID(),t.getStuName());var s=window.location.pathname+"#/interface";switch(e.page){case"test":s=window.location.pathname+"#/interface";break;case"analysis":t.hideAnalysis()||(s=window
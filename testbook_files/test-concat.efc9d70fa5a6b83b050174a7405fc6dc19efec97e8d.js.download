r:</strong><ul class="single-page-comp-option col-xs-12 col-sm-2 pull-right" ng-if="isMobile"><li ng-repeat="option in getOptions(question) track by $index"><label><input type="radio" name="option-{{question.qSNo}}" ng-checked="question.selectedOption.value == option.prompt" ng-click="setOption(option, question,$event)"><div class="qns-view-box mar-l24" ng-class="{\'font-weight-bold\': isASMInterface}" ng-bind-html="parseDesc(option.value)"></div><div class="mar-l24 qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><ul class="single-page-comp-option col-xs-12 col-sm-4 pull-right option-content-box counter-reset" ng-class="{\'asm-singlepage--options pad-r52\' : isASMInterface}" ng-if="!isMobile"><li ng-repeat="option in getOptions(question) track by $index" class="counter-list"><label><input type="radio" name="option-{{question.qSNo}}" ng-checked="question.selectedOption.value == option.prompt" ng-click="setOption(option, question,$event)"><div ng-bind-html="parseDesc(option.value)"></div><div ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul></div></li></ul></div><div ng-show="isNumerical()" class="mar-t16 col-md-3 col-xs-6" ng-controller="KeypadController"><div class="alert bg-gray-1"><span ng-show="getNumInput() === \'None\'">Enter your answer</span> <span class="font-weight-semibold" ng-show="getNumInput() !== \'None\'">{{getNumInput()}}</span></div><div class="row"><div class="col-xs-4 pad-h8" ng-repeat="i in range" ng-click="onKeyPress(i)"><button type="button" class="btn btn-theme" style="min-width:60px; margin:3px;">{{i}}</button></div></div></div></div></div><div id="question-box" ng-if="hasTypingTest" class="typing-question body slim-scrollbar"><div class="typing-question__box mar-t12 col-lg-offset-2"><div><label for="question">Text</label><div><div class="question slim-scrollbar" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div></div></div><div class="mar-t24"><div><textarea spellcheck="false" id="answer" class="slim-scrollbar" ng-model="$parent.typingTestAnswer.value" ng-keyup="getTypingTestAnswer($event)" ng-keydown="getTypingTestAnswer($event)" name="answer" type="text" placeholder="*Start Typing Here*"></textarea></div></div><div class="input-info"><div ng-if="typingTestAnswer.value" id="input-info-char">Characters - <span ng-bind="countInfoCharacters(typingTestAnswer.value)"></span></div><div ng-if="typingTestAnswer.value" id="input-info-words">Words - <span ng-bind="countInfoWords(typingTestAnswer.value)"></span></div></div></div></div><div id="question-box" ng-if="!hasTypingTest && test.sections[currentQuestion.sSNo-1].isInstruction" class="body detailed-question js-detailed-question" ng-class="{\'asm-scroll-view\' : isASMInterface}"><div class="que-ans-box qns-view-box" ng-bind-html="parseHtml(test.sections[currentQuestion.sSNo-1].text)"></div></div><div class="footer mob-button-footer on-test-page"><div class="footer-inner hide-on-railway" ng-if="!test.sections[currentQuestion.sSNo-1].isNonQuestionSection"><button type="button" class="btn btn-info-test mar-t0" ng-show="!hasTypingTest && !isNoShowSection() && !isASMInterface" ng-click="bookmarkAndNextBtnPressed()" ng-disabled="areAnswersDisabled()">Mark for Review <span class="temp-text">& Next</span><span class="icon"></span></button> <button type="button" class="btn btn-info-test mar-t0" ng-show="!hasTypingTest && !isNoShowSection() && !isSpeedComprehension()" ng-click="clearResponse()">Clear <span class="temp-text">Response</span></button> <button type="button" class="btn btn-gray-1 mar-t0 mar-l16" ng-if="!shouldHideSubmitSectionButton()" ng-click="sectionalSubmitBtnClicked()">Submit Section</button> <button type="button" class="btn btn-gray-1 mar-t0 mar-l16" ng-if="shouldShowSubmitSubsectionButton()" ng-disabled="isSubsectionProgressionSyncInFlight()" ng-click="subsectionalSubmitBtnClicked()">Submit Sub-section</button> <button type="button" class="btn btn-gray-1 pull-right mar-t0 mar-l16" ng-if="isASMInterface && test.isSectionalSubmit" ng-click="sectionalSubmitBtnClicked()">{{\'Submit Sections\' }}</button> <button type="button" class="btn btn-theme pull-right mar-t0 mar-l16" ng-if="isASMInterface && !isFixedComprehension()">{{\'Save\' }}</button><button type="button" class="btn btn-theme pull-right mar-t0" ng-show="!hasTypingTest && !isSpeedComprehension() && !isNoShowSection() && !isInEndofSection()" ng-click="saveAndNextBtnPressed(false, \'\', true)">{{\'Save\' }} <span>& Next</span><span class="icon">&rarr;</span></button> <button type="button" class="btn btn-theme pull-right mar-t0 mar-r8" ng-if="!isSpeedComprehension() && !isNoShowSection() && isASMInterface && currentQuestion.qSNo > 10" ng-click="saveAndPreviousBtnPressed()"><i class="tb-icon tb-arrow-left-thin"></i> Prev<span class="temp-text">ious</span> Que<span class="temp-text">stions</span></button> <button type="button" class="btn btn-theme pull-right mar-t0" ng-class="{\'mar-r16\' : test.sectionTimeSharedFlag && currentQuestion.qSNo > 10}" ng-if="(isSpeedComprehension() && !isASMInterface)" ng-click="submitTest(false)">{{\'Submit Test\' }}</button> <button type="button" class="btn btn-theme pull-right mar-t0" ng-class="{\'mar-r16\' : test.sectionTimeSharedFlag && currentQuestion.qSNo > 10}" ng-if="isASMInterface && !test.isSectionalSubmit" ng-click="showSubmitConfirmationModal()">{{\'Submit Test\' }}</button></div><div class="footer-inner hide-on-railway" ng-if="test.sections[currentQuestion.sSNo-1].isInstruction"><button type="button" class="btn btn-gray-1 pull-right mar-t0 mar-l16" ng-if="isASMInterface && test.isSectionalSubmit && !test.sections[currentQuestion.sSNo-1].isNonQuestionSection" ng-click="sectionalSubmitBtnClicked(true)">{{\'Submit Section\' }}</button> <button type="button" class="btn btn-gray-1 pull-right mar-t0 mar-l16" ng-if="isASMInterface && !test.sectionTimeSharedFlag && !test.isSectionalSubmit" ng-click="sectionalSubmitBtnClicked()">{{\'Submit instruction\' }}</button> <button type="button" class="btn btn-gray-1 pull-right mar-t0 mar-l16" ng-if="isASMInterface && !test.sectionTimeSharedFlag && test.sections[currentQuestion.sSNo-1].isNonQuestionSection" ng-click="sectionalSubmitBtnClicked()">{{\'Submit instruction\' }}</button></div><div class="footer-inner railway-footer-inner show-on-railway" ng-if="!isASMInterface"><button type="button" class="btn btn-info-outline-test" ng-show="!isSpeedComprehension() && !isNoShowSection()" ng-click="saveAndPreviousBtnPressed()">Save & Previous</button> <span class="d-inline-block option-btn-box counter-reset" ng-if="!isNumerical()"><button type="button" class="btn btn-info-outline-test pad-0 counter-list" ng-repeat="option in getOptions() track by $index"><label class="ui-form__element"><input type="radio" name="option-railways" ng-checked="selectedOption.value == option.prompt" ng-click="setOption(option)"> <span></span> <span class="option-number"></span></label></button></span> <button type="button" class="btn btn-info-outline-test" ng-show="!hasTypingTest && !isSpeedComprehension() && !isNoShowSection()" ng-click="saveAndNextBtnPressed(isQuestionBookmarked())">Save & Next</button> <button ng-show="!!hasTypingTest" type="button" class="btn btn-info-test pad-0"><label class="ui-form__element"><input type="checkbox" ng-show="!isNoShowSection()" ng-checked="isQuestionBookmarked()" ng-click="bookmarkBtnPressed()"> <span>Mark for Review</span></label></button> <button type="button" class="btn btn-theme" ng-show="!hasTypingTest && !isNoShowSection()" ng-click="clearResponse()">Erase Answer</button></div><div class="footer-inner-ssc text-center" ng-if="!test.sections[currentQuestion.sSNo-1].isNonQuestionSection"><button type="button" class="btn btn-gray-dark pull-left" ng-class="{\'mar-l16\': test.sectionTimeSharedFlag}" ng-click="saveAndPreviousBtnPressed()"><i class="tb-icon tb-arrow-left-thin"></i> Prev<span class="temp-text">ious</span> Que<span class="temp-text">stion</span></button> <button type="button" class="btn btn-gray-dark pull-left" ng-show="!hasTypingTest" ng-click="saveAndNextBtnPressed(false)">Next Que<span class="temp-text">stion</span> <i class="tb-icon tb-arrow-right-thin"></i></button> <button type="button" class="btn btn-danger pull-right" ng-if="!hasTypingTest" ng-click="clearResponse()">Erase</button> <button type="button" class="btn btn-warning toggle-que-tag" ng-click="bookmarkBtnPressed()" ng-class="{\'que-tagged\':isBookmarked(currentQuestion.sSNo, currentQuestion.qSNo)}"><span class="que-tag">Tag</span> <span class="que-de-tag">De-Tag</span></button></div></div></div><div class="qpip-inner" id="questionPaper" ng-if="isCurTab(\'qpaper\')"><div class="header"><h4 class="text-center pad-t12">Question Paper</h4></div><div class="body slim-scrollbar"><div class="body-inner"><div ng-repeat="section in test.sections track by $index" ng-show="isActiveSection($index)"><h4>Section: {{section.title || "Overall"}}</h4><ul class="list-group"><li class="list-group-item" ng-repeat="question in section.questions track by $index">Q. {{$index + 1}}) <span ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, $root.lang.name)"></span><hr></li><li class="list-group-item" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-repeat="question in section.questions track by $index">Q. {{$index + 1}}) <span ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, $root.secLang.name)"></span><hr></li></ul></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="instructions" ng-if="isCurTab(\'instructions\')"><div class="header"><h4 class="text-center pad-t12">Instructions</h4></div><div class="body"><div class="body-inner"><div ng-include="\'/livetest/views/partials/instructions.html\'"></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="profile" ng-if="isCurTab(\'profile\')"><div class="header"><h4 class="text-center pad-t12">Profile Details</h4></div><div class="body"><div class="body-inner"><div class="row"><div class="col-xs-12 col-md-6 col-md-offset-4"><div class="row"><div class="col-xs-12 col-sm-4"><b>User ID</b></div><div class="col-xs-12 col-sm-8">{{profile.userid}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Name</b></div><div class="col-xs-12 col-sm-8">{{profile.name}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Date of birth</b></div><div class="col-xs-12 col-sm-8">{{profile.dob}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Email ID</b></div><div class="col-xs-12 col-sm-8">{{profile.email}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Contact</b></div><div class="col-xs-12 col-sm-8">{{profile.contact}}</div></div></div></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="warning" ng-if="isCurTab(\'switchconfirmfinal\') || isCurTab(\'switchreset\') || isCurTab(\'resetconfirm\')"><ng-container ng-if="isCurTab(\'switchreset\') && (!test.containOptionalSections || !isSscNewInterface)"><div class="warning-container body" style="background: #ffffff;"><div class="warn__content"><h3 class="warn-header">Warning</h3><p class="warn-text"><span class="explain-text">You have chosen to change the optional section. You are required to reset the previously chosen optional sections by clicking on the corresponding checkbox in the table given below and then clicking on the <strong>RESET</strong> button. Please be aware that by resetting one of the previously chosen optional Sections, all the answers you have provided for questions in that Section will be <strong>DELETED. (If you choose to come back to this section later, you have to start answering this Section afresh.)</strong></span> <strong class="d-block">Are you sure that you want to reset an optional section now?</strong> <span class="hidden-xs">If <strong>YES</strong>, click the checkbox next to section you wish to reset and click on Reset button to reset that section.</span> <span class="visible-xs">If <strong>YES</strong>, click on Reset button to reset that section.</span></p></div><div class="action_content-web hidden-xs"><h4 class="font-weight-bold">Summary of Optional Section(s) :</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th translate>Optional Section Name</th><th translate>No. of Questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Answered & Marked for Review (will be considered for evaluation)</th><th ng-if="hasSkipOptionSupport" translate>No options selected</th><th translate>Reset</th></tr></thead><tbody><tr><td data-prompt="Section">{{selectedOptionalSectionName}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Answered & Marked for Review (will be considered for evaluation)">{{getBookmarkedAndAttemptedForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Reset" class="checkbox-gd"><span class="table-checkbox checkbox-gd_border" ng-class="{\'active\':isCheckedForOptionalSectionConfirmation}" ng-click="isCheckedForOptionalSection()"></span></td></tr></tbody></table><p class="warn-text" ng-if="isCheckBoxNotCheckedForOptionalSection"><strong>Please select the section(s) from the following list to reset :</strong></p></div><div class="action-cta"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div><div class="action_content-mweb visible-xs"><h5 class="text-center">Summary of Optional Section(s) :</h5><div class="content-summary"><div class="summary-col"><span>Optional Section Name</span> <span class="right">{{selectedOptionalSectionName}}</span></div><div class="summary-col"><span>No. of Questions</span> <span class="right">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Answered</span> <span class="right">{{getAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Not Answered</span> <span class="right">{{getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Marked for Review</span> <span class="right">{{getBookmarkedCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Answered & Marked for Review <span class="font-size-small d-block text-gray-11">(will be considered for evaluation)</span></span> <span class="right">{{getBookmarkedAndAttemptedForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Not Visited</span> <span class="right">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex) - getAnsweredCountForOptional(selectedCurrentSummaryIndex) - getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div></div></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'switchreset\') && test.containOptionalSections && isSscNewInterface"><div class="warning-container body" style="background: #ffffff;"><div class="warn__content"><h3 class="warn-header">Warning</h3><p class="warn-text"><span class="explain-text">You have chosen to change the optional subsection. You are required to reset the previously chosen optional subsection by clicking on the corresponding checkbox in the table given below and then clicking on the <strong>RESET</strong> button. Please be aware that by resetting one of the previously chosen optional subsections, all the answers you have provided for questions in that subsection will be <strong>DELETED. (If you choose to come back to this subsection later, you have to start answering this subsection afresh.)</strong></span> <strong class="d-block">Are you sure that you want to reset an optional subsection now?</strong> <span class="hidden-xs">If <strong>YES</strong>, click the checkbox next to subsection you wish to reset and click on Reset button to reset that subsection.</span> <span class="visible-xs">If <strong>YES</strong>, click on Reset button to reset that subsection.</span></p></div><div class="action_content-web hidden-xs"><h4 class="font-weight-bold">Summary of Optional Subsection(s) :</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th translate>Optional Subsection Name</th><th translate>No. of Questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Answered & Marked for Review (will be considered for evaluation)</th><th ng-if="hasSkipOptionSupport" translate>No options selected</th><th translate>Reset</th></tr></thead><tbody><tr><td data-prompt="Section">{{selectedOptionalSectionName}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Answered & Marked for Review (will be considered for evaluation)">{{getBookmarkedAndAttemptedForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Reset" class="checkbox-gd"><span class="table-checkbox checkbox-gd_border" ng-class="{\'active\':isCheckedForOptionalSectionConfirmation}" ng-click="isCheckedForOptionalSection()"></span></td></tr></tbody></table><p class="warn-text" ng-if="isCheckBoxNotCheckedForOptionalSection"><strong>Please select the subsection(s) from the following list to reset :</strong></p></div><div class="action-cta"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div><div class="action_content-mweb visible-xs"><h5 class="text-center">Summary of Optional Subsection(s) :</h5><div class="content-summary"><div class="summary-col"><span>Optional Subsection Name</span> <span class="right">{{selectedOptionalSectionName}}</span></div><div class="summary-col"><span>No. of Questions</span> <span class="right">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Answered</span> <span class="right">{{getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Not Answered</span> <span class="right">{{getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Marked for Review</span> <span class="right">{{getBookmarkedCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Answered & Marked for Review <span class="font-size-small d-block text-gray-11">(will be considered for evaluation)</span></span> <span class="right">{{getBookmarkedAndAttemptedForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Not Visited</span> <span class="right">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo) - getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo) - getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div></div></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'switchconfirmfinal\')"><div class="warning-container"><div class="warn__content"><h4 class="warn-header">ALERT</h4><p class="text-gray-base">Upon resetting, all the responses provided by you to all the questions in this section will be <strong>DELETED.<br>Are you sure, do you want to proceed further and reset {{selectedOptionalSectionName}} ?</strong></p></div><div class="action_content-web action-cta hidden-xs"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="handleWarningResetAction()">Reset</button></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="handleWarningResetAction()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'resetconfirm\')"><div class="warning-container"><div class="warn__content"><h4 class="warn-header">ALERT</h4><p class="text-gray-5"><strong>Deselecting the checkbox will DELETE all the questions marked in this section. Are you sure, do you want to deselect this section ?</strong></p></div><div class="action_content-web action-cta hidden-xs"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">No</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="deSelectionConfirm()">Yes</button></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">No</button> <button type="button" class="btn btn-block btn-theme" ng-click="deSelectionConfirm()">Yes</button></div></div></ng-container></div></div></div><div class="sidebar-open-bg"></div><button type="button" class="btn btn-theme navbar-toggle js-trigger-toggle-sidebar"><span class="tb-icon tb-menu"></span> <span class="tb-icon tb-clear"></span></button></div><div class="newInterface-left-box" ng-class="{\'newInterface-left-box-extended\': isTestScreenExtended}" ng-if="isSscNewInterface"><div class="test-sections-list" style="display: none;"><h5 class="sl-title" ng-if="!isASMInterface">Sections</h5><div class="sl-inner" ng-if="!isASMInterface"><ng-container ng-if="test.containOptionalSections && test.chooseOptionalSecInTest"><button ng-show="test.allSections.length > 4" ng-click="scrollSectionLeft()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-left" data-scroll="left"><svg width="17" height="17" viewBox="0 0 17 17"><path fill="#86A1AE" d="M11.896 12.604L7.698 8.396l4.198-4.207-1.292-1.293-5.5 5.5 5.5 5.5z" fill-rule="evenodd"></path></svg></button><ul id="sectionNavTabs" tb-auto-scroll class="height-100 nav nav-pills sections-list sections-gd"><li class="dropdown" ng-repeat="section in test.allSections track by $index" ng-class="{\'active\' : currentQuestion.actualSectionIndex == $index, \'disabled\': !isActiveSection($index) || isPartSectionDisabled($index)}" ng-click="jumpToLastViewedQuestionInSection($index + 1)"><div data-target="#section{{$index}}" class="btn checkbox-gd" ng-class="{\'optional-cta\':section && section.isOptional}"><div class="tb-popover bottom" ng-if="section.isOptional && section.isCurrentOptionalSectionNotSelectedAlert"><div class="gd-content">Please click the checkbox beside the optional section to attempt the questions in it</div></div><span ng-if="section && section.isOptional" class="checkbox-gd_border" ng-class="{\'active\':section.isSelectedSection}" ng-click="setOptionalSection($event,$index)"></span> <span class="hidden-xs sectional-title" ng-class="{\'sectional\':section && section.isOptional}">{{section.title || "Overall"}}</span> <span class="visible-xs">{{section.title.slice(0,3) || "Overall"}}</span></div></li></ul><button ng-show="test.allSections.length > 4" ng-click="scrollSectionRight()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-right" data-scroll="left"><svg width="17" height="17" viewBox="0 0 17 17"><path fill="#86A1AE" d="M5.104 12.604l4.198-4.208L5.104 4.19l1.292-1.293 5.5 5.5-5.5 5.5z" fill-rule="evenodd"></path></svg></button></ng-container><ng-container ng-if="test.containOptionalSections && !test.chooseOptionalSecInTest || !test.containOptionalSections"><button ng-show="test.sections.length > 6" ng-click="scrollSectionLeft()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-left" data-scroll="left"><svg width="17" height="17" viewBox="0 0 17 17"><path fill="#86A1AE" d="M11.896 12.604L7.698 8.396l4.198-4.207-1.292-1.293-5.5 5.5 5.5 5.5z" fill-rule="evenodd"></path></svg></button><ul id="sectionNavTabs" tb-auto-scroll class="nav nav-pills sections-list" ng-class="{\'height-100\': isOptionalSectionQuestion(currentQuestion.sSNo)}"><li class="dropdown" ng-repeat="section in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo - 1 == $index, \'disabled\': !isActiveSection($index) || isPartSectionDisabled($index)}" ng-click="jumpToLastViewedQuestionInSection($index + 1)"><a data-target="#section{{$index}}" class="question-attempted"><span class="hidden-xs">{{section.title || "Overall"}}</span> <span class="visible-xs">{{section.title.slice(0,3) || "Overall"}}</span> <span class="current-active-section" ng-if="isOptionalSectionQuestion(currentQuestion.sSNo)"><svg width="16" height="16" fill="none" viewBox="0 0 22 22" class="warn-circle"><path fill-rule="evenodd" clip-rule="evenodd" d="M11 2a9 9 0 1 0 0 18 9 9 0 0 0 0-18zM.5 11C.5 5.201 5.201.5 11 .5S21.5 5.201 21.5 11 16.799 21.5 11 21.5.5 16.799.5 11z" fill="#F7F8FA"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M11 8.75a.75.75 0 0 1 .75.75V17a.75.75 0 0 1-1.5 0V9.5a.75.75 0 0 1 .75-.75z" fill="#F7F8FA"></path><path d="M12.125 6.125a1.125 1.125 0 1 1-2.25 0 1.125 1.125 0 0 1 2.25 0z" fill="#F7F8FA"></path></svg><div class="tb-popover bottom" ng-if="!isMobile"><div class="po-content"><ul class="pad-0"><li>{{getAnsweredCount(currentQuestion.sSNo)}} Qs. Answered</li><li>You can attempt any {{OptionalSectionQuestionMaximumAttemptedCount(currentQuestion.sSNo)}} Qs. out of {{isTotalSectionQuestionCount(currentQuestion.sSNo)}} Qs.</li></ul></div></div><div class="tb-popover bottom" ng-if="testHoverOptionalQuestion && isMobile"><div class="po-content"><ul class="pad-0"><li>{{getAnsweredCount(currentQuestion.sSNo)}} Qs. Answered</li><li>You can attempt any {{OptionalSectionQuestionMaximumAttemptedCount(currentQuestion.sSNo)}} Qs. out of {{isTotalSectionQuestionCount(currentQuestion.sSNo)}} Qs.</li></ul></div></div></span></a><ul id="section{{$index}}Summary" class="dropdown-menu sections-list-details" role="menu" style="width:250px;" ng-if="isASMInterface"><li><div class="col-xs-12"><h6>{{section.title || "Overall"}}</h6></div></li><li><div class="col-xs-12"><h4><span class="label attempted pull-right">{{getAnsweredCount($index + 1)}}</span><small>Answered</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label skipped pull-right">{{getNotAnsweredCount($index + 1)}}</span><small>Not answered</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label bookmarked pull-right">{{getBookmarkedCount($index + 1)}}</span><small>Marked for Review</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label unattempted-que pull-right">{{test.sections[$index].questions.length - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1)}}</span><small>Not visited</small></h4></div></li></ul></li></ul><button ng-show="test.sections.length > 6" ng-click="scrollSectionRight()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-right" data-scroll="left"><svg width="17" height="17" viewBox="0 0 17 17"><path fill="#86A1AE" d="M5.104 12.604l4.198-4.208L5.104 4.19l1.292-1.293 5.5 5.5-5.5 5.5z" fill-rule="evenodd"></path></svg></button></ng-container></div><div class="sl-inner" ng-if="isASMInterface"><button ng-show="test.sections.length > 6" ng-click="scrollSectionLeft()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-left" data-scroll="left"><svg viewBox="0 0 17 17" height="32" width="32" class="icon"><path fill="currentColor" d="M8.5 1C4.4 1 1 4.4 1 8.5S4.4 16 8.5 16 16 12.6 16 8.5 12.6 1 8.5 1zm3.7 8.1H7l2.3 2.3-.8.8-3.7-3.7 3.7-3.7.8.8L7 7.9h5.1v1.2z"></path></svg></button> <button ng-show="test.sections.length > 6" ng-click="scrollSectionRight()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-right" data-scroll="left"><svg viewBox="0 0 17 17" height="32" width="32" class="icon"><path fill="currentColor" d="M8.5 1C4.4 1 1 4.4 1 8.5S4.4 16 8.5 16 16 12.6 16 8.5 12.6 1 8.5 1zm0 11.2l-.8-.8L10 9.1H4.9V7.9H10L7.7 5.6l.8-.8 3.7 3.7-3.7 3.7z"></path></svg></button><ul id="sectionNavTabs" style="overflow-x: scroll !important;" tb-auto-scroll class="nav nav-pills sections-list"><li class="dropdown" ng-repeat="section in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo -1 == $index, \'disabled\': !isActiveSection($index) || isPartSectionDisabled($index), \'section-completed\': currentQuestion.sSNo -1 > $index}" ng-click="jumpToLastViewedQuestionInSection($index + 1)" ng-if="!section.isBreak"><a data-target="#section{{$index}}">{{section.title || "Overall"}} <span class="info-icon">!</span></a><ul id="section{{$index}}Summary" ng-if="!section.isNonQuestionSection" class="dropdown-menu sections-list-details" role="menu" style="width:250px; position: relative; top: -5px;"><li><span style="background-color: #25cd71;">{{getAnsweredCount($index + 1)}}</span> Answered</li><li><span style="background-color: #e4174f;">{{getNotAnsweredCountForASM($index + 1)}}</span>Not answered</li><li><span style="background-color: #86a1ae;">{{getBookmarkedCount($index + 1)}}</span>Marked for Review</li><li><span style="background-color: #4788f4;">{{getBookmarkedAndAttempted($index + 1)}}</span>Answered & Marked for Review</li></ul></li></ul></div></div><div class="test-sections-tab" ng-if="isSubSectionPresentForIndex(currentQuestion.sSNo - 1) && !isSectionalSubmitWithNonSharedTimeFlag"><div class="test-sections-tab__inner"><div class="btn btn-tab" ng-click="subSectionClick(item)" ng-class="{\'active\': item.SSSNo == isActiveSubSection}" ng-repeat="item in test.sections[currentQuestion.sSNo - 1].subsections track by $index" title="{{item.title}}"><span>{{item.title}}</span></div></div></div><div class="mob-question-holder" style="top: 0;" ng-class="{\'holder-section\': isSubSectionPresentForIndex(currentQuestion.sSNo - 1)}" ng-if="!isSscNewInterface || !test.containOptionalSections || !hasMultipleSubsections(currentQuestion.sSNo) || ( (selectedSubsections && selectedSubsections[currentQuestion.sSNo]) || (focusedSubsections && focusedSubsections[currentQuestion.sSNo]) )"><div ng-if="isSscNewInterfaceInstructionEnabled && isSscNewInterface" class="newInterface-ssc-instructions slim-scrollbar"><h3>Instructions</h3><img src="/assets/img/ui-kit/new-ssc-instruction.webp" alt="new-ssc-instruction"> <button class="instruction-back-button" ng-click="handleCloseInstruction()">Back</button></div><div style="display: flex; align-items: center; padding: 2px 16px 0;"><div style="display: flex; gap:16px; align-items: center; width: 100%; margin-top: 12px;" ng-style="{\'display\': isMobile ? \'none\' : \'flex\'}"><span ng-mouseover="handleSybbols(true)" ng-mouseleave="handleSybbols(false)" ng-click="handleSybbols(true)" class="instruction-symbols" style="color:#2596be; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;">SYMBOLS</span><drag-calculator ng-if="isShowCalculator && isSscNewInterface" for-new-ssc-interface="true" heading-styles="calcHeadingStylesForNewSscInterface" config="{btnClasses: \'btn-link\'}" is-basic-calc="isBasicCalculator" is-acca-type="false"></drag-calculator><span style="color:#ec6249; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;" ng-click="getDynamicInstructions()">INSTRUCTIONS</span> <span style="color:#99301d; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;" ng-mouseover="handleOverallTestSummaryTooltip(true)" ng-mouseleave="handleOverallTestSummaryTooltip(false)" ng-click="handleOverallTestSummaryTooltip(true)">OVERALL TEST SUMMARY</span> <span style="color:#e81e1e; font-size: 12px; font-weight: 600; flex-grow: 1; text-align: center;"></span><p class="question-header-tittle" style="position: relative; margin-bottom: 0; z-index: 42; width: 240px; text-align: right; font-weight: 700;" ng-style="{\'display\': !isTestScreenExtended ? \'none\' : \'visible\'}">Total Questions Answered: <span style="background-color: #FFFF00; color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsAnswered()}}</span></p><span ng-if="showTooltip" class="newInterfaceSymbols"><span ng-click="handleSybbols(false)" class="newInterfaceSymbolsClose">X</span></span> <span ng-if="showOverallTestSummaryTooltip" class="newInterfaceOverallTestSummary"><span ng-click="handleOverallTestSummaryTooltip(false)" class="newInterfaceSymbolsClose">X</span><div class="content"><p style="font-size: 13px; font-weight: 700; background-color:#d6ccb6; padding: 2px; margin: 0px 0px 10px 0px;">Test Summary</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have answered <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsAnswered() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have not answered <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsNotAnswered() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have marked for review <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsBookmarked() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p></div></span></div></div><div id="mainBox" ng-class="{\'newInterface-mainbox\': isSscNewInterfaceInstructionEnabled}"><div class="qpip-inner" id="questions" ng-if="isCurTab(\'question\')"><div class="header ssc-new-header" style="border-bottom: none;"><div class="d-flex new-ssc-mobile-sub-header" style="height: 100%; margin-top: 12px;"><div class="newInterface-sections-list-v2" ng-style="{\'display\': isMobile ? \'none\' : \'visible\'}"><div class="q-possible-states newInterface-sections slim-scrollbar"><span ng-repeat="section in test.sections track by $index" ng-class="{\'section-box-current\' : currentQuestion.sSNo -1 == $index, \'disabled\': isPartSectionDisabled($index)}" class="section-box" ng-click="jumpToLastViewedQuestionInSection($index + 1)">{{ displaSectionBox($index) }}</span></div></div><div class="newInterface-action-button-container" style="position: relative; top: -2.5px;" ng-style="{\'margin-right\': isTestScreenExtended ? \'300px\' : \'0\'}"><div class="newInterface-action-button" style="gap: 12px; height: 23.5px; margin-bottom: 12px;"><button type="button" style="width: fit-content; background-color: #2E66CC; color: #ffffff; display: flex; align-items: center; justify-content: center;" class="btn btn-info-test mar-t0 header-action-button" ng-show="shouldShowPreviousButton()" ng-click="goToPreviousQuestionWithoutSaving()">Previous</button><button type="button" style="width: fit-content; background-color: #2E66CC; color: #ffffff; display: flex; align-items: center; justify-content: center;" class="btn btn-info-test mar-t0 header-action-button" ng-class="{\'newSscMarked\': sscNewMarkReview() }" ng-show="!hasTypingTest && !isNoShowSection() && !isASMInterface" ng-click="toggleBookmark(currentQuestion.sSNo, currentQuestion.qSNo)" ng-disabled="areAnswersDisabled() || (isSscNewInterface && isSubsectionMismatch())">{{sscNewMarkReview() ? \'Unmark Review\' : \'Mark for Review\'}}</button> <button style="background-color: #2E66CC; display: flex; align-items: center; justify-content: center;" type="button" class="btn btn-theme header-action-button pull-right mar-t0" ng-show="!hasTypingTest && !isSpeedComprehension() && !isNoShowSection() && !isInEndofSection()" ng-if="!showLastQuestionHoverText" ng-click="saveAndNextBtnPressed(false, \'\', true)" ng-disabled="areAnswersDisabled() || (isSscNewInterface && isSubsectionMismatch())">{{\'Save\' }} <span style="display: inline-block; margin-left: 4px;">{{" "}} & Next</span></button> <button ng-if="!shouldHideSubmitSectionButton()" type="button" style="width: fit-content; background-color: #2E66CC; display: flex; align-items: center; justify-content: center;" class="btn btn-theme header-action-button btn-block for-all-exams" ng-click="sectionalSubmitBtnClicked()">Submit Section</button> <button ng-if="shouldShowSubmitSubsectionButton()" ng-disabled="isSubsectionProgressionSyncInFlight()" type="button" style="width: fit-content; background-color: #2E66CC; display: flex; align-items: center; justify-content: center;" class="btn btn-theme header-action-button btn-block for-all-exams" ng-click="subsectionalSubmitBtnClicked()">Submit Sub-section</button> <button type="button" style="width: fit-content; background-color: #2E66CC; display: flex; align-items: center; justify-content: center;" class="btn btn-theme header-action-button btn-block for-all-exams" ng-click="submitBtnPressed()">{{\'Submit Test\'}}</button><div ng-if="showLastQuestionHoverText && isSscNewInterface" style="margin: 0; font-size: 10px; font-weight: 600; color: #00f; position: relative; bottom: 2px;"><span ng-if="!isCurrentSectionNumber(\'last\')">This is the last question of this part.<br><span ng-if="!(!test.isSectionalSubmit && !test.sectionTimeSharedFlag)">Click <span ng-if="test.sections && test.sections.length > 0 && (!$scope.test.isSectionalSubmit || ($scope.test.isSectionalSubmit && $scope.currentQuestion.sSNo !== $scope.test.sections.length))">\'Next Parts <span ng-repeat="section in test.sections track by $index">{{displayNextParts($index)}}</span>\' to proceed</span> <span ng-if="test.sections && test.sections.length > 0 && test.isSectionalSubmit">on \'Submit <span ng-if="($scope.currentQuestion.sSNo === $scope.test.sections.length)">Test\' to submit the test</span><span ng-if="($scope.currentQuestion.sSNo !== $scope.test.sections.length)">Section\' to access next section</span></span></span> <span ng-if="!test.isSectionalSubmit && !test.sectionTimeSharedFlag">Please wait for the timer to get over</span></span> <span ng-if="isCurrentSectionNumber(\'last\')"><span>Reached last question of the exam.<br>You may revise.</span></span></div></div></div></div><div class="hidden-xs text-size-resize show-on-railway">{{\'Text Size\' }} <button type="button" class="btn js-font-size fs-decrease"><small>A<sup>-</sup></small></button> <button type="button" class="btn js-font-size fs-increase">A<sup>+</sup></button></div></div><div class="header" style="border-bottom: none;"><div class="d-flex items-center justify-between language-sub-header"><div ng-if="!isASMInterface" style="flex-shrink: 0;"><p style="display: flex; gap:16px; position: relative; left: 12px;"><span style="font-size: 14px; font-weight: 600;">Question No. {{currentQuestion.qSNo}}</span></p></div></div></div><div id="question-box" ng-style="{\'top\': isMobile ? \'128px\' : \'158px\'}" style="overflow: auto !important; padding: 0 26px;" ng-if="!hasTypingTest && !test.sections[currentQuestion.sSNo-1].isNonQuestionSection" class="slim-scrollbar body detailed-question js-detailed-question" ng-class="{\'asm-scroll-view\': isASMInterface}"><div class="slim-scrollbar" ng-class="{\'aei-comprehension\': !isSpeedComprehension(), \'mar-l32\': isSpeedComprehension(), \'asm-scroll-view\' : isASMInterface}" ng-style="getComprehensionStyle(true)" ng-if="hasComprehension()"><div class="mar-b16"><u class="font-weight-semibold"><i>{{\'Comprehension\' }}:</i></u><span class="d-inline-block mar-l16" ng-if="!isSpeedComprehension()">(Que No. {{(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno + 1) + " - " + (test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1)}})</span></div><div class="qns-view-box" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div class="qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist()" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name)"></div><div class="mar-t32 qns-view-box" ng-if="injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><div class="mar-t32 qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist() && injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name)"></div></div><div ng-if="hasSkipOptionSupport && parentIsSkipAlert" style="background-color: #FFE3DC;text-align: center;" class="pad-8"><span>Extra {{skipDurationValue}} Mins allocated for attempting Skipped Qs has been started</span></div><div class="que-ans-box slim-scrollbar ssc-zoom" ng-style="getComprehensionStyle(false); {\'transform\': \'scale(\' + sscZoomScale + \')\'}" ng-class="{\'asm-scroll-view\': isASMInterface, \'new-ssc-interface-container\': isSscNewInterface}" style="border: 1px solid #eeeeee; border-bottom: none; height: 100%;"><div class="d-flex" style="width: 100%; justify-content: flex-end; margin: -12px 0 4px 0;"><div><div class="pull-left tp-language-selector" ng-if="!hasTypingTest && languages.length && languages.length >= 1"><div class="form-inline d-flex"><div class="form-group" ng-show="languages.length && languages.length > 1 || !checkSdkModeActive" ng-class="{\'d-none\' : isASMInterface}"><label for="language" class="font-size-base-1 control-label hidden-xs" style="margin-right: 4px !important;">Select Language</label><select ng-disabled="languages.length == 1" style="color:#86a1ae" id="language" ng-if="!(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed)" ng-model="$root.lang" ng-change="setLanguagesPrompt(lang)" ng-options="lang.prompt for lang in languages"></select><select ng-disabled="languages.length == 1" style="color:#86a1ae" id="language" ng-if="isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed" ng-model="$root.defLang" ng-change="setLanguagesPrompt(lang)" ng-options="lang.prompt for lang in languages"></select></div><div ng-if="isASMInterface && hasInstructions" class="asm-ins-btn"><button type="button" class="btn btn-default mar-t0 mar-l16" ng-click="showInstructionsModal(false)">{{\'View Instructions\' }}</button> <button type="button" class="btn btn-default mar-t0" ng-click="showInstructionsModal(true)">{{\'Useful Data\' }}</button></div></div></div><report-cta ng-if="!isASMInterface" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" options="Wrong Question,Formatting Issue,Wrong Translation,Others" btn-type module-Type="{{moduleType}}" class="report-this-question"></report-cta></div></div><div ng-if="!isSpeedComprehension() && !isFixedComprehension()" style="border: 1px solid #eeeeee !important; padding: 8px 0 0 0;"><b ng-show="hasComprehension()"><u><i>Question:</i></u></b><div class="qns-view-box" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)" style="padding-left: 16px; margin: 0px; border-bottom: 1px solid #eeeeee; padding-bottom: 15px;"></div><ul ng-if="isKvsTestInterfaceUsed" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index" style="border-bottom: 1px solid #eeeeee !important;"><label class="lable-opt label-kvs-q-option" style="padding-left: 16px !important;">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(option.value)"></div></label></li></ul><div class="qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist()" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name)"></div><ul ng-if="isKvsTestInterfaceUsed && doesSecLangExist()" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index" style="border-bottom: 1px solid #eeeeee;"><label class="lable-opt label-kvs-q-option" style="padding-left: 16px !important;">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(getSecondaryOptions()[$index].value || \'(Translation Not Available)\')"></div></label></li></ul><div class="mar-t24 qns-view-box" ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><ul ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)) && isKvsTestInterfaceUsed" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index" style="border-bottom: 1px solid #eeeeee;"><label class="lable-opt" style="padding-left: 16px !important;">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(option.value)"></div></label></li></ul><div class="mar-t24 qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist() && injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name)"></div><ul ng-if="isKvsTestInterfaceUsed && doesSecLangExist() && injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index" style="border-bottom: 1px solid #eeeeee;"><label class="lable-opt" style="padding-left: 16px !important;"><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))">{{$index+1}}.<div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><p class="text-gray-4" ng-show="isMAMCQ()"><i>*This question may have multiple correct answers.</i></p><ul ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices q-multiple-choices-new-ssc" style="margin:0px !important"><li ng-repeat="option in getOptions() track by $index" class="new-ssc-question-option-box" style="display: flex; border-bottom: 1px solid #eeeeee; cursor: pointer;"><input style="margin:16px !important; cursor: pointer;" class="check-box-input" type="radio" name="mcqOption" ng-if="!isMAMCQ()" ng-checked="!(isSscNewInterface && isSubsectionMismatch()) && markOptioncheckingInMCQ(option)" ng-click="(isSscNewInterface && isSubsectionMismatch()) ? showSubsectionMismatchTooltip($event) : setOption(option,null,$event)"> <input style="margin:16px !important; cursor: pointer;" class="check-box-input" name="mamcqOption" ng-checked="!(isSscNewInterface && isSubsectionMismatch()) && isOptionSelected(option.prompt)" ng-if="isMAMCQ()" ng-click="(isSscNewInterface && isSubsectionMismatch()) ? showSubsectionMismatchTooltip($event) : setOption(option)" type="checkbox" ng-disabled="areAnswersDisabled()"><div style="border-left: 1px solid #eeeeee; height: fit-content; padding: 16px;" class="qns-view-box" ng-if="!isKvsTestInterfaceUsed" ng-bind-html="parseDesc(option.value)"></div><div class="qns-view-box" ng-if="isKvsTestInterfaceUsed">{{$index+1}}</div><div class="qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions()[$index].value || \'(Translation Not Available)\')"></div><div class="mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></li></ul><div ng-if="test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions"><div><textarea spellcheck="false" id="answer" class="slim-scrollbar descriptive-ans" ng-model="$parent.typingTestAnswer.value" ng-keyup="getTypingTestAnswer($event)" ng-keydown="getTypingTestAnswer($event)" name="answer" type="text" placeholder="*Start Typing Here*">\n                                        </textarea></div><div class="des-ans-info"><div ng-if="typingTestAnswer.value" id="input-info-char">Characters - <span ng-bind="countInfoCharacters(typingTestAnswer.value)"></span></div><div ng-if="typingTestAnswer.value" id="input-info-words">Words - <span ng-bind="countInfoWords(typingTestAnswer.value)"></span></div></div></div></div><div ng-if="isFixedComprehension()"><div><ul class="q-multiple-choices"><li ng-repeat="question in test.sections[currentQuestion.sSNo - 1].questions | slice:(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno): test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1"><div class="row mar-r16 mar-l16 mar-t16 mar-b16" ng-if="isASMInterface"><div class="row pad-b16" ng-if="isSpatialSection(currentQuestion.sSNo) && isFirstInPage(question.qSNo,10)"><span class="font-weight-bold col-sm-6" style="width:46%">The shortest route from:</span> <span class="font-weight-bold">Passes Building:</span></div><span class="font-weight-bold">Question {{question.qSNo}} &nbsp;</span><div class="report-group font-weight-normal"><button class="mark-inline mar-r16" ng-click="markQuestionClicked(question.sSNo, question.qSNo)"><svg viewBox="0 0 20 20" ng-if="!studentResponses[question._id] || !studentResponses[question._id].isBookmarked" class="mar-r8" height="20" width="20"><path d="M17.144 7.438l-4.316-.627L10.897 2.9c-.338-.683-1.456-.683-1.794 0l-1.93 3.911-4.317.627a1.002 1.002 0 0 0-.554 1.707l3.124 3.044-.737 4.299a1 1 0 0 0 1.451 1.054L10 15.513l3.861 2.03c.728.381 1.591-.234 1.451-1.054l-.737-4.299 3.124-3.044a1.003 1.003 0 0 0-.555-1.708z" stroke="currentColor" stroke-width="1.4" fill="none"></path></svg><svg width="18" height="18" viewBox="0 0 28 28" class="mar-r8" ng-if="studentResponses[question._id] && studentResponses[question._id].isBookmarked"><desc>Created with Sketch.</desc><g id="Assets" stroke="none" stroke-width="1" fill="#ffd13c" fill-rule="evenodd"><g id="Artboard" transform="translate(-41.000000, -70.000000)" fill="#ffd13c"><g id="Star-Fill" transform="translate(41.000000, 70.000000)"><path d="M25.8865204,8.85475156 L19.3033203,7.88652393 L16.2493482,1.8204 C15.9444463,1.20276031 14.9689552,0.71622004 14.0002485,0.714107722 C13.0248932,0.711980905 12.056291,1.19852117 11.7492964,1.8204 L8.69682031,7.88652393 L2.11352693,8.85475156 C1.3321742,8.96884037 0.421611845,9.8529574 0.166820735,10.8553021 C-0.0606917525,11.7503331 0.180737583,12.7478875 0.687999767,13.244417 L5.45435937,17.7909531 L4.35038281,24.4704839 C4.09874488,25.9477432 5.93726562,27.6891481 7.52289051,27.2864692 L14.0002485,23.9952539 L19.6978701,27 C20.3632611,27.3490933 21.5093231,27.5433193 22.3539409,27 C23.1822462,26.4671741 23.7169868,25.2073026 23.5914983,24.4704839 L22.4922734,17.9726296 L27.2143939,13.244417 C27.7248768,12.7430294 27.9868451,11.7563053 27.7494688,10.8553021 C27.4876478,9.86151503 26.6622593,8.96802067 25.8865204,8.85475156 Z" id="Shape"></path></g></g></g></svg>Mark Question</button><report-cta ng-if="!test.sections[question.sSNo -1].isNonQuestionSection" qid="{{getTQDID(question.sSNo, question.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" options="Wrong Question,Formatting Issue,Wrong Translation,Others" btn-type class="report-this-question tb-top"></report-cta></div></div><div class="row" style="padding-right: 36px; position: relative" ng-class="{\'speed-comprehension--ques\' : isASMInterface}"><div ng-class="{\'col-sm-6\': !test.sections[currentQuestion.sSNo - 1].asmInformationOrdering}"><span class="mar-t8 mar-r16 pull-left font-weight-bold" ng-if="!isASMInterface">{{question.qSNo}}. &nbsp;</span><div class="mar-t8 fixed-comp-question qns-view-box" ng-bind-html="getQuestionDesc(question.sSNo, question.qSNo, $root.lang.name)"></div><div class="mar-t8 fixed-comp-question qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="getQuestionDesc(question.sSNo, question.qSNo, $root.secLang.name)"></div></div><ul ng-class="{\'mar-t32 mar-l32\' : test.sections[currentQuestion.sSNo - 1].asmInformationOrdering, \'fixed-comp-option pull-right\' : !test.sections[currentQuestion.sSNo - 1].asmInformationOrdering}" class="single-page-comp-option col-xs-12 col-sm-6 hide-on-railway"><li ng-repeat="option in getOptions(question) track by $index"><label ng-class="{\'font-weight-bold\': isASMInterface}"><input type="radio" name="option-{{question.qSNo}}" ng-checked="!(isSscNewInterface && isSubsectionMismatch()) && (question.selectedOption.value == option.prompt)" ng-click="(isSscNewInterface && isSubsectionMismatch()) ? showSubsectionMismatchTooltip($event) : setOption(option, question,$event)"><div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(option.value)"></div><div class="mar-l24 qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><ul class="single-page-comp-option fixed-comp-option col-xs-12 col-sm-6 pull-right option-content-box counter-reset show-on-railway"><li ng-repeat="option in getOptions(question) track by $index" class="counter-list"><div class="qns-view-box" ng-bind-html="parseDesc(option.value)"></div><div class="qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></li></ul></div></li></ul></div></div><div ng-if="isSpeedComprehension()"><ul class="q-multiple-choices"><li ng-repeat="question in test.sections[currentQuestion.sSNo - 1].questions" style="min-width: 1200px;"><div class="row" ng-class="{\'border-bottom-dotted\': !isASMInterface, \'mar-b16\': isASMInterface}"><div class="col-xs-8 row single-page-comp-question"><div class="col-xs-10"><span class="font-weight-bold">Question No : {{question.qSNo}}</span><div class="report-group"><button class="mark-inline mar-r16" ng-click="markQuestionClicked(question.sSNo, question.qSNo)"><svg viewBox="0 0 20 20" ng-if="!studentResponses[question._id] || !studentResponses[question._id].isBookmarked" class="mar-r8" height="20" width="20"><path d="M17.144 7.438l-4.316-.627L10.897 2.9c-.338-.683-1.456-.683-1.794 0l-1.93 3.911-4.317.627a1.002 1.002 0 0 0-.554 1.707l3.124 3.044-.737 4.299a1 1 0 0 0 1.451 1.054L10 15.513l3.861 2.03c.728.381 1.591-.234 1.451-1.054l-.737-4.299 3.124-3.044a1.003 1.003 0 0 0-.555-1.708z" stroke="currentColor" stroke-width="1.4" fill="none"></path></svg><svg width="18" height="18" viewBox="0 0 28 28" class="mar-r8" ng-if="studentResponses[question._id] && studentResponses[question._id].isBookmarked"><desc>Created with Sketch.</desc><g id="Assets" stroke="none" stroke-width="1" fill="#ffd13c" fill-rule="evenodd"><g id="Artboard" transform="translate(-41.000000, -70.000000)" fill="#ffd13c"><g id="Star-Fill" transform="translate(41.000000, 70.000000)"><path d="M25.8865204,8.85475156 L19.3033203,7.88652393 L16.2493482,1.8204 C15.9444463,1.20276031 14.9689552,0.71622004 14.0002485,0.714107722 C13.0248932,0.711980905 12.056291,1.19852117 11.7492964,1.8204 L8.69682031,7.88652393 L2.11352693,8.85475156 C1.3321742,8.96884037 0.421611845,9.8529574 0.166820735,10.8553021 C-0.0606917525,11.7503331 0.180737583,12.7478875 0.687999767,13.244417 L5.45435937,17.7909531 L4.35038281,24.4704839 C4.09874488,25.9477432 5.93726562,27.6891481 7.52289051,27.2864692 L14.0002485,23.9952539 L19.6978701,27 C20.3632611,27.3490933 21.5093231,27.5433193 22.3539409,27 C23.1822462,26.4671741 23.7169868,25.2073026 23.5914983,24.4704839 L22.4922734,17.9726296 L27.2143939,13.244417 C27.7248768,12.7430294 27.9868451,11.7563053 27.7494688,10.8553021 C27.4876478,9.86151503 26.6622593,8.96802067 25.8865204,8.85475156 Z" id="Shape"></path></g></g></g></svg>Mark Question</button><report-cta ng-if="!test.sections[question.sSNo -1].isNonQuestionSection" qid="{{getTQDID(question.sSNo, question.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" options="Wrong Question,Formatting Issue,Wrong Translation,Others" btn-type class="report-this-question tb-top"></report-cta></div></div><div class="col-xs-10 mar-t8 qns-view-box" ng-bind-html="getQuestionDesc(question.sSNo, question.qSNo, $root.lang.name)"></div><div class="col-xs-10 mar-t8 qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="getQuestionDesc(question.sSNo, question.qSNo, $root.secLang.name)"></div></div><strong class="pad-h12" ng-if="isASMInterface && !isMobile">Your answer:</strong><ul class="single-page-comp-option col-xs-12 col-sm-2 pull-right" ng-if="isMobile"><li ng-repeat="option in getOptions(question) track by $index"><label><input type="radio" name="option-{{question.qSNo}}" ng-checked="question.selectedOption.value == option.prompt" ng-click="setOption(option, question,$event)"><div class="qns-view-box mar-l24" ng-class="{\'font-weight-bold\': isASMInterface}" ng-bind-html="parseDesc(option.value)"></div><div class="mar-l24 qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><ul class="single-page-comp-option col-xs-12 col-sm-4 pull-right option-content-box counter-reset" ng-class="{\'asm-singlepage--options pad-r52\' : isASMInterface}" ng-if="!isMobile"><li ng-repeat="option in getOptions(question) track by $index" class="counter-list"><label><input type="radio" name="option-{{question.qSNo}}" ng-checked="question.selectedOption.value == option.prompt" ng-click="setOption(option, question,$event)"><div ng-bind-html="parseDesc(option.value)"></div><div ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions(question)[$index].value || \'(Translation Not Available)\')"></div><div ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul></div></li></ul></div><div ng-show="isNumerical()" class="mar-t16 col-md-3 col-xs-6" ng-controller="KeypadController"><div class="alert bg-gray-1"><span ng-show="getNumInput() === \'None\'">Enter your answer</span> <span class="font-weight-semibold" ng-show="getNumInput() !== \'None\'">{{getNumInput()}}</span></div><div class="row"><div class="col-xs-4 pad-h8" ng-repeat="i in range" ng-click="onKeyPress(i)"><button type="button" class="btn btn-theme" style="min-width:60px; margin:3px;">{{i}}</button></div></div></div></div></div><div id="question-box" ng-if="hasTypingTest" class="typing-question body slim-scrollbar"><div class="typing-question__box mar-t12 col-lg-offset-2"><div><label for="question">Text</label><div><div class="question slim-scrollbar" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div></div></div><div class="mar-t24"><div><textarea spellcheck="false" id="answer" class="slim-scrollbar" ng-model="$parent.typingTestAnswer.value" ng-keyup="getTypingTestAnswer($event)" ng-keydown="getTypingTestAnswer($event)" name="answer" type="text" placeholder="*Start Typing Here*"></textarea></div></div><div class="input-info"><div ng-if="typingTestAnswer.value" id="input-info-char">Characters - <span ng-bind="countInfoCharacters(typingTestAnswer.value)"></span></div><div ng-if="typingTestAnswer.value" id="input-info-words">Words - <span ng-bind="countInfoWords(typingTestAnswer.value)"></span></div></div></div></div><div id="question-box" ng-if="!hasTypingTest && test.sections[currentQuestion.sSNo-1].isInstruction" class="body detailed-question js-detailed-question" ng-class="{\'asm-scroll-view\' : isASMInterface}"><div class="que-ans-box qns-view-box" ng-bind-html="parseHtml(test.sections[currentQuestion.sSNo-1].text)"></div></div><div class="footer-newsscInterface mob-button-footer on-test-page" ng-if="isSscNewInterface"><div class="footer-inner hide-on-railway" ng-if="!test.sections[currentQuestion.sSNo-1].isNonQuestionSection"><button type="button" class="btn new-ssc-footer-action-btn btn-info-test mar-t0" ng-class="{\'newSscMarked\': sscNewMarkReview()}" ng-show="!hasTypingTest && !isNoShowSection() && !isASMInterface" ng-click="toggleBookmark(currentQuestion.sSNo, currentQuestion.qSNo)" ng-disabled="areAnswersDisabled() || (isSscNewInterface && isSubsectionMismatch())">{{ sscNewMarkReview() ? \'Unmark Review\' : \'Mark for Review\' }}</button> <button type="button" class="btn new-ssc-footer-action-btn btn-gray-1 mar-t0 mar-l16" ng-if="isSectionalSubmitWithNonSharedTimeFlag && !shouldHideSubmitSectionButton()" ng-click="sectionalSubmitBtnClicked()">Submit Section</button> <button type="button" class="btn new-ssc-footer-action-btn btn-gray-1 mar-t0 mar-l16" ng-if="shouldShowSubmitSubsectionButton()" ng-disabled="isSubsectionProgressionSyncInFlight()" ng-click="subsectionalSubmitBtnClicked()">Submit Sub-section</button> <button type="button" class="btn btn-gray-1 pull-right mar-t0 mar-l16" ng-if="isASMInterface && test.isSectionalSubmit" ng-click="sectionalSubmitBtnClicked()">{{\'Submit Sections\' }}</button> <button type="button" class="btn btn-theme pull-right mar-t0 mar-l16" ng-if="isASMInterface && !isFixedComprehension()">{{\'Save\' }}</button> <button type="button" class="btn new-ssc-footer-action-btn btn-theme pull-right mar-t0" ng-show="!hasTypingTest && !isSpeedComprehension() && !isNoShowSection() && !isInEndofSection()" ng-click="saveAndNextBtnPressed(false, \'\', true)" ng-disabled="areAnswersDisabled() || (isSscNewInterface && isSubsectionMismatch())">{{\'Save\' }} <span>& Next</span></button></div></div></div><div class="qpip-inner" id="questionPaper" ng-if="isCurTab(\'qpaper\')"><div class="header"><h4 class="text-center pad-t12">Question Paper</h4></div><div class="body slim-scrollbar"><div class="body-inner"><div ng-repeat="section in test.sections track by $index" ng-show="isActiveSection($index)"><h4>Section: {{section.title || "Overall"}}</h4><ul class="list-group"><li class="list-group-item" ng-repeat="question in section.questions track by $index">Q. {{$index + 1}}) <span ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, $root.lang.name)"></span><hr></li><li class="list-group-item" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-repeat="question in section.questions track by $index">Q. {{$index + 1}}) <span ng-bind-html="getQuestionDesc($parent.$index + 1, $index + 1, $root.secLang.name)"></span><hr></li></ul></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="instructions" ng-if="isCurTab(\'instructions\')"><div class="header"><h4 class="text-center pad-t12">Instructions</h4></div><div class="body"><div class="body-inner"><div ng-include="\'/livetest/views/partials/instructions.html\'"></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="profile" ng-if="isCurTab(\'profile\')"><div class="header"><h4 class="text-center pad-t12">Profile Details</h4></div><div class="body"><div class="body-inner"><div class="row"><div class="col-xs-12 col-md-6 col-md-offset-4"><div class="row"><div class="col-xs-12 col-sm-4"><b>User ID</b></div><div class="col-xs-12 col-sm-8">{{profile.userid}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Name</b></div><div class="col-xs-12 col-sm-8">{{profile.name}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Date of birth</b></div><div class="col-xs-12 col-sm-8">{{profile.dob}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Email ID</b></div><div class="col-xs-12 col-sm-8">{{profile.email}}</div></div><div class="row"><div class="col-xs-12 col-sm-4"><b>Contact</b></div><div class="col-xs-12 col-sm-8">{{profile.contact}}</div></div></div></div></div></div><div class="footer text-center"><button type="button" class="btn btn-info-test mar-t0" ng-click="setTab(\'question\')">Back</button></div></div><div class="qpip-inner" id="warning" ng-if="isCurTab(\'switchconfirmfinal\') || isCurTab(\'switchreset\') || isCurTab(\'resetconfirm\')"><ng-container ng-if="isCurTab(\'switchreset\') && (!test.containOptionalSections || !isSscNewInterface)"><div class="warning-container body" style="background: #ffffff;"><div class="warn__content"><h3 class="warn-header">Warning</h3><p class="warn-text"><span class="explain-text">You have chosen to change the optional section. You are required to reset the previously chosen optional sections by clicking on the corresponding checkbox in the table given below and then clicking on the <strong>RESET</strong> button. Please be aware that by resetting one of the previously chosen optional Sections, all the answers you have provided for questions in that Section will be <strong>DELETED. (If you choose to come back to this section later, you have to start answering this Section afresh.)</strong></span> <strong class="d-block">Are you sure that you want to reset an optional section now?</strong> <span class="hidden-xs">If <strong>YES</strong>, click the checkbox next to section you wish to reset and click on Reset button to reset that section.</span> <span class="visible-xs">If <strong>YES</strong>, click on Reset button to reset that section.</span></p></div><div class="action_content-web hidden-xs"><h4 class="font-weight-bold">Summary of Optional Section(s) :</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th translate>Optional Section Name</th><th translate>No. of Questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Answered & Marked for Review (will be considered for evaluation)</th><th ng-if="hasSkipOptionSupport" translate>No options selected</th><th translate>Reset</th></tr></thead><tbody><tr><td data-prompt="Section">{{selectedOptionalSectionName}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Answered & Marked for Review (will be considered for evaluation)">{{getBookmarkedAndAttemptedForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptional(selectedCurrentSummaryIndex)}}</td><td data-prompt="Reset" class="checkbox-gd"><span class="table-checkbox checkbox-gd_border" ng-class="{\'active\':isCheckedForOptionalSectionConfirmation}" ng-click="isCheckedForOptionalSection()"></span></td></tr></tbody></table><p class="warn-text" ng-if="isCheckBoxNotCheckedForOptionalSection"><strong>Please select the section(s) from the following list to reset :</strong></p></div><div class="action-cta"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div><div class="action_content-mweb visible-xs"><h5 class="text-center">Summary of Optional Section(s) :</h5><div class="content-summary"><div class="summary-col"><span>Optional Section Name</span> <span class="right">{{selectedOptionalSectionName}}</span></div><div class="summary-col"><span>No. of Questions</span> <span class="right">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Answered</span> <span class="right">{{getAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Not Answered</span> <span class="right">{{getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Marked for Review</span> <span class="right">{{getBookmarkedCountForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Answered & Marked for Review <span class="font-size-small d-block text-gray-11">(will be considered for evaluation)</span></span> <span class="right">{{getBookmarkedAndAttemptedForOptional(selectedCurrentSummaryIndex)}}</span></div><div class="summary-col"><span>Not Visited</span> <span class="right">{{getQuestionsCountForOptional(selectedCurrentSummaryIndex) - getAnsweredCountForOptional(selectedCurrentSummaryIndex) - getNotAnsweredCountForOptional(selectedCurrentSummaryIndex)}}</span></div></div></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'switchreset\') && test.containOptionalSections && isSscNewInterface"><div class="warning-container body" style="background: #ffffff;"><div class="warn__content"><h3 class="warn-header">Warning</h3><p class="warn-text"><span class="explain-text">You have chosen to change the optional subsection. You are required to reset the previously chosen optional subsection by clicking on the corresponding checkbox in the table given below and then clicking on the <strong>RESET</strong> button. Please be aware that by resetting one of the previously chosen optional subsections, all the answers you have provided for questions in that subsection will be <strong>DELETED. (If you choose to come back to this subsection later, you have to start answering this subsection afresh.)</strong></span> <strong class="d-block">Are you sure that you want to reset an optional subsection now?</strong> <span class="hidden-xs">If <strong>YES</strong>, click the checkbox next to subsection you wish to reset and click on Reset button to reset that subsection.</span> <span class="visible-xs">If <strong>YES</strong>, click on Reset button to reset that subsection.</span></p></div><div class="action_content-web hidden-xs"><h4 class="font-weight-bold">Summary of Optional Subsection(s) :</h4><div class="table-responsive"><table class="table table-bordered"><thead><tr><th translate>Optional Subsection Name</th><th translate>No. of Questions</th><th translate>Answered</th><th translate>Not Answered</th><th translate>Marked for Review</th><th translate>Answered & Marked for Review (will be considered for evaluation)</th><th ng-if="hasSkipOptionSupport" translate>No options selected</th><th translate>Reset</th></tr></thead><tbody><tr><td data-prompt="Section">{{selectedOptionalSectionName}}</td><td data-prompt="No. of questions">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Answered">{{getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Not Answered">{{getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Marked for Review">{{getBookmarkedCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Answered & Marked for Review (will be considered for evaluation)">{{getBookmarkedAndAttemptedForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="No Options Selected" ng-if="hasSkipOptionSupport">{{getNoOptionMarksCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</td><td data-prompt="Reset" class="checkbox-gd"><span class="table-checkbox checkbox-gd_border" ng-class="{\'active\':isCheckedForOptionalSectionConfirmation}" ng-click="isCheckedForOptionalSection()"></span></td></tr></tbody></table><p class="warn-text" ng-if="isCheckBoxNotCheckedForOptionalSection"><strong>Please select the subsection(s) from the following list to reset :</strong></p></div><div class="action-cta"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div><div class="action_content-mweb visible-xs"><h5 class="text-center">Summary of Optional Subsection(s) :</h5><div class="content-summary"><div class="summary-col"><span>Optional Subsection Name</span> <span class="right">{{selectedOptionalSectionName}}</span></div><div class="summary-col"><span>No. of Questions</span> <span class="right">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Answered</span> <span class="right">{{getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Not Answered</span> <span class="right">{{getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Marked for Review</span> <span class="right">{{getBookmarkedCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Answered & Marked for Review <span class="font-size-small d-block text-gray-11">(will be considered for evaluation)</span></span> <span class="right">{{getBookmarkedAndAttemptedForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div><div class="summary-col"><span>Not Visited</span> <span class="right">{{getQuestionsCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo) - getAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo) - getNotAnsweredCountForOptionalByIds(warningSummarySSNo, warningSummarySSSNo)}}</span></div></div></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="moveToFinalConfirmation()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'switchconfirmfinal\')"><div class="warning-container"><div class="warn__content"><h4 class="warn-header">ALERT</h4><p class="text-gray-base">Upon resetting, all the responses provided by you to all the questions in this section will be <strong>DELETED.<br>Are you sure, do you want to proceed further and reset {{selectedOptionalSectionName}} ?</strong></p></div><div class="action_content-web action-cta hidden-xs"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="handleWarningResetAction()">Reset</button></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">Back</button> <button type="button" class="btn btn-block btn-theme" ng-click="handleWarningResetAction()">Reset</button></div></div></ng-container><ng-container ng-if="isCurTab(\'resetconfirm\')"><div class="warning-container"><div class="warn__content"><h4 class="warn-header">ALERT</h4><p class="text-gray-5"><strong>Deselecting the checkbox will DELETE all the questions marked in this section. Are you sure, do you want to deselect this section ?</strong></p></div><div class="action_content-web action-cta hidden-xs"><button type="button" class="btn btn-xlg btn-outline-theme" ng-click="backToQuestion()">No</button> <button type="button" class="btn btn-xlg btn-theme" ng-click="deSelectionConfirm()">Yes</button></div></div><div class="footer action-cta-mweb visible-xs"><div class="action-btn"><button type="button" class="btn btn-block btn-outline-theme" ng-click="backToQuestion()">No</button> <button type="button" class="btn btn-block btn-theme" ng-click="deSelectionConfirm()">Yes</button></div></div></ng-container></div></div></div><div class="sidebar-open-bg"></div><button type="button" class="btn btn-theme new-ssc-mobile-action-btn navbar-toggle js-trigger-toggle-sidebar"><span class="tb-icon tb-menu"></span> <span class="tb-icon tb-clear"></span></button></div><span class="newInterface-extend" ng-if="isTestScreenExtended" ng-click="handleTestExtend(false)" style="position: absolute; right: 0; top: 100px; z-index: 1000; transform: rotate(90deg); width: 14px; border-left: 9px solid transparent;border-right: 11px solid transparent;border-top: 15px solid #2596be;"></span><div id="sidebar" class="newInterface-tp-right-box" ng-if="isSscNewInterface" ng-class="{\'newInterface-tp-right-box-extend\': isTestScreenExtended}"><button type="button" class="btn new-ssc-mobile-action-btn btn-theme navbar-toggle js-trigger-toggle-sidebar"><span class="tb-icon tb-menu"></span> <span class="tb-icon tb-clear"></span></button><div class="sidebar-content new-ssc-sidebaar" style="background-color: #ffffff; display: flex; flex-direction: column;"><div style="display: flex; gap:16px; align-items: center; width: 100%; padding: 0 12px;" ng-style="{\'display\': isMobile ? \'visible\' : \'none\'}"><span ng-mouseover="handleSybbols(true)" ng-mouseleave="handleSybbols(false)" ng-click="handleSybbols(true)" class="instruction-symbols" style="color:#2596be; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;">SYMBOLS</span> <span style="color:#ec6249; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;" ng-click="getDynamicInstructions()">INSTRUCTIONS</span> <span style="color:#99301d; cursor: pointer; font-size: 12px; font-weight: 600; text-decoration: underline;" ng-mouseover="handleOverallTestSummaryTooltip(true)" ng-mouseleave="handleOverallTestSummaryTooltip(false)" ng-click="handleOverallTestSummaryTooltip(true)">OVERALL TEST SUMMARY</span><p class="question-header-tittle" style="position: relative; margin-bottom: 0; z-index: 42; width: 240px; text-align: right; font-weight: 700;" ng-style="{\'display\': !isTestScreenExtended ? \'none\' : \'visible\'}">Total Questions Answered: <span style="background-color: #FFFF00; color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsAnswered()}}</span></p><span ng-if="showTooltip" class="newInterfaceSymbols"><span ng-click="handleSybbols(false)" class="newInterfaceSymbolsClose">X</span></span><div ng-if="showOverallTestSummaryTooltip" class="newInterfaceOverallTestSummary"><span ng-click="handleOverallTestSummaryTooltip(false)" class="newInterfaceSymbolsClose">X</span><p style="font-size: 13px; font-weight: 700; background-color:#d6ccb6; padding: 2px; margin: 0px 0px 10px 0px;">Test Summary</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have answered <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsAnswered() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have not answered <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsNotAnswered() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p><p style="font-size: 16px; font-weight: 700; text-align: center;">You have marked for review <span style="color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsBookmarked() || 0}}</span> questions out of <span style="color: red; padding: 4px; margin: 0px;">{{test.sections.length * test.sections[0].questions.length || 0}}</span> questions.</p></div></div><div class="q-possible-states newInterface-sections slim-scrollbar" ng-style="{\'display\': isMobile ? \'visible\' : \'none\'}"><span ng-repeat="section in test.sections track by $index" ng-class="{\'section-box-current\' : currentQuestion.sSNo -1 == $index, \'disabled\': isPartSectionDisabled($index)}" class="section-box" ng-click="jumpToLastViewedQuestionInSection($index + 1)">{{ displaSectionBox($index) }}</span></div><p class="question-header-tittle" style="position: relative; z-index: 42; text-align: right; font-weight: 700;" ng-style="{\'top\': isMobile ? \'8px\' : \'15.4px\', \'right\': isMobile ? \'106px\' : \'14px\', \'margin-left\': isTestScreenExtended ? \'auto\' : \'0\'}">Total Questions Answered: <span style="background-color: #FFFF00; color: red; padding: 4px; margin: 0px;">{{calCulateTotalQuestionsAnswered()}}</span></p><div class="questions-number-holder slim-scrollbar overflow-auto questions-number-section" style="top:68px; bottom: 12px !important; display: flex; flex-direction: column; flex-grow: 1;" ng-class="{ \'cuet-position\': isOptionalSectionQuestion(currentQuestion.sSNo)}"><div class="qnh-inner new-ssc-question-box slim-scrollbar overflow-x-hidden" ng-style="{\'margin-top\': isMobile ? \'42px\' : \'0\'}" ng-show="currentQuestion.sSNo - 1 == $index" id="section{{$index}}" ng-repeat="section in test.sections track by $index"><div class="q-possible-states hide-on-railway" style="display: flex; gap:8px; padding-left: 0; border-bottom: none; padding-bottom: 0;" ng-style="{\'margin-bottom\': isSscNewInterface ? \'24px\' : \'0\', \'justify-content\': isSscNewInterface ? \'center\' : \'\'}"><div ng-if="hasMultipleSubsections(section.SSNo) && test.containOptionalSections && isSscNewInterface" class="subsection-checkbox-container" style="display: flex; gap: 12px; align-items: center; white-space: nowrap; overflow-x: auto; flex: 1; margin-bottom: 10px;" ng-init="ensureSubsectionApplied(section.SSNo)"><div ng-repeat="subsection in getSubsectionsForSection(section.SSNo) track by subsection.SSSNo" class="subsection-checkbox-item" style="display: flex; align-items: center; gap: 10px; min-width: max-content;"><div style="display: flex; gap: 5px; align-items: center; border-radius: 4px; padding: 4px 8px; background-color: #DFE4E8; transition: all 0.2s ease; position: relative;" ng-class="{\'focused\': isSubsectionFocused(section.SSNo, subsection), \'selected\': isSubsectionSelected(section.SSNo, subsection)}" ng-style="{\'background-color\': isSubsectionFocused(section.SSNo, subsection) ? \'#166a84\' : \'#DFE4E8\', \'color\': isSubsectionFocused(section.SSNo, subsection) ? \'#ffffff\' : \'inherit\'}"><div class="tb-popover bottom" ng-if="showSubsectionTooltip && isSubsectionFocused(section.SSNo, subsection) && !isSubsectionSelected(section.SSNo, subsection) && isSscNewInterface" style="position: absolute; top: 100%; left: 0; z-index: 1000; margin-top: 5px; pointer-events: none;"><div class="gd-content">Please click the checkbox beside the optional section to attempt the questions in it</div></div><input type="checkbox" id="subsection_{{$parent.$index}}_{{subsection.SSSNo}}" ng-checked="isSubsectionSelected(section.SSNo, subsection)" ng-disabled="!isSubsectionFocused(section.SSNo, subsection) && !isSubsectionSelected(section.SSNo, subsection)" ng-click="(isSubsectionFocused(section.SSNo, subsection) || isSubsectionSelected(section.SSNo, subsection)) && selectSubsection(section.SSNo, subsection, false, $event)" style="margin: 0; cursor: pointer;" ng-class="{\'checkbox-checked\': isSubsectionSelected(section.SSNo, subsection)}"> <label for="subsection_{{$parent.$index}}_{{subsection.SSSNo}}" style="margin: 0; font-size: 13px; font-weight: 500; cursor: pointer;" ng-click="focusSubsection(section.SSNo, subsection); $event.preventDefault(); $event.stopPropagation();">{{subsection.title}}</label></div></div></div><span class="newInterface-extend" ng-click="handleTestExtend(true)" style="position: absolute; transform: rotate(-90deg); width: 14px; border-left: 15px solid transparent;border-right: 17px solid transparent;border-top: 21px solid #2596be; left: -12px; top:6px"></span> <span ng-if="!hasMultipleSubsections(section.SSNo)" class="mob-sidebar-section" style="background: transparent !important; font-weight: 700;">{{section.title}}</span></div><ul class="newInterfaceList slim-scrollbar hide-on-railway" ng-if="hasSkipOptionSupport && section && ((selectedSubsections && selectedSubsections[section.SSNo]) || (focusedSubsections && focusedSubsections[section.SSNo]) || !hasMultipleSubsections(section.SSNo)) && (!section.subsections || section.isSubsectionDisplay) && (!hasMultipleSubsections(section.SSNo) || (test.containOptionalSections && isSscNewInterface))"><li class="label" ng-repeat="question in section.questions track by $index" ng-class="{ \'bookmarked\' : isBookmarked(section.SSNo, $index+1), \'newInterfaceAttempted\' : isAttempted(section.SSNo, $index+1), \'newInterfaceSkipped\' : isSkipOptionSelected(section.SSNo, $index+1), \'newInterfaceCurrent\': isCurrentQuestion(section.SSNo, $index + 1), \'newInterfaceUnattempted\' : isSkipped(section.SSNo, $index+1), \'newInterfaceBookmarkedAnswered\' : isBookmarked(section.SSNo, $index+1) && isAttempted(section.SSNo, $index+1), \'newInterfaceBookmarkedNotAnswered\' : isSscMarkedArrowAnswerd(question) && isSkipped(question.SSNo, question.qSNo), }" ng-click="sideBarItemClicked(section.SSNo, $index+1)">{{$index + 1}}</li></ul><ul class="newInterfaceList slim-scrollbar hide-on-railway" ng-if="!hasSkipOptionSupport && section && ((selectedSubsections && selectedSubsections[section.SSNo]) || (focusedSubsections && focusedSubsections[section.SSNo]) || !hasMultipleSubsections(section.SSNo)) && (!section.subsections || section.isSubsectionDisplay) && (!hasMultipleSubsections(section.SSNo) || (test.containOptionalSections && isSscNewInterface))"><li class="label" ng-repeat="question in section.questions track by $index" ng-class="{ \'newInterfaceBookmarked\' : isBookmarked(section.SSNo, $index+1), \'newInterfaceAttempted\' : isAttempted(section.SSNo, $index+1), \'newInterfaceSkipped\' : isSkipped(section.SSNo, $index+1), \'newInterfaceCurrent\': isCurrentQuestion(section.SSNo, $index + 1), \'newInterfaceBookmarkedAnswered\' : isBookmarked(section.SSNo, $index+1) && isAttempted(section.SSNo, $index+1), }" ng-click="sideBarItemClicked(section.SSNo, $index+1)">{{$index + 1}}</li></ul><div ng-if="section.subsections && section.subsections.length > 0" class="question-sub-section" ng-repeat="item in section.subsections"><ul class="newInterfaceList slim-scrollbar hide-on-railway" ng-if="section.isSubsectionDisplay && hasSkipOptionSupport"><li class="label" ng-repeat="question in section.questions track by question.qSNo" ng-class="{ \'bookmarked\' : isBookmarked(question.SSNo, question.qSNo), \'newInterfaceAttempted\' : isAttempted(question.SSNo, question.qSNo), \'newInterfaceSkipped\' : isSkipOptionSelected(question.SSNo, question.qSNo), \'newInterfaceCurrent\': isCurrentQuestion(question.SSNo, question.qSNo), \'newInterfaceUnattempted\' : isSkipped(question.SSNo, question.qSNo), \'newInterfaceBookmarkedAnswered\' : isSscMarkedArrowAnswerd(question), }" ng-click="sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li></ul><ul class="newInterfaceList slim-scrollbar hide-on-railway" ng-if="section.isSubsectionDisplay && !hasSkipOptionSupport"><li class="label" ng-repeat="question in section.questions track by question.qSNo" ng-class="{ \'newInterfaceBookmarked\' : isBookmarked(question.SSNo, question.qSNo), \'newInterfaceAttempted\' : isAttempted(question.SSNo, question.qSNo), \'newInterfaceSkipped\' : isSkipped(question.SSNo, question.qSNo), \'newInterfaceCurrent\': isCurrentQuestion(question.SSNo, question.qSNo), \'newInterfaceBookmarkedAnswered\' : isSscMarkedArrowAnswerd(question), }" ng-click="sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li></ul><div class="h5" ng-class="{\'subsection-title-newline\': isSectionalSubmitWithNonSharedTimeFlag, \'subsection-heading-completed\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($index + 1)) === \'completed\', \'subsection-heading-active\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($index + 1)) === \'active\', \'subsection-heading-locked\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($index + 1)) === \'locked\'}" style="margin-top: 30px;" ng-style="{\'margin-left\': isMobile ? \'12px\' : \'\'}"><span><span ng-if="isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($index + 1)) === \'completed\'" class="subsection-state-icon"><img src="/assets/img/sat/tick-black.svg" alt="arrow"></span>{{item.title}}</span> <img src="/assets/img/sat/arrow-down-dark.svg" class="subsection-collapse-arrow" ng-class="{\'pending-subsection\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($index + 1)) !== \'completed\', \'is-hidden\': !isSubsectionalSubmitSection(section)}" alt="arrow"></div><ul class="newInterfaceList hide-on-railway" ng-style="{\'margin-left\': isMobile ? \'8px\' : \'\'}" ng-class="{\'subsection-list-newline\': isSectionalSubmitWithNonSharedTimeFlag}" ng-if="!(isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) === \'completed\')"><li ng-if="hasSkipOptionSupport" class="label" ng-repeat="question in item.questions track by $index" ng-class="{ \'newInterfaceBookmarked\' : isBookmarked(question.SSNo, question.qSNo), \'newInterfaceAttempted\' : isAttempted(question.SSNo, question.qSNo), \'newInterfaceSkipped\' : isSkipOptionSelected(question.SSNo, question.qSNo), \'newInterfaceCurrent\': isCurrentQuestion(question.SSNo, question.qSNo), \'newInterfaceUnattempted\' : isSkipped(question.SSNo, question.qSNo), \'newInterfaceBookmarkedAnswered\' : isSscMarkedArrowAnswerd(question), \'subsection-question-disabled\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\' }" ng-click="!(isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\') && sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li><li ng-if="!hasSkipOptionSupport" class="label" ng-repeat="question in item.questions track by $index" ng-class="{ \'newInterfaceBookmarked\' : isBookmarked(question.SSNo, question.qSNo), \'newInterfaceAttempted\' : isAttempted(question.SSNo, question.qSNo), \'newInterfaceSkipped\' : isSkipped(question.SSNo, question.qSNo), \'newInterfaceCurrent\': isCurrentQuestion(question.SSNo, question.qSNo), \'newInterfaceBookmarkedAnswered\' : isSscMarkedArrowAnswerd(question), \'subsection-question-disabled\': isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\' }" ng-click="!(isSubsectionDrivenActive() && getSubsectionProgressionState(item.SSSNo || ($parent.$index + 1)) !== \'active\') && sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li></ul></div><div class="questionList-states-railway show-on-railway"><ul><li class="new-legend" ng-repeat="question in section.questions track by $index" ng-if="!section.isSubsectionDisplay" ng-class="{ \'reviewed\' : isBookmarked($parent.$index +1, $index+1), \'answered\' : isAttempted($parent.$index +1, $index+1), \'not-answered\': isSkipped($parent.$index + 1, $index + 1), \'current\': isCurrentQuestion($parent.$index + 1, $index + 1) }" ng-click="sideBarItemClicked($parent.$index +1, $index+1)">{{$index + 1}}</li><li class="new-legend" ng-repeat="question in section.questions track by question.qSNo" ng-if="section.isSubsectionDisplay" ng-class="{ \'reviewed\' : isBookmarked(question.SSNo, question.qSNo), \'answered\' : isAttempted(question.SSNo, question.qSNo), \'not-answered\': isSkipped(question.SSNo, question.qSNo), \'current\': isCurrentQuestion(question.SSNo, question.qSNo) }" ng-click="sideBarItemClicked(question.SSNo, question.qSNo)">{{question.qSNo}}</li></ul></div></div><div style="display: flex; flex-direction: column; gap: 2px;"><div class="newInterfaceAnalysis"><p class="nia-tittle">{{ displaSectionBox(currentQuestion.sSNo -1) }} Analysis{{TM}}</p><div class="nia-box"><p class="nia-answer">Answered <span>{{getAnsweredCountForCurrentContext(currentQuestion.sSNo)}}</span></p><p class="nia-not-answer">Not Answered <span>{{getNotAnsweredCountForCurrentContext(currentQuestion.sSNo)}}</span></p><p class="nia-bookmarked">Mark for Review <span>{{getBookmarkedCountForCurrentContext(currentQuestion.sSNo)}}</span></p></div></div></div></div><div class="marks-action-newInterface" ng-if="isSscNewInterface"><button type="button" class="btn new-ssc-footer-action-btn btn-theme btn-block for-all-exams" ng-click="submitBtnPressed()">{{\'Submit Test\' }}</button></div></div></div><div id="sidebar" class="tp-right-box" ng-if="!isSscNewInterface"><button type="button" class="toggle-sidebar-btn js-toggle-sidebar-btn"><i class="tb-icon tb-arrow-left-thin"></i> <i class="tb-icon tb-arrow-right-thin"></i></button><div class="sidebar-content"><div class="student-details"><span class="img" ng-style="{\'background-image\': \'url(\' + dpSrc + \')\'}"></span> <span>{{name}}</span></div><div class="q-possible-states hide-on-railway"><div class="col-xs-4 pad-r0"><span class="u-legend-indicator attempted">{{getAnsweredCount(currentQuestion.sSNo)}}</span> <span class="qps-state"><span>Answered</span><span>Attempted</span></span></div><div class="col-xs-4"><span class="u-legend-indicator bookmarked">{{getBookmarkedCount(currentQuestion.sSNo)}}</span> <span class="qps-state"><span>Marked</span><span>Tagged</span></span></div><div class="col-xs-4 pad-l0"><span class="u-legend-indicator">{{getQuestionsCountOld(currentQuestion.sSNo) - getAnsweredCountOld(currentQuestion.sSNo) - getNotAnsweredCountOld(currentQuestion.sSNo)}}</span> <span class="qps-state">Not Visited</span></div><div class="col-xs-7 pad-r0"><span class="u-legend-indicator bookmarked attempted">{{getBookmarkedAndAttempted(currentQuestion.sSNo)}}</span> <span class="qps-state"><span>Marked and answered</span><span>Attempted & Tagged</span></span></div><div class="col-xs-5 pad-l0"><span class="u-legend-indicator skipped">{{getNotAnsweredCountOld(currentQuestion.sSNo)}}</span> <span class="qps-state"><span>Not Answered</span><span>Unattempted</span></span></div><div class="col-xs-4" ng-if="hasSkipOptionSupport"><span class="u-legend-indicator unattempted">{{getNoOptionMarksCount(currentQuestion.sSNo)}}</span> <span class="qps-state">No option selected</span></div></div><div class="q-possible-states legend-area show-on-railway"><div class="col-xs-6"><span class="new-legend answered">{{getAnsweredCount(currentQuestion.sSNo)}}</span> <span class="qps-state">Questions Answered</span></div><div class="col-xs-6"><span class="new-legend not-answered">{{getNotAnsweredCount(currentQuestion.sSNo)}}</span> <span class="qps-state">Not Answered</span></div><div class="col-xs-6"><span class="new-legend reviewed answered">{{getBookmarkedAndAttempted(currentQuestion.sSNo)}}</span> <span class="qps-state">Review Answered</span></div><div class="col-xs-6"><span class="new-legend reviewed">{{ getBookmarkedCount(currentQuestion.sSNo) - getBookmarkedAndAttempted(currentQuestion.sSNo) }}</span> <span cla
ion in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo - 1 == $index, \'disabled\': !isActiveSection($index) || isPartSectionDisabled($index)}" ng-click="jumpToLastViewedQuestionInSection($index + 1)"><a data-target="#section{{$index}}" class="question-attempted"><span class="hidden-xs">{{section.title || "Overall"}}</span> <span class="visible-xs">{{section.title.slice(0,3) || "Overall"}}</span> <span class="current-active-section" ng-if="isOptionalSectionQuestion(currentQuestion.sSNo)"><svg width="16" height="16" fill="none" viewBox="0 0 22 22" class="warn-circle"><path fill-rule="evenodd" clip-rule="evenodd" d="M11 2a9 9 0 1 0 0 18 9 9 0 0 0 0-18zM.5 11C.5 5.201 5.201.5 11 .5S21.5 5.201 21.5 11 16.799 21.5 11 21.5.5 16.799.5 11z" fill="#F7F8FA"></path><path fill-rule="evenodd" clip-rule="evenodd" d="M11 8.75a.75.75 0 0 1 .75.75V17a.75.75 0 0 1-1.5 0V9.5a.75.75 0 0 1 .75-.75z" fill="#F7F8FA"></path><path d="M12.125 6.125a1.125 1.125 0 1 1-2.25 0 1.125 1.125 0 0 1 2.25 0z" fill="#F7F8FA"></path></svg><div class="tb-popover bottom" ng-if="!isMobile"><div class="po-content"><ul class="pad-0"><li>{{getAnsweredCount(currentQuestion.sSNo)}} Qs. Answered</li><li>You can attempt any {{OptionalSectionQuestionMaximumAttemptedCount(currentQuestion.sSNo)}} Qs. out of {{isTotalSectionQuestionCount(currentQuestion.sSNo)}} Qs.</li></ul></div></div><div class="tb-popover bottom" ng-if="testHoverOptionalQuestion && isMobile"><div class="po-content"><ul class="pad-0"><li>{{getAnsweredCount(currentQuestion.sSNo)}} Qs. Answered</li><li>You can attempt any {{OptionalSectionQuestionMaximumAttemptedCount(currentQuestion.sSNo)}} Qs. out of {{isTotalSectionQuestionCount(currentQuestion.sSNo)}} Qs.</li></ul></div></div></span></a><ul id="section{{$index}}Summary" class="dropdown-menu sections-list-details" role="menu" style="width:250px;" ng-if="isASMInterface"><li><div class="col-xs-12"><h6>{{section.title || "Overall"}}</h6></div></li><li><div class="col-xs-12"><h4><span class="label attempted pull-right">{{getAnsweredCount($index + 1)}}</span><small>Answered</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label skipped pull-right">{{getNotAnsweredCount($index + 1)}}</span><small>Not answered</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label bookmarked pull-right">{{getBookmarkedCount($index + 1)}}</span><small>Marked for Review</small></h4></div></li><li><div class="col-xs-12"><h4><span class="label unattempted-que pull-right">{{test.sections[$index].questions.length - getAnsweredCount($index + 1) - getNotAnsweredCount($index + 1)}}</span><small>Not visited</small></h4></div></li></ul></li></ul><button ng-show="test.sections.length > 6" ng-click="scrollSectionRight()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-right" data-scroll="left"><svg width="17" height="17" viewBox="0 0 17 17"><path fill="#86A1AE" d="M5.104 12.604l4.198-4.208L5.104 4.19l1.292-1.293 5.5 5.5-5.5 5.5z" fill-rule="evenodd"></path></svg></button></ng-container></div><div class="sl-inner" ng-if="isASMInterface"><button ng-show="test.sections.length > 6" ng-click="scrollSectionLeft()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-left" data-scroll="left"><svg viewBox="0 0 17 17" height="32" width="32" class="icon"><path fill="currentColor" d="M8.5 1C4.4 1 1 4.4 1 8.5S4.4 16 8.5 16 16 12.6 16 8.5 12.6 1 8.5 1zm3.7 8.1H7l2.3 2.3-.8.8-3.7-3.7 3.7-3.7.8.8L7 7.9h5.1v1.2z"></path></svg></button> <button ng-show="test.sections.length > 6" ng-click="scrollSectionRight()" type="button" class="btn card-scroll-btn course-nav-scroll intentional-outline left test-scroll-btn-right" data-scroll="left"><svg viewBox="0 0 17 17" height="32" width="32" class="icon"><path fill="currentColor" d="M8.5 1C4.4 1 1 4.4 1 8.5S4.4 16 8.5 16 16 12.6 16 8.5 12.6 1 8.5 1zm0 11.2l-.8-.8L10 9.1H4.9V7.9H10L7.7 5.6l.8-.8 3.7 3.7-3.7 3.7z"></path></svg></button><ul id="sectionNavTabs" style="overflow-x: scroll !important;" tb-auto-scroll class="nav nav-pills sections-list"><li class="dropdown" ng-repeat="section in test.sections track by $index" ng-class="{\'active\' : currentQuestion.sSNo -1 == $index, \'disabled\': !isActiveSection($index) || isPartSectionDisabled($index), \'section-completed\': currentQuestion.sSNo -1 > $index}" ng-click="jumpToLastViewedQuestionInSection($index + 1)" ng-if="!section.isBreak"><a data-target="#section{{$index}}">{{section.title || "Overall"}} <span class="info-icon">!</span></a><ul id="section{{$index}}Summary" ng-if="!section.isNonQuestionSection" class="dropdown-menu sections-list-details" role="menu" style="width:250px; position: relative; top: -5px;"><li><span style="background-color: #25cd71;">{{getAnsweredCount($index + 1)}}</span> Answered</li><li><span style="background-color: #e4174f;">{{getNotAnsweredCountForASM($index + 1)}}</span>Not answered</li><li><span style="background-color: #86a1ae;">{{getBookmarkedCount($index + 1)}}</span>Marked for Review</li><li><span style="background-color: #4788f4;">{{getBookmarkedAndAttempted($index + 1)}}</span>Answered & Marked for Review</li></ul></li></ul></div></div><div class="test-sections-tab" ng-if="isSubSectionPresentForIndex(currentQuestion.sSNo - 1) && !isSectionalSubmitWithNonSharedTimeFlag"><div class="test-sections-tab__inner"><div class="btn btn-tab" ng-click="subSectionClick(item)" ng-class="{\'active\': item.SSSNo == isActiveSubSection}" ng-repeat="item in test.sections[currentQuestion.sSNo - 1].subsections track by $index" title="{{item.title}}"><span>{{item.title}}</span></div></div></div><div class="mob-question-holder" ng-class="{\'holder-section\': isSubSectionPresentForIndex(currentQuestion.sSNo - 1)}"><div id="mainBox" class="test-qpip-holder"><div class="qpip-inner" id="questions" ng-if="isCurTab(\'question\')"><div class="header"><div class="header-inner"><div class="row"><div class="col-xs-3 tp-ques-number pad-r0 pad-t16" ng-if="!isASMInterface"><span class="hidden-xs">Question No. {{currentQuestion.qSNo}}</span> <span class="hidden-lg">{{currentQuestion.qSNo}}.</span></div><div class="col-xs-3 tp-ques-number tp-asm-title pad-r0 pad-t16" ng-if="isASMInterface">{{test.sections[currentQuestion.sSNo -1].title}}</div><div class="col-xs-9 d-flex tp-pos-neg-marks pad-l0" ng-class="{\'asm-ins-btn\':isASMInterface && hasInstructions }"><div class="text-left mar-r8 pad-md-r8" ng-if="!hasTypingTest && !isASMInterface"><div class="font-size-base-1">Marks</div><span class="badge bg-attempted d-inline-block" style="min-width:35px;">+{{getPosMarks()}}</span> <span class="badge bg-skipped d-inline-block" style="min-width:35px;">-{{getNegMarks()}}</span> <span ng-if="hasSkipOptionSupport" class="badge bg-unattempt gernal-tooltip d-inline-block" style="min-width:35px;">-{{getNoOptionMarks()}} <img src="/assets/img/other/info-white.svg" width="12" height="12" alt="info-icon"><span class="tooltiptext"><ol><li>Marks will be deducted if no option is selected in this question.</li><li>If you want to leave this Question unattempted, please mark the last option.</li></ol></span></span></div><div class="text-left mar-r4 pad-md-r8" ng-if="!hasTypingTest" ng-show="!isSpeedComprehension() && !isASMInterface" style="min-width: 40px"><div class="font-size-base-1">Time<div class="pad-h0"><count-up-timer secs="{{questionStartTimeOffsetIfRefresh}}" current-section="{{currentQuestion.sSNo}}" current-question="{{currentQuestion.qSNo}}" hide-zero="y" stop="{{isTestSubmitted || isTimerPaused}}"></count-up-timer></div></div></div><div class="pull-left tp-language-selector" ng-if="!hasTypingTest && languages.length && languages.length >= 1"><div class="form-inline d-flex mar-t4"><div class="form-group" ng-show="languages.length && languages.length > 1 || !checkSdkModeActive" ng-class="{\'d-none\' : isASMInterface}"><label for="language" class="font-size-base-1 control-label hidden-xs">View in</label><select ng-disabled="languages.length == 1" style="color:#86a1ae" id="language" ng-if="!(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed)" ng-model="$root.lang" ng-change="setLanguagesPrompt(lang)" ng-options="lang.prompt for lang in languages"></select><select ng-disabled="languages.length == 1" style="color:#86a1ae" id="language" ng-if="isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed" ng-model="$root.defLang" ng-change="setLanguagesPrompt(lang)" ng-options="lang.prompt for lang in languages"></select></div><div ng-if="isASMInterface && hasInstructions" class="asm-ins-btn"><button type="button" class="btn btn-default mar-t0 mar-l16" ng-click="showInstructionsModal(false)">{{\'View Instructions\' }}</button> <button type="button" class="btn btn-default mar-t0" ng-click="showInstructionsModal(true)">{{\'Useful Data\' }}</button></div></div></div><report-cta ng-if="!isASMInterface" qid="{{getTQDID(currentQuestion.sSNo, currentQuestion.qSNo)}}" chapter-id test-id="{{test._id}}" course-id="{{test.courseid}}" lang="{{$root.lang.name}}" options="Wrong Question,Formatting Issue,Wrong Translation,Others" btn-type module-Type="{{moduleType}}" class="report-this-question"></report-cta></div></div></div><div class="hidden-xs text-size-resize show-on-railway">{{\'Text Size\' }} <button type="button" class="btn js-font-size fs-decrease"><small>A<sup>-</sup></small></button> <button type="button" class="btn js-font-size fs-increase">A<sup>+</sup></button></div></div><div id="question-box" ng-if="!hasTypingTest && !test.sections[currentQuestion.sSNo-1].isNonQuestionSection" class="slim-scrollbar body detailed-question js-detailed-question" ng-class="{\'asm-scroll-view\': isASMInterface}"><div class="slim-scrollbar" ng-class="{\'aei-comprehension\': !isSpeedComprehension(), \'mar-l32\': isSpeedComprehension(), \'asm-scroll-view\' : isASMInterface}" ng-style="getComprehensionStyle(true)" ng-if="hasComprehension()"><div class="mar-b16"><u class="font-weight-semibold"><i>{{\'Comprehension\' }}:</i></u><span class="d-inline-block mar-l16" ng-if="!isSpeedComprehension()">(Que No. {{(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno + 1) + " - " + (test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1)}})</span></div><div class="qns-view-box" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><div class="qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist()" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name)"></div><div class="mar-t32 qns-view-box" ng-if="injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><div class="mar-t32 qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist() && injectTranslation(getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-bind-html="getComprehension(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name)"></div></div><div ng-if="hasSkipOptionSupport && parentIsSkipAlert" style="background-color: #FFE3DC;text-align: center;" class="pad-8"><span>Extra {{skipDurationValue}} Mins allocated for attempting Skipped Qs has been started</span></div><div class="que-ans-box slim-scrollbar" ng-style="getComprehensionStyle(false)" ng-class="{\'asm-scroll-view\': isASMInterface}"><div ng-if="!isSpeedComprehension() && !isFixedComprehension()"><b ng-show="hasComprehension()"><u><i>Question:</i></u></b><div class="qns-view-box" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name)"></div><ul ng-if="isKvsTestInterfaceUsed" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index"><label class="lable-opt label-kvs-q-option">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(option.value)"></div></label></li></ul><div class="qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist()" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name)"></div><ul ng-if="isKvsTestInterfaceUsed && doesSecLangExist()" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index"><label class="lable-opt label-kvs-q-option">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(getSecondaryOptions()[$index].value || \'(Translation Not Available)\')"></div></label></li></ul><div class="mar-t24 qns-view-box" ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)"></div><ul ng-if="injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.lang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.lang.name).name)) && isKvsTestInterfaceUsed" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index"><label class="lable-opt">{{$index+1}}.<div class="mar-l24 qns-view-box" ng-bind-html="parseDesc(option.value)"></div></label></li></ul><div class="mar-t24 qns-view-box" ng-if="(isIbpsTestInterfaceUsed || isKvsTestInterfaceUsed) && doesSecLangExist() && injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-bind-html="getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name)"></div><ul ng-if="isKvsTestInterfaceUsed && doesSecLangExist() && injectTranslation(getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, $root.secLang.name), getQuestionDesc(currentQuestion.sSNo, currentQuestion.qSNo, getFlippedLanguage($root.secLang.name).name))" ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index"><label class="lable-opt"><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))">{{$index+1}}.<div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><p class="text-gray-4" ng-show="isMAMCQ()"><i>*This question may have multiple correct answers.</i></p><ul ng-hide="isNumerical() || isNoShowSection()" class="q-multiple-choices"><li ng-repeat="option in getOptions() track by $index"><label><input type="radio" name="mcqOption" ng-if="!isMAMCQ()" ng-checked="!areAnswersDisabled() && !(isSscNewInterface && isSubsectionMismatch()) && markOptioncheckingInMCQ(option)" ng-click="(isSscNewInterface && isSubsectionMismatch()) ? showSubsectionMismatchTooltip($event) : setOption(option,null,$event)"> <input name="mamcqOption" ng-checked="!areAnswersDisabled() && !(isSscNewInterface && isSubsectionMismatch()) && isOptionSelected(option.prompt)" ng-if="isMAMCQ()" ng-click="(isSscNewInterface && isSubsectionMismatch()) ? showSubsectionMismatchTooltip($event) : setOption(option)" type="checkbox" ng-disabled="areAnswersDisabled()"><div class="mar-l24 qns-view-box" ng-if="!isKvsTestInterfaceUsed" ng-bind-html="parseDesc(option.value)"></div><div class="mar-l24 qns-view-box" ng-if="isKvsTestInterfaceUsed">{{$index+1}}</div><div class="mar-l24 qns-view-box" ng-if="isIbpsTestInterfaceUsed && doesSecLangExist()" ng-bind-html="parseDesc(getSecondaryOptions()[$index].value || \'(Translation Not Available)\')"></div><div class="mar-l24 mar-t8" ng-if="injectTranslation(parseDesc(option.value), parseDesc(getTranslatedOptionByIndex($index).value))"><div class="qns-view-box" ng-bind-html="parseDesc(getTranslatedOptionByIndex($index).value)"></div></div></label></li></ul><div ng-if="test.sections[currentQuestion.sSNo-1].hasDescriptiveQuestions"><div><textarea spellcheck="false" id="answer" class="slim-scrollbar descriptive-ans" ng-model="$parent.typingTestAnswer.value" ng-keyup="getTypingTestAnswer($event)" ng-keydown="getTypingTestAnswer($event)" name="answer" type="text" placeholder="*Start Typing Here*">\n                                        </textarea></div><div class="des-ans-info"><div ng-if="typingTestAnswer.value" id="input-info-char">Characters - <span ng-bind="countInfoCharacters(typingTestAnswer.value)"></span></div><div ng-if="typingTestAnswer.value" id="input-info-words">Words - <span ng-bind="countInfoWords(typingTestAnswer.value)"></span></div></div></div></div><div ng-if="isFixedComprehension()"><div><ul class="q-multiple-choices"><li ng-repeat="question in test.sections[currentQuestion.sSNo - 1].questions | slice:(test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].startQno): test.sections[currentQuestion.sSNo - 1].questions[currentQuestion.qSNo - 1].endQno + 1"><div class="row mar-r16 mar-l16 mar-t16 mar-b16" ng-if="isASMInterface"><div class="row pad-b16" ng-if="isSpatialSection(currentQuestion.sSNo) && isFirstInPage(question.qSNo,10)"><span class="font-weight-bold col-sm-6" style="width:46%">The shortest route from:</span> <span class="font-weight-bold">Passes Building:</span></div><span class="font-weight-bold">Question {{question.qSNo}} &nbsp;</span><div class="report-group font